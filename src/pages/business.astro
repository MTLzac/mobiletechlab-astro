---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Business & Wholesale Device Repair | Mobile Tech Lab Winnipeg";
const description = "Volume device repair and wholesale services for businesses in Winnipeg and Manitoba. Fast turnaround, priority service, and flexible pricing for bulk repairs.";
const canonical = "https://mobiletechlab.ca/business";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Business &amp; Wholesale Device Repair
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        We partner with businesses, schools, and organizations across Manitoba to provide fast, reliable, and cost-effective device repair and refurbishment services.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Business Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Business Services We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Tailored solutions for organizations of all sizes</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: "Bulk Device Repair",
            description: "Send multiple devices at once for volume pricing and priority turnaround. Ideal for businesses, schools, and repair fleets.",
          },
          {
            title: "Corporate Account Setup",
            description: "Establish a business account for streamlined billing, repair tracking, and dedicated support for your organization.",
          },
          {
            title: "Wholesale Refurbishment",
            description: "We buy, refurbish, and resell used devices. Great for businesses upgrading their fleet or clearing old inventory.",
          },
          {
            title: "On-Site Assessment",
            description: "For large volume orders, we can arrange an on-site assessment of your devices before repair.",
          },
          {
            title: "Data Management",
            description: "Certified data wiping and transfer services to ensure your business data is handled securely.",
          },
          {
            title: "Priority Turnaround",
            description: "Business clients receive priority service to minimize downtime and keep your team productive.",
          },
        ].map(service => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold">{service.title}</h3>
            <p class="text-sm text-muted-foreground">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="trade-in" class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-4 text-2xl font-bold md:text-3xl">Sell or Trade In Your Old Devices</h2>
        <p class="mb-8 text-muted-foreground">
          Upgrading your business fleet? We buy used phones, tablets, and laptops. Get instant cash or credit toward repairs and new devices. Contact us to discuss bulk trade-in pricing.
        </p>
        <a
          href="/trade-in"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-6 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          Learn About Trade-In
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Businesses Choose Mobile Tech Lab</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Competitive volume pricing for bulk repairs",
            "Fast turnaround to minimize business downtime",
            "Certified, experienced technicians",
            "Secure data handling and certified wiping",
            "Flexible pickup and drop-off arrangements",
            "Serving Winnipeg, Thompson, and all of Manitoba",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Partner with Us?</h2>
      <p class="mb-8 text-muted-foreground">Contact us to discuss your business repair needs and get a custom quote.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Business Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Us
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
