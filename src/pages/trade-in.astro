---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Sell Your Phone Winnipeg | Get Cash for Used Devices | Mobile Tech Lab";
const description = "Sell your used phone, tablet, or laptop in Winnipeg. Get cash or store credit same-day. Price match guarantee. Free shipping on mail-ins. Working or damaged devices accepted.";
const canonical = "https://mobiletechlab.ca/trade-in";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Trade-In", "item": "https://mobiletechlab.ca/trade-in" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should I repair or sell my phone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on the damage, device age, and current part costs. Minor issues like cracked screens are often worth repairing—compare repair vs. sell to see what makes sense. Our offers are based on current replacement part prices, so you'll always get a fair deal either way."
      }
    },
    {
      "@type": "Question",
      "name": "Can you recover data from my phone before I sell it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We offer Data Recovery & Transfer services for phones, tablets, and laptops. Bundle it with your trade-in for a discount. We'll transfer your photos, contacts, and files to a USB drive or cloud backup before processing your device."
      }
    },
    {
      "@type": "Question",
      "name": "Why won't you buy locked phones?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iCloud-locked or Google FRP-locked devices can't be resold or refurbished legally. We need devices that you can sign out of and unlock before selling. Our payouts are based on current part costs—if parts get cheaper, your payout goes up."
      }
    },
    {
      "@type": "Question",
      "name": "How do I ship my phone to sell?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "After accepting your quote, we'll send you a free prepaid shipping label with tracking. Pack your device securely (we recommend bubble wrap or the original box) and drop it off at any Canada Post location. Our offers reflect real-time part pricing, so you'll get a fair value."
      }
    },
    {
      "@type": "Question",
      "name": "How fast do I get cash for my phone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Drop off in Winnipeg and get paid same-day via cash or E-Transfer. Mail-in devices are processed and paid within 24-48 hours of inspection. Payouts are based on current part costs—we adjust fairly as market prices change."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to erase my phone before selling?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can, but you don't have to. Our team securely wipes or destroys all data from every device during intake. Either way, your personal information is fully protected before we refurbish or recycle the device."
      }
    },
    {
      "@type": "Question",
      "name": "How do I sell my phone in Winnipeg?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Submit your device details through our quote form or drop by our Winnipeg location. We'll assess your phone and provide a cash offer based on the model, condition, and current part costs."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get cash for my used phone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! In-store drop-offs receive same-day cash or E-Transfer. You can also use your payout as store credit toward repairs or a pre-owned device. Our offers are based on real replacement part prices and may change over time."
      }
    }
  ]
};

const howItWorksSteps = [
  { number: 1, icon: "clipboard-list", title: "Get a Quote", description: "Tell us your device's make, model & condition. We send a cash offer right away." },
  { number: 2, icon: "package", title: "Drop Off or Ship", description: "Bring it to our Winnipeg shop or mail it in with free, trackable shipping." },
  { number: 3, icon: "search", title: "We Inspect & Confirm", description: "Our techs verify the device and confirm your payout. If our part cost drops, your payout increases; if parts get more expensive, we adjust fairly." },
  { number: 4, icon: "credit-card", title: "Get Paid Fast", description: "Choose cash, e-transfer or store credit and get paid the same day." }
];

const deviceCategories = [
  {
    icon: "smartphone",
    title: "Sell iPhone & Android Phones",
    description: "We buy working or broken phones—cracked screens, battery issues, water damage. We securely wipe all data before processing.",
    pills: ["iPhone", "Samsung Galaxy", "Google Pixel", "OnePlus", "and more"],
    repairLink: "/repairs/samsung",
    repairLabel: "phone repair"
  },
  {
    icon: "tablet",
    title: "Sell iPad & Tablets",
    description: "Sell your tablet in any condition. We handle data wiping and accept devices with damaged screens or batteries.",
    pills: ["iPad", "Samsung Galaxy Tab", "Surface", "Amazon Fire", "and more"],
    repairLink: "/repairs/ipad",
    repairLabel: "tablet repair"
  },
  {
    icon: "laptop",
    title: "Sell MacBook & Laptops",
    description: "Get cash for your laptop—even older models have value. We securely erase all personal data during intake.",
    pills: ["MacBook", "Windows laptops", "Chromebooks", "Desktop PCs", "and more"],
    repairLink: "/repairs/macbook",
    repairLabel: "laptop repair"
  },
  {
    icon: "gamepad",
    title: "Sell Game Consoles & Games",
    description: "Sell PlayStation, Xbox, Nintendo Switch, Steam Deck, and game discs. Working or with issues.",
    pills: ["PlayStation", "Xbox", "Nintendo Switch", "Steam Deck", "and more"],
    repairLink: "/repair/nintendo-switch",
    repairLabel: "console repair"
  },
  {
    icon: "watch",
    title: "Sell Apple Watch & Wearables",
    description: "Sell your smartwatch or fitness tracker. We buy devices in any cosmetic or functional condition.",
    pills: ["Apple Watch", "Samsung Galaxy Watch", "Fitbit", "and more"],
    repairLink: "/repairs/apple-watch",
    repairLabel: "wearable repair"
  }
];

const advantages = [
  { icon: "dollar-sign", title: "Best Price Guarantee", description: "We use real-time part pricing and beat any advertised local offer. If a competitor publishes a higher payout, show us and we'll match it." },
  { icon: "zap", title: "Fast Payment", description: "Cash, e-transfer or store credit—paid on the same day we receive your device." },
  { icon: "truck", title: "Free Shipping & Drop-Off", description: "Mail it in on us or stop by our convenient Winnipeg locations.", hasLink: true },
  { icon: "recycle", title: "Eco-Friendly Upcycling", description: "Broken tech still has value. We refurbish or responsibly recycle every device to reduce e-waste." }
];

const caseStudySteps = [
  { number: 1, icon: "search", title: "Assessed the Damage", description: "Inspected the bent frame and shattered display to determine if data recovery was possible." },
  { number: 2, icon: "wrench", title: "Installed a Temp Screen", description: "Fitted a working screen temporarily to power on the device and access the data." },
  { number: 3, icon: "hard-drive", title: "Backed Up Everything", description: "Transferred photos, contacts, and files to a secure backup before any further processing." },
  { number: 4, icon: "dollar-sign", title: "Paid Out & Recycled", description: "Confirmed trade-in eligibility, paid the customer same-day, and responsibly recycled the parts." }
];

const faqItems = [
  { question: "Should I repair or sell my phone?", answer: "It depends on the damage, device age, and current part costs. Minor issues like cracked screens are often worth repairing—<a href='/repair-pricing#should-i-repair-or-sell-my-device'>compare repair vs. sell</a> to see what makes sense. Our offers are based on current replacement part prices, so you'll always get a fair deal either way." },
  { question: "Can you recover data from my phone before I sell it?", answer: "Yes! We offer Data Recovery & Transfer services for phones, tablets, and laptops. Bundle it with your trade-in for a discount. We'll transfer your photos, contacts, and files to a USB drive or cloud backup before processing your device." },
  { question: "Why won't you buy locked phones?", answer: "iCloud-locked or Google FRP-locked devices can't be resold or refurbished legally. We need devices that you can sign out of and unlock before selling. Our payouts are based on current part costs—if parts get cheaper, your payout goes up." },
  { question: "How do I ship my phone to sell?", answer: "After accepting your quote, we'll send you a free prepaid shipping label with tracking. Pack your device securely (we recommend bubble wrap or the original box) and drop it off at any Canada Post location. Our offers reflect real-time part pricing, so you'll get a fair value." },
  { question: "How fast do I get cash for my phone?", answer: "Drop off in Winnipeg and get paid same-day via cash or E-Transfer. Mail-in devices are processed and paid within 24-48 hours of inspection. Payouts are based on current part costs—we adjust fairly as market prices change." },
  { question: "Do I need to erase my phone before selling?", answer: "You can, but you don't have to. Our team securely wipes or destroys all data from every device during intake. Either way, your personal information is fully protected before we refurbish or recycle the device." },
  { question: "How do I sell my phone in Winnipeg?", answer: "Submit your device details through our <a href='https://shop.mobiletechlab.ca/pages/repair2' target='_blank' rel='noopener noreferrer'>quote form</a> or drop by our Winnipeg location. We'll assess your phone and provide a cash offer based on the model, condition, and current part costs." },
  { question: "Can I get cash for my used phone?", answer: "Yes! In-store drop-offs receive same-day cash or E-Transfer. You can also use your payout as store credit toward repairs or a <a href='/pre-owned'>pre-owned device</a>. Our offers are based on real replacement part prices and may change over time." }
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Section 1: Hero -->
  <section class="hero-section">
    <div class="hero-circle hero-circle-1"></div>
    <div class="hero-circle hero-circle-2"></div>
    <div class="hero-container">
      <span class="hero-badge">Device Trade-In Program</span>
      <h1 class="hero-headline">Sell Your Phone, Tablet & Laptop in Winnipeg</h1>
      <p class="hero-subheadline">Get top dollar for used, broken or unwanted devices with fast quotes, price match guarantee, and same-day payout.</p>
      <p class="hero-body">We buy iPhones, Androids, iPads, MacBooks and more—even with cracked screens or water damage. Our offers are based on real part costs: if parts get cheaper, your payout goes up, and if they rise, we adjust honestly.</p>
      <div class="hero-ctas">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Get Cash Quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="tel:2045009757" class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call For Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2: How It Works -->
  <section class="section-muted">
    <div class="section-container">
      <h2 class="section-heading">How to Sell Your Device</h2>
      <p class="section-subheading">Selling your device is quick and easy—just four simple steps.</p>
      <div class="steps-grid">
        {howItWorksSteps.map(step => (
          <div class="step-card">
            <div class="step-number">{step.number}</div>
            <div class="step-icon">
              {step.icon === "clipboard-list" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>}
              {step.icon === "package" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>}
              {step.icon === "search" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>}
              {step.icon === "credit-card" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>}
            </div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        ))}
      </div>
      <p class="comparison-link">
        Questions about repair versus selling? <a href="/repair-pricing#should-i-repair-or-sell-my-device">Compare repair vs. sell</a>
      </p>
    </div>
  </section>

  <!-- Section 3: Device Categories -->
  <section class="section-white" id="quote-form">
    <div class="section-container">
      <h2 class="section-heading">Devices We Buy</h2>
      <p class="section-subheading">We buy a wide range of used devices in any condition—working, cracked, or damaged.</p>
      <div class="categories-grid">
        {deviceCategories.map(cat => (
          <div class="category-card">
            <div class="category-icon">
              {cat.icon === "smartphone" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>}
              {cat.icon === "tablet" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>}
              {cat.icon === "laptop" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>}
              {cat.icon === "gamepad" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>}
              {cat.icon === "watch" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="6"/><polyline points="12 10 12 12 13 13"/><path d="m16.13 7.66-.81-4.05a2 2 0 0 0-2-1.61h-2.68a2 2 0 0 0-2 1.61l-.78 4.05"/><path d="m7.88 16.36.8 4a2 2 0 0 0 2 1.61h2.72a2 2 0 0 0 2-1.61l.81-4.05"/></svg>}
            </div>
            <h3 class="category-title">{cat.title}</h3>
            <p class="category-description">{cat.description}</p>
            <div class="category-pills">
              {cat.pills.map(pill => <span class="pill">{pill}</span>)}
            </div>
            <div class="category-actions">
              <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="btn-primary-small">
                Get Cash Quote
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href={cat.repairLink} class="category-repair-link">or get {cat.repairLabel} instead</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Why Trade-In -->
  <section class="section-white">
    <div class="section-container">
      <h2 class="section-heading">Why Sell to Mobile Tech Lab?</h2>
      <p class="section-subheading">Get more cash for your used devices with our straightforward sell program.</p>
      <div class="advantages-grid">
        {advantages.map(adv => (
          <div class="advantage-card">
            <div class="advantage-icon">
              {adv.icon === "dollar-sign" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
              {adv.icon === "zap" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
              {adv.icon === "truck" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>}
              {adv.icon === "recycle" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"/><path d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"/><path d="m14 16-3 3 3 3"/><path d="M8.293 13.596 4.875 9.5l3.418-4.096"/><path d="m7.078 9.5 5.588 9.5"/><path d="m11.5 5 3.418 4.096"/><path d="M11.5 5H7.078l2.156 3.714"/><path d="m14 5 3 3-3 3"/></svg>}
            </div>
            <h3 class="advantage-title">{adv.title}</h3>
            {adv.hasLink ? (
              <p class="advantage-description">Mail it in on us or stop by our convenient <a href="/contact">Winnipeg locations</a>.</p>
            ) : (
              <p class="advantage-description">{adv.description}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: Case Study -->
  <section class="section-muted">
    <div class="section-container">
      <span class="case-study-badge">Real Customer Story</span>
      <h2 class="section-heading">Data Rescued, Device Bought — Even in This Condition</h2>
      <p class="section-subheading">This iPhone XR came to us completely bent and shattered—front and back. The customer just wanted their photos and contacts recovered, not a full repair. Here's how we helped.</p>

      <div class="case-study-images">
        <div class="case-study-image-card">
          <div class="image-badge badge-destructive">Before</div>
          <img src="/assets/trade-in/bent-xr-damaged.png" alt="Severely bent and shattered iPhone XR on Mobile Tech Lab's glass display counter" width="400" height="300" loading="lazy" />
          <p class="image-caption">Device arrived with a completely bent frame and shattered display — seemed beyond repair.</p>
        </div>
        <div class="case-study-image-card">
          <div class="image-badge badge-primary">After</div>
          <img src="/assets/trade-in/bent-xr-recovered.png" alt="Same iPhone XR with temporary screen installed on workbench, powered on after successful data recovery" width="400" height="300" loading="lazy" />
          <p class="image-caption">Temporary screen installed, device powered on, and all data successfully backed up at our workstation.</p>
        </div>
      </div>

      <h3 class="process-heading">How We Did It</h3>
      <div class="process-grid">
        {caseStudySteps.map(step => (
          <div class="process-step">
            <div class="process-number">{step.number}</div>
            <div class="process-icon">
              {step.icon === "search" && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>}
              {step.icon === "wrench" && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>}
              {step.icon === "hard-drive" && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="2" y1="12" y2="12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" x2="6.01" y1="16" y2="16"/><line x1="10" x2="10.01" y1="16" y2="16"/></svg>}
              {step.icon === "dollar-sign" && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
            </div>
            <h4 class="process-title">{step.title}</h4>
            <p class="process-description">{step.description}</p>
          </div>
        ))}
      </div>

      <div class="case-study-cta">
        <h3 class="cta-heading">Think your device is too damaged to sell?</h3>
        <p class="cta-body">You might be surprised. Get a free quote and find out what your device is worth.</p>
        <div class="cta-buttons">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Get a Quote
