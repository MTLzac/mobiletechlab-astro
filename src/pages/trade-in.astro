---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Sell Your Phone Winnipeg | Get Cash for Used Devices | Mobile Tech Lab";
const description = "Sell or trade in your used phone, tablet, or laptop in Winnipeg. Mobile Tech Lab pays cash for used devices. Fast, fair offers on iPhones, Samsung, and more.";
const canonical = "https://mobiletechlab.ca/trade-in";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Sell Your Device for Cash
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Got an old phone, tablet, or laptop sitting around? Mobile Tech Lab pays fair cash prices for used devices — walk in to our Winnipeg or Thompson location today.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call for a Quote
        </a>
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          Get a Repair Quote Instead
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">What Devices We Buy</h2>
      <p class="mb-10 text-center text-muted-foreground">We accept most smartphones, tablets, and laptops — working or not</p>
      <div class="mx-auto max-w-3xl grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          "iPhones (all models)",
          "Samsung Galaxy phones",
          "Google Pixel phones",
          "iPads (all models)",
          "MacBooks",
          "Windows Laptops",
          "Samsung Galaxy Tabs",
          "Other Android phones",
          "Broken or damaged devices",
        ].map(item => (
          <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <span class="text-sm font-medium">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">How the Trade-In Process Works</h2>
        <p class="mb-10 text-center text-muted-foreground">Simple, fast, and transparent</p>
        <div class="grid gap-6 md:grid-cols-3">
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">1</div>
            <h3 class="mb-2 font-semibold">Bring Your Device</h3>
            <p class="text-sm text-muted-foreground">Walk in to our Winnipeg or Thompson location with your device. No appointment needed.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">2</div>
            <h3 class="mb-2 font-semibold">Get an Offer</h3>
            <p class="text-sm text-muted-foreground">We'll assess your device on the spot and give you a fair cash offer within minutes.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">3</div>
            <h3 class="mb-2 font-semibold">Get Paid</h3>
            <p class="text-sm text-muted-foreground">Accept the offer and walk out with cash, or apply it as credit toward a repair or new device.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-4 text-2xl font-bold md:text-3xl">Factors That Affect Your Trade-In Value</h2>
        <p class="mb-8 text-muted-foreground">Understanding what we look at helps you get the best value for your device.</p>
        <div class="grid gap-3 text-left sm:grid-cols-2">
          {[
            "Device model and age",
            "Screen and body condition",
            "Whether it powers on",
            "Storage capacity",
            "Whether iCloud/Google account is removed",
            "Whether original box and accessories are included",
          ].map(factor => (
            <div class="flex items-center gap-2 rounded-lg border border-border bg-card p-3">
              <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm">{factor}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Sell Your Device?</h2>
      <p class="mb-8 text-muted-foreground">Walk in to our Winnipeg location or call us to discuss your device.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Winnipeg: (204) 500-9757
        </a>
        <a
          href="tel:2044100262"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Thompson: (204) 410-0262
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
