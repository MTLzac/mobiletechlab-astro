---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Repair Pricing Explained in Winnipeg | Mobile Tech Lab";
const description = "Transparent repair pricing for phones, tablets, laptops, and consoles in Winnipeg. No hidden fees, free diagnostics, and a 90-day warranty on all repairs.";
const canonical = "https://mobiletechlab.ca/repair-pricing";

const pricingCategories = [
  {
    device: "iPhone",
    repairs: [
      { name: "Screen Replacement", range: "Starting from $79" },
      { name: "Battery Replacement", range: "Starting from $59" },
      { name: "Charging Port Repair", range: "Starting from $69" },
      { name: "Back Glass Replacement", range: "Starting from $89" },
      { name: "Water Damage Recovery", range: "Starting from $99" },
    ],
  },
  {
    device: "Samsung Galaxy",
    repairs: [
      { name: "Screen Replacement", range: "Starting from $89" },
      { name: "Battery Replacement", range: "Starting from $59" },
      { name: "Charging Port Repair", range: "Starting from $69" },
      { name: "Back Glass Replacement", range: "Starting from $79" },
      { name: "Water Damage Recovery", range: "Starting from $99" },
    ],
  },
  {
    device: "iPad",
    repairs: [
      { name: "Screen Replacement", range: "Starting from $99" },
      { name: "Battery Replacement", range: "Starting from $79" },
      { name: "Charging Port Repair", range: "Starting from $79" },
    ],
  },
  {
    device: "MacBook",
    repairs: [
      { name: "Screen Replacement", range: "Starting from $199" },
      { name: "Battery Replacement", range: "Starting from $149" },
      { name: "Keyboard Replacement", range: "Starting from $129" },
      { name: "Logic Board Repair", range: "Quote required" },
    ],
  },
  {
    device: "Game Consoles",
    repairs: [
      { name: "PS5 HDMI Port Repair", range: "Starting from $89" },
      { name: "PS4 HDMI Port Repair", range: "Starting from $79" },
      { name: "Nintendo Switch Screen", range: "Starting from $79" },
      { name: "Joy-Con Drift Fix", range: "Starting from $39" },
      { name: "Xbox HDMI Port Repair", range: "Starting from $79" },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Repair Pricing
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Transparent, fair pricing with no hidden fees. Free diagnostics on all devices. Final price confirmed before any work begins.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get an Exact Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call for Pricing
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Pricing by Device</h2>
      <p class="mb-10 text-center text-muted-foreground">Starting prices — exact quotes provided after free diagnosis</p>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {pricingCategories.map(cat => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-4 text-lg font-semibold text-foreground">{cat.device}</h3>
            <ul class="space-y-3">
              {cat.repairs.map(repair => (
                <li class="flex items-center justify-between border-b border-border pb-2 last:border-0 last:pb-0">
                  <span class="text-sm text-muted-foreground">{repair.name}</span>
                  <span class="text-sm font-medium text-foreground">{repair.range}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-muted-foreground">
        All prices in CAD. Prices vary by model and parts availability. Get a free quote for your exact device.
      </p>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Our Pricing Promise</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Free diagnostics — no charge to assess your device",
            "No hidden fees or surprise charges",
            "Price confirmed before repair begins",
            "90-day warranty on all parts and labour",
            "We use quality OEM and aftermarket parts",
            "No fix, no fee — if we can't fix it, you don't pay",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Get Your Exact Price</h2>
      <p class="mb-8 text-muted-foreground">Submit your device details online for a precise, no-obligation repair quote.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
