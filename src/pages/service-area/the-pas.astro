---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Phone Repair in The Pas, MB | Mobile Tech Lab (via Thompson or Mail-In)";
const description = "The Pas residents: get device repairs via our Thompson location or convenient mail-in service. Phones, tablets, laptops, and consoles. 90-day warranty on all repairs.";
const canonical = "https://mobiletechlab.ca/service-area/the-pas";

const repairs = [
  { name: "iPhone Repair", href: "/repair/iphone" },
  { name: "Samsung Repair", href: "/repair/samsung" },
  { name: "iPad Repair", href: "/repair/ipad" },
  { name: "MacBook Repair", href: "/repair/macbook" },
  { name: "Laptop Repair", href: "/repair/laptop" },
  { name: "PS5 & PS4 Repair", href: "/repair/ps5" },
  { name: "Xbox Repair", href: "/repair/xbox" },
  { name: "Nintendo Switch Repair", href: "/repair/nintendo-switch" },
  { name: "Water Damage Recovery", href: "/repair/water-damage" },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Service Area</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Device Repair for The Pas, MB</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Residents of The Pas can access Mobile Tech Lab repair services through our Thompson location or via mail-in. Fast turnaround, 90-day warranty, and transparent pricing on all repairs.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2044100262"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Thompson: (204) 410-0262
        </a>
      </div>
    </div>
  </section>

  <!-- Two Service Options -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Two Ways to Get Your Device Repaired</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Choose the option that works best for you.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Option 1: Thompson -->
        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class="mb-3 text-xl font-bold text-foreground">Visit Our Thompson Location</h3>
          <p class="mb-4 text-sm text-muted-foreground">
            Our Thompson store is the closest walk-in location to The Pas. Drop in during business hours — no appointment needed.
          </p>
          <ul class="mb-5 space-y-2 text-sm text-muted-foreground">
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> Same-day repairs available</li>
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> Walk-ins welcome</li>
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> Free diagnostics in-store</li>
          </ul>
          <a href="/location/thompson" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
            View Thompson Location
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Option 2: Mail-In -->
        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class="mb-3 text-xl font-bold text-foreground">Mail-In Repair Service</h3>
          <p class="mb-4 text-sm text-muted-foreground">
            Can't travel? Our mail-in service gets your device repaired and returned to your door. Free return shipping on approved repairs.
          </p>
          <ul class="mb-5 space-y-2 text-sm text-muted-foreground">
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> 1–3 business day turnaround</li>
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> Free return shipping included</li>
            <li class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg> 90-day warranty on all repairs</li>
          </ul>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Repair -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Devices We Repair</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Full-service device repair available in-store at Thompson or by mail-in from The Pas.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <a href={repair.href} class="group flex items-center gap-2 rounded-lg border border-border bg-card p-4 hover:border-primary/50 hover:bg-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
            <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{repair.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Ready to Get Your Device Repaired?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Get a free quote online, or call our Thompson location to discuss your repair options. We're here to help.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2044100262"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call Thompson: (204) 410-0262
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
