---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Mail-In Phone & Device Repair for Steinbach, MB | Mobile Tech Lab";
const description = "Steinbach, MB residents: mail-in repair for iPhones, Samsung phones, tablets, laptops, and consoles. Served by Mobile Tech Lab in Winnipeg. 90-day warranty, free return shipping.";
const canonical = "https://mobiletechlab.ca/service-area/steinbach";

const repairs = [
  { name: "iPhone Repair", href: "/repair/iphone" },
  { name: "Samsung Repair", href: "/repair/samsung" },
  { name: "iPad Repair", href: "/repair/ipad" },
  { name: "MacBook Repair", href: "/repair/macbook" },
  { name: "Laptop Repair", href: "/repair/laptop" },
  { name: "PS5 & PS4 Repair", href: "/repair/ps5" },
  { name: "Xbox Repair", href: "/repair/xbox" },
  { name: "Nintendo Switch Repair", href: "/repair/nintendo-switch" },
  { name: "Water Damage Recovery", href: "/repair/water-damage" },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Service Area</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Device Repair for Steinbach, MB</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Mobile Tech Lab serves Steinbach with convenient mail-in device repair. Send us your phone, tablet, laptop, or game console — we fix it and send it back with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- How Mail-In Works -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">How Mail-In Repair Works</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">A simple 4-step process — get your device repaired without leaving Steinbach.</p>
      </div>
      <div class="mx-auto max-w-3xl">
        <ol class="space-y-6">
          {[
            { step: "1", title: "Get a Quote", desc: "Request a quote online or call us to discuss your repair. We confirm pricing upfront before you ship anything." },
            { step: "2", title: "Ship Your Device", desc: "Pack your device securely and ship it to our Winnipeg location via Canada Post or any courier of your choice." },
            { step: "3", title: "We Repair & Test", desc: "Our technicians complete your repair and test the device thoroughly before it's returned to you." },
            { step: "4", title: "We Ship It Back", desc: "Your repaired device ships back to Steinbach with full tracking. Return shipping included on approved repairs." },
          ].map(item => (
            <li class="flex gap-4">
              <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">{item.step}</div>
              <div>
                <h3 class="font-semibold text-foreground">{item.title}</h3>
                <p class="text-sm text-muted-foreground">{item.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- What We Repair -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Repairs Available for Steinbach</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Full-service device repair by mail — the same work we do in-store, delivered to your door.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <a href={repair.href} class="group flex items-center gap-2 rounded-lg border border-border bg-card p-4 hover:border-primary/50 hover:bg-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
            <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{repair.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Why Choose Mobile Tech Lab</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "90-Day Warranty", desc: "Every mail-in repair backed by our 90-day parts and labour warranty." },
          { title: "Free Return Shipping", desc: "Return shipping covered on all approved repairs." },
          { title: "Fast Turnaround", desc: "Most repairs completed within 1–3 business days of receiving your device." },
          { title: "Upfront Pricing", desc: "Full repair quote provided before any work begins — no surprises." },
          { title: "Experienced Technicians", desc: "Certified techs who've successfully repaired thousands of Manitoba devices." },
          { title: "Safe & Secure", desc: "We handle your device with care and return it securely packaged." },
        ].map(item => (
          <div class="flex gap-3">
            <div class="mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Get Your Device Repaired from Steinbach</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Start with a free quote online or give us a call. Fast mail-in repair with a 90-day warranty, shipped right back to you.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
