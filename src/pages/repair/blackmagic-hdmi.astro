        <a href="#faqs" class="toc-link block rounded-md px-2 py-1.5 text-sm text-muted-foreground hover:bg-muted transition-colors" data-section="faqs">FAQs</a>
      </nav>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('toc-toggle');
    const popover = document.getElementById('toc-popover');
    const iconClosed = document.getElementById('toc-icon-closed');
    const iconOpen = document.getElementById('toc-icon-open');
    let isOpen = false;

    toggle?.addEventListener('click', () => {
      isOpen = !isOpen;
      popover?.classList.toggle('hidden', !isOpen);
      iconClosed?.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
    });

    const sections = ['proof', 'process', 'why-choose-us', 'locations', 'faqs'];
    const links = document.querySelectorAll('.toc-link');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          links.forEach((link) => {
            const isActive = link.getAttribute('data-section') === entry.target.id;
            link.classList.toggle('bg-primary/10', isActive);
            link.classList.toggle('font-medium', isActive);
            link.classList.toggle('text-primary', isActive);
          });
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  </script>
