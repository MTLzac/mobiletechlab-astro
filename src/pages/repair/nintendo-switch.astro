---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Nintendo Switch Repair Winnipeg | Joy-Con Drift Fix | Mobile Tech Lab";
const description = "Expert Nintendo Switch repair in Winnipeg. Joy-Con drift fixes, screen replacements, charging port repair, and battery replacement. 90-day warranty.";
const canonical = "https://mobiletechlab.ca/repair/nintendo-switch";

const repairs = [
  { name: "Joy-Con Drift Fix", description: "Characters moving on their own? Joy-Con drift is one of the most common Switch issues. We replace the analog sticks to fix drift permanently." },
  { name: "Screen Replacement", description: "Cracked or damaged Switch screen? We replace the LCD display on Nintendo Switch, Switch Lite, and Switch OLED models." },
  { name: "Charging Port Repair", description: "Nintendo Switch not charging? We repair USB-C charging ports on all Switch models to restore reliable charging." },
  { name: "Battery Replacement", description: "Switch not holding a charge? We replace batteries on all Nintendo Switch models to restore full portable playtime." },
  { name: "Button & Rail Repair", description: "Buttons sticking or Joy-Con not attaching properly? We repair button mechanisms and Joy-Con rail assemblies." },
  { name: "Fan & Cooling Service", description: "Switch running hot or fan loud? We clean dust buildup and service the cooling system to prevent overheating and throttling." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="text-center md:text-left">
          <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
            Nintendo Switch Repair in Winnipeg
          </h1>
          <p class="mb-8 text-lg text-muted-foreground">
            Expert Nintendo Switch repair for all models. Joy-Con drift, cracked screens, charging issues — fast repairs with a 90-day warranty.
          </p>
          <div class="flex flex-col sm:flex-row items-center md:items-start justify-center md:justify-start gap-3">
            <a
              href="https://shop.mobiletechlab.ca/pages/repair2"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
            >
              Get a Free Quote
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="tel:2045009757"
              class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              (204) 500-9757
            </a>
          </div>
        </div>
        <div class="flex justify-center">
          <img
            src="/assets/nintendo-switch-hero.png"
            alt="Nintendo Switch repair showing common issues including Joy-Con drift, cracked screen, unresponsive screen, button issues, charging problems, and battery issues"
            width="600"
            height="450"
            loading="eager"
            class="max-w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Nintendo Switch Repairs We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Switch, Switch Lite, and Switch OLED repairs — walk in or get a quote online</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Us for Nintendo Switch Repair?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "We service original Switch, Switch Lite, and Switch OLED",
            "Quality analog sticks to permanently fix Joy-Con drift",
            "90-day warranty on all Switch repairs",
            "Free diagnostic before any repair begins",
            "Experienced console repair technicians",
            "Walk-ins welcome at our Winnipeg location",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Fix Your Nintendo Switch?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to our Winnipeg location.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
