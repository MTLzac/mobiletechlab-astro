---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Microsoft Surface Repair in Manitoba | MobileTechLab";
const description = "Expert Microsoft Surface repair in Winnipeg. Screen replacements, battery service, keyboard/type cover, and charging issues for Surface Pro, Go, and Laptop. 90-day warranty.";
const canonical = "https://mobiletechlab.ca/repair/surface";

const repairs = [
  { name: "Screen Replacement", description: "Cracked Surface screen? We replace displays on Surface Pro, Surface Go, Surface Laptop, and Surface Book models." },
  { name: "Battery Replacement", description: "Surface not holding a charge? We replace batteries on compatible Surface models to restore full battery life." },
  { name: "Type Cover / Keyboard Issues", description: "Surface keyboard not responding or connecting? We diagnose Type Cover connector issues and keyboard hardware faults." },
  { name: "Charging Port Repair", description: "Surface Connector or USB-C not charging? We repair and replace charging ports on all Surface models." },
  { name: "Kickstand Repair", description: "Surface kickstand broken or not holding position? We repair and replace the kickstand hinge assembly." },
  { name: "Water Damage Recovery", description: "Surface exposed to liquid? We perform professional disassembly, cleaning, and board-level diagnostics." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Microsoft Surface Repair in Winnipeg
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Professional Microsoft Surface repair for Surface Pro, Surface Go, Surface Laptop, and Surface Book. Screen, battery, and charging issues fixed with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Surface Repairs We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Covering all common Microsoft Surface issues — walk in or get a quote online</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Us for Surface Repair?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Repairs for Surface Pro, Go, Laptop, and Book",
            "Quality replacement parts for Surface devices",
            "90-day warranty on all repairs",
            "Free diagnostic before any repair begins",
            "Experienced technicians with Microsoft Surface hardware",
            "Walk-ins welcome — no appointment needed",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Fix Your Surface?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to our Winnipeg location.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
