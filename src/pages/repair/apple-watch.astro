---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Apple Watch Repair Winnipeg | Screen & Battery Replacement";
const description = "Expert Apple Watch repair in Winnipeg. Screen replacement, battery service, and general Apple Watch repairs for all series. 90-day warranty on all repairs.";
const canonical = "https://mobiletechlab.ca/repair/apple-watch";

const repairs = [
  { name: "Screen Replacement", description: "Cracked Apple Watch screen? We replace OLED display assemblies on Apple Watch Series 3 through Ultra — restoring the original look and touch functionality." },
  { name: "Battery Replacement", description: "Apple Watch not lasting a full day? We replace Apple Watch batteries on all series using quality cells to restore your watch's battery life." },
  { name: "Charging Issues", description: "Apple Watch not charging or charging slowly? We diagnose charging hardware and Crown/Digital Crown issues affecting power delivery." },
  { name: "Crown & Button Repair", description: "Digital Crown not responding or stuck? We repair and replace the Digital Crown and side button on Apple Watch models." },
  { name: "Band Port Repair", description: "Band not releasing or locking properly? We repair band attachment mechanisms on all Apple Watch models." },
  { name: "Water Damage Recovery", description: "Apple Watch exposed to salt water or damaged beyond IP rating? We perform diagnostics and attempt component-level recovery." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Apple Watch Repair in Winnipeg
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Professional Apple Watch repair for all series. Cracked screen, dead battery, or charging issues — our technicians deliver reliable repairs with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Apple Watch Repairs We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Covering all common Apple Watch issues — walk in or get a quote online</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Us for Apple Watch Repair?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Repairs for Apple Watch Series 3 through Ultra",
            "Quality OEM and aftermarket Apple Watch parts",
            "90-day warranty on all repairs",
            "Free diagnostic before any repair begins",
            "Experienced technicians with Apple Watch expertise",
            "Walk-ins welcome — no appointment needed",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Fix Your Apple Watch?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to our Winnipeg location.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
