---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "iPod Repair Winnipeg | Screen, Battery & Data Recovery";
const description = "iPod repair specialists in Winnipeg. Screen, battery, charging port, home button repair and data recovery for all iPod Touch, Classic, Nano and Shuffle generations.";
const canonical = "https://mobiletechlab.ca/repair/ipod";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "iPod Repair", "item": "https://mobiletechlab.ca/repair/ipod" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "iPod Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Electronics Repair",
  "url": "https://mobiletechlab.ca/repair/ipod",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "iPod Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Home Button and Click Wheel Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Data Recovery" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Free Diagnostics" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Do you still repair older iPod models in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all iPod generations including iPod Classic, Nano, Shuffle, Mini, and all seven generations of iPod Touch. We maintain legacy parts suppliers specifically for discontinued Apple devices, so we can still service models that most repair shops stopped supporting years ago." } },
    { "@type": "Question", "name": "Can you recover music from a broken iPod in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "In many cases yes — we offer data recovery services for damaged, water-damaged, and non-booting iPods. Recovery success depends on the nature of the failure, and we assess the device before charging anything so you know what's possible before committing." } },
    { "@type": "Question", "name": "How long does an iPod repair take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most iPod Touch repairs are completed same-day in 1–2 hours at our Winnipeg St. Vital location. iPod Classic, Nano, and Shuffle repairs may take 1–3 business days depending on parts availability for your specific model and generation." } },
    { "@type": "Question", "name": "Is it worth repairing my old iPod?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the model and the repair needed — a battery replacement on an iPod Touch 7th Gen often makes great financial sense, while a screen repair on a 1st Gen iPod Nano may cost more than the device is worth. We always give you an honest assessment before starting any repair so you can make an informed decision." } },
    { "@type": "Question", "name": "Do you repair iPod Classic click wheels in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair and replace click wheel assemblies on iPod Classic and Nano models. Click wheel issues are one of the most common failures on older iPods and parts are still available for most generations, though availability varies — contact us to confirm your model." } },
    { "@type": "Question", "name": "Can you replace the battery in an iPod Classic?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — iPod Classic battery replacement is one of our most requested legacy repairs and can dramatically extend the life of your device. We use quality replacement cells and the repair typically takes 1–2 business days depending on parts availability." } },
    { "@type": "Question", "name": "Do you repair iPod Touch screens in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we replace cracked and unresponsive screens on all seven generations of iPod Touch at our Winnipeg shop. Most iPod Touch screen replacements are completed same-day and carry a warranty depending on the part tier selected." } },
    { "@type": "Question", "name": "Can you fix an iPod that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive iPod is often caused by a fully depleted battery, a failed display connection, or a corrupted firmware issue. We run free diagnostics to identify the root cause before recommending any repair." } },
    { "@type": "Question", "name": "Do you offer a warranty on iPod repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — screen repairs carry a 30-day to lifetime warranty depending on the part tier. Battery replacements include a 90-day warranty, and most other repairs carry a lifetime warranty on parts and labour — even on legacy iPod models." } },
    { "@type": "Question", "name": "Do you repair iPods in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts iPod repairs and walk-ins Monday through Saturday 10AM–6PM. For older or less common iPod models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="ip-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="ip-container">
      <ol class="ip-breadcrumb-list">
        <li><a href="/" class="ip-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ip-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="ip-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ip-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="ip-breadcrumb-current" aria-current="page">iPod Repair</li>
      </ol>
    </div>
  </nav>

  <section class="ip-hero-section" id="hero">
    <div class="ip-hero-inner">
      <div class="ip-hero-content">
        <div class="ip-hero-badge-row">
          <span class="ip-service-badge">Legacy iPod Repair Specialists</span>
          <span class="ip-location-badge">
            <span class="ip-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="ip-location-badge">
            <span class="ip-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="ip-hero-headline">
          iPod Repair <span class="ip-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="ip-hero-subheadline">iPod Touch, Classic, Nano & Shuffle Repair Specialists</p>

        <div class="ip-hero-body">
          <p>Still using your iPod? We repair all iPod generations at our Winnipeg shop — from the original iPod Mini through iPod Classic, Nano, Shuffle, and all seven generations of iPod Touch. Common repairs include screen replacements, battery swaps, charging port fixes, home button repairs, click wheel issues, and data recovery from damaged or non-booting devices.</p>
          <p>As a discontinued product line, iPod parts are increasingly scarce — but we've maintained relationships with legacy parts suppliers so we can keep your device running long after Apple stopped supporting it. We'll always give you an honest assessment of whether repair makes financial sense before touching your device.</p>
        </div>

        <div class="ip-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="ip-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="ip-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="ip-hero-image-wrapper">
        <img
          src="/assets/hero-ipod-DzgjphDN.png"
          alt="iPod repair in Winnipeg — Touch, Classic, Nano and Shuffle specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="ip-services-section" id="services">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">iPod Repair Services in Winnipeg</h2>
        <p class="ip-section-subtitle">Expert repairs for all iPod models. Legacy parts stocked, honest advice, warranty included.</p>
      </div>
      <div class="ip-services-grid">
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ip-service-title">Screen Replacement</h3>
          <p class="ip-service-body">Cracked or unresponsive iPod Touch display? We replace LCD and touchscreen panels on all iPod Touch generations (1st through 7th). iPod Classic and Nano screen replacements are also available subject to parts availability — contact us to confirm your specific model before bringing it in.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="ip-service-title">Battery Replacement</h3>
          <p class="ip-service-body">iPod not holding a charge or dying after a few songs? We replace degraded batteries across all iPod lines including Touch, Classic, Nano, and Mini. Battery availability for older generations may vary — we'll confirm before starting the repair.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="ip-service-title">Charging Port Repair</h3>
          <p class="ip-service-body">iPod not charging or syncing? We repair and replace Lightning connectors on iPod Touch models and the 30-pin dock connector on older iPod Classic, Nano, and Mini models. Most charging port repairs are completed same-day.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="ip-service-title">Home Button & Click Wheel</h3>
          <p class="ip-service-body">Home button unresponsive on your iPod Touch? Click wheel not registering on your iPod Classic or Nano? We repair and replace both home buttons and click wheel assemblies across all generations.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3 class="ip-service-title">Data Recovery</h3>
          <p class="ip-service-body">Lost access to your music library, playlists, or photos stored on your iPod? We offer data recovery services for damaged, water-damaged, or non-booting iPods. Recovery success depends on the nature of the failure — we assess the device before charging anything.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="ip-service-title">Free Diagnostics</h3>
          <p class="ip-service-body">Not sure what's wrong with your iPod or whether it's worth repairing? We run a full diagnostic at no charge and give you an honest recommendation — including whether the repair cost makes sense given the device's current value and parts availability.</p>
        </div>
      </div>
      <div class="ip-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="ip-models-section" id="models">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">All iPod Models We Repair in Winnipeg</h2>
        <p class="ip-section-subtitle">From the original iPod Mini to the final iPod Touch 7th Gen</p>
      </div>
      <div class="ip-models-grid">
        <div class="ip-model-card">
          <div class="ip-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ip-model-title">iPod Touch</h3>
          <p class="ip-model-description">All seven generations of iPod Touch. Screen, battery, charging port, and home button repairs available. The 7th Gen is the most recent and parts are still readily available.</p>
          <div class="ip-model-pills">
            <span class="ip-pill">iPod Touch 7th Gen</span>
            <span class="ip-pill">iPod Touch 6th Gen</span>
            <span class="ip-pill">iPod Touch 5th Gen</span>
            <span class="ip-pill">iPod Touch 4th Gen</span>
            <span class="ip-pill">iPod Touch 3rd Gen</span>
            <span class="ip-pill">iPod Touch 2nd Gen</span>
            <span class="ip-pill">iPod Touch 1st Gen</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ip-model-card">
          <div class="ip-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="ip-model-title">iPod Classic</h3>
          <p class="ip-model-description">Click wheel iPods with high-capacity hard drives. Battery replacements and hard drive upgrades are the most common Classic repairs. Screen and click wheel parts available for most generations.</p>
          <div class="ip-model-pills">
            <span class="ip-pill">iPod Classic 7th Gen</span>
            <span class="ip-pill">iPod Classic 6th Gen</span>
            <span class="ip-pill">iPod Classic 5th Gen</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ip-model-card">
          <div class="ip-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="7" y="2" width="10" height="20" rx="2" ry="2"/></svg>
          </div>
          <h3 class="ip-model-title">iPod Nano</h3>
          <p class="ip-model-description">Compact click wheel and touchscreen Nano models. Battery and screen repairs available for most generations — parts availability varies, contact us to confirm your model.</p>
          <div class="ip-model-pills">
            <span class="ip-pill">iPod Nano 7th Gen</span>
            <span class="ip-pill">iPod Nano 6th Gen</span>
            <span class="ip-pill">iPod Nano 5th Gen</span>
            <span class="ip-pill">iPod Nano 4th Gen</span>
            <span class="ip-pill">iPod Nano 3rd Gen</span>
            <span class="ip-pill">iPod Nano 2nd Gen</span>
            <span class="ip-pill">iPod Nano 1st Gen</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ip-model-card">
          <div class="ip-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <h3 class="ip-model-title">iPod Shuffle & Mini</h3>
          <p class="ip-model-description">Ultra-compact and colourful legacy iPods. Battery replacement is the most common repair for Shuffle and Mini models. Contact us to confirm parts availability for your generation.</p>
          <div class="ip-model-pills">
            <span class="ip-pill">iPod Shuffle 4th Gen</span>
            <span class="ip-pill">iPod Shuffle 3rd Gen</span>
            <span class="ip-pill">iPod Shuffle 2nd Gen</span>
            <span class="ip-pill">iPod Shuffle 1st Gen</span>
            <span class="ip-pill">iPod Mini 2nd Gen</span>
            <span class="ip-pill">iPod Mini 1st Gen</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-why-section" id="why-choose-us">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">The Mobile Tech Lab Advantage: Winnipeg's Legacy iPod Repair Experts</h2>
        <p class="ip-section-subtitle">Why Winnipeg customers trust us with their classic iPods</p>
      </div>
      <div class="ip-pillars-grid">
        <div class="ip-pillar-card">
          <div class="ip-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="ip-pillar-title">Legacy Device Specialists</h3>
          <p class="ip-pillar-body">Most repair shops stopped stocking iPod parts years ago — we didn't. We maintain supplier relationships specifically for discontinued Apple devices so we can still service your iPod Classic, Nano, and early Touch models when others can't.</p>
        </div>
        <div class="ip-pillar-card">
          <div class="ip-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3 class="ip-pillar-title">Data Recovery Experts</h3>
          <p class="ip-pillar-body">Your iPod may hold music, playlists, and memories that aren't backed up anywhere else. We specialise in recovering data from damaged, water-damaged, and non-booting iPods — assessing recovery feasibility before charging you anything.</p>
        </div>
        <div class="ip-pillar-card">
          <div class="ip-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <h3 class="ip-pillar-title">Honest Repair vs Replace Advice</h3>
          <p class="ip-pillar-body">With discontinued devices, repair costs can sometimes exceed the device's value. We'll always give you a straight assessment — if repair doesn't make financial sense, we'll tell you and suggest alternatives rather than taking your money.</p>
        </div>
        <div class="ip-pillar-card">
          <div class="ip-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="ip-pillar-title">Warranty on Every Repair</h3>
          <p class="ip-pillar-body">Screen repairs carry a 30-day to lifetime warranty depending on part tier. Battery replacements are covered for 90 days. All other repairs include a lifetime warranty on parts and labour — even on legacy devices.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-cost-section" id="pricing">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">Worried About Repair Cost? You Have Options.</h2>
        <p class="ip-section-subtitle">Most customers use one of these options to lower their repair cost.</p>
      </div>
      <div class="ip-cost-grid">
        <div class="ip-cost-card">
          <div class="ip-cost-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="ip-cost-title">We'll Match Any Local Repair Price</h3>
          <p class="ip-cost-body">Found a lower price at another Winnipeg repair shop? We'll match it — so you don't overpay. No pressure. No hassle.</p>
          <a href="sms:2045009757?body=Hey%20Mobile%20Tech%20Lab!%20I%20want%20a%20better%20price%20on%20a%20repair!" class="ip-price-match-btn">
            Check If We Can Match Your Price
          </a>
        </div>
        <div class="ip-cost-card">
