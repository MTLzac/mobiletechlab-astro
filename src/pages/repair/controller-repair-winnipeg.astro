---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Controller Repair Winnipeg | Xbox & PS5 Controller Repair";
const description = "Expert game controller repair in Winnipeg. Joystick drift, button replacement, and trigger repairs for PlayStation, Xbox, Nintendo Switch, and Steam Deck controllers.";
const canonical = "https://mobiletechlab.ca/repair/controller-repair-winnipeg";

const repairs = [
  { name: "Joystick Drift Repair", description: "Analog stick drifting on its own? We replace thumbstick modules on PS5 DualSense, PS4 DualShock 4, Xbox, Joy-Con, and Steam Deck controllers." },
  { name: "Button Replacement", description: "Sticky, stuck, or broken face buttons? We replace individual buttons and button membranes on all controller types." },
  { name: "Trigger Repair", description: "Triggers not registering, squeaking, or physically damaged? We repair and replace L1/L2, R1/R2, LT/RT trigger assemblies." },
  { name: "Bumper Repair", description: "Bumpers broken or not clicking properly? We repair and replace bumper mechanisms on all major controller models." },
  { name: "USB & Charging Port Repair", description: "Controller not charging via USB-C or Micro-USB? We repair charging ports on DualSense, DualShock 4, Xbox, and other controllers." },
  { name: "D-Pad & Touchpad Repair", description: "D-pad not registering directions or touchpad unresponsive on PS controllers? We diagnose and repair these input components." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Controller Repair in Winnipeg
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Expert game controller repair for PlayStation, Xbox, Nintendo Switch, and Steam Deck controllers. Joystick drift, button issues, and trigger repairs with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Controller Repairs We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Covering all major controller brands — walk in or get a quote online</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-8 text-center text-2xl font-bold md:text-3xl">Controllers We Service</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {["PS5 DualSense", "PS4 DualShock 4", "Xbox Series Controller", "Xbox One Controller", "Nintendo Joy-Con", "Nintendo Switch Pro", "Steam Deck Controller", "8BitDo Controllers", "Other third-party controllers"].map(controller => (
            <div class="rounded-lg border border-border bg-background px-4 py-3 text-center text-sm font-medium">
              {controller}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Fix Your Controller?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to our Winnipeg location. Most controller repairs done same day.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
