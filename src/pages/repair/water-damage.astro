---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Water & Liquid Damage Repair Winnipeg | Mobile Tech Lab";
const description = "Professional water damage repair for phones, tablets, and laptops in Winnipeg. Ultrasonic cleaning, board-level diagnostics, and component repair. Act fast for best results.";
const canonical = "https://mobiletechlab.ca/repair/water-damage";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Water &amp; Liquid Damage Repair
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Dropped your phone in water? Spilled liquid on your laptop? Act fast — the sooner you bring it in, the better the chance of recovery. Our Winnipeg technicians use professional cleaning and diagnostics to save water-damaged devices.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Now: (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">What to Do Immediately After Water Damage</h2>
        <p class="mb-10 text-center text-muted-foreground">Quick action significantly improves recovery chances</p>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            { do: true, text: "Power off the device immediately" },
            { do: true, text: "Remove any case, SIM card, and accessories" },
            { do: true, text: "Gently pat dry with a clean cloth" },
            { do: true, text: "Bring it to us as soon as possible" },
            { do: false, text: "Do NOT press buttons or try to charge it" },
            { do: false, text: "Do NOT put it in rice — this is a myth" },
            { do: false, text: "Do NOT use a hair dryer or heat" },
            { do: false, text: "Do NOT turn it on to 'test' if it works" },
          ].map(item => (
            <div class={`flex items-center gap-3 rounded-lg border p-4 ${item.do ? 'border-border bg-card' : 'border-border bg-card'}`}>
              <div class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-full ${item.do ? 'bg-primary/10 text-primary' : 'bg-destructive/10 text-destructive'}`}>
                {item.do
                  ? <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  : <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                }
              </div>
              <span class="text-sm font-medium">{item.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Our Water Damage Recovery Process</h2>
        <p class="mb-10 text-center text-muted-foreground">Professional multi-step recovery for the best results</p>
        <div class="grid gap-6 md:grid-cols-3">
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">1</div>
            <h3 class="mb-2 font-semibold">Disassembly</h3>
            <p class="text-sm text-muted-foreground">We carefully disassemble the device to access all internal components and assess the extent of the damage.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">2</div>
            <h3 class="mb-2 font-semibold">Ultrasonic Cleaning</h3>
            <p class="text-sm text-muted-foreground">We use an ultrasonic cleaner with a specialized solution to remove corrosion and mineral deposits from the circuit board.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-background p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">3</div>
            <h3 class="mb-2 font-semibold">Diagnosis & Repair</h3>
            <p class="text-sm text-muted-foreground">After cleaning, we test all components and replace any that were damaged by the liquid exposure.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-4 text-2xl font-bold md:text-3xl">Devices We Recover</h2>
        <p class="mb-8 text-muted-foreground">We handle water damage recovery for all major device types:</p>
        <div class="grid gap-3 sm:grid-cols-2 text-left">
          {["iPhones (all models)", "Samsung Galaxy phones", "Android phones", "iPads and tablets", "MacBooks", "Windows Laptops", "Google Pixel phones", "Other smartphones"].map(device => (
            <div class="flex items-center gap-2 rounded-lg border border-border bg-card p-3">
              <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm">{device}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Don't Wait — Act Now</h2>
      <p class="mb-8 text-muted-foreground">Every minute counts with water damage. Bring your device in or call us immediately.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Now: (204) 500-9757
        </a>
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          Get a Quote Online
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
