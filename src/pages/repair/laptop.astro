---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Laptop Repair Winnipeg | Asus, Acer, Lenovo, HP, Dell & More";
const description = "Expert laptop repair in Winnipeg for all brands including HP, Dell, Lenovo, Asus, and Acer. Screen replacements, keyboard repairs, battery service, and more.";
const canonical = "https://mobiletechlab.ca/repair/laptop";

const repairs = [
  { name: "Screen Replacement", description: "Cracked or dead laptop screen? We replace LCD and LED displays on all brands and sizes, from 11-inch to 17-inch laptops." },
  { name: "Battery Replacement", description: "Laptop not holding a charge? We replace batteries on HP, Dell, Lenovo, Asus, Acer, and other major brands." },
  { name: "Keyboard Replacement", description: "Broken or sticky keys? We replace full keyboard assemblies on most laptop models quickly and affordably." },
  { name: "Charging Port Repair", description: "Laptop not charging? We repair DC jack, USB-C, and proprietary charging ports on all laptop brands." },
  { name: "RAM & SSD Upgrades", description: "Slow laptop? We upgrade RAM and replace hard drives with faster SSDs to dramatically improve performance." },
  { name: "Virus & Malware Removal", description: "Laptop running slow or acting strange? We perform thorough virus scans, malware removal, and OS optimization." },
  { name: "Cooling System Service", description: "Laptop overheating? We clean fans, replace thermal paste, and service cooling systems to prevent overheating damage." },
  { name: "Water Damage Recovery", description: "Spilled liquid on your laptop? Bring it in immediately for professional cleaning and component assessment." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Laptop Repair in Winnipeg
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Expert repairs for all laptop brands — HP, Dell, Lenovo, Asus, Acer, and more. Screen replacements, battery service, keyboard repairs, and software fixes with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Laptop Repairs We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Covering all common laptop issues — walk in or get a quote online</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Laptop Brands We Service</h2>
        <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-4 max-w-2xl mx-auto">
          {["HP", "Dell", "Lenovo", "Asus", "Acer", "Microsoft Surface", "Toshiba", "Samsung"].map(brand => (
            <div class="rounded-lg border border-border bg-background px-4 py-3 text-center text-sm font-medium">
              {brand}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Us for Laptop Repair?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Repairs for all major laptop brands",
            "Quality replacement parts and components",
            "90-day warranty on all repairs",
            "Free diagnostic before any repair",
            "Experienced technicians with Windows and Linux expertise",
            "Walk-ins welcome — no appointment needed",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Fix Your Laptop?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to our Winnipeg location.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
