        </details>
        <details class="lg-faq-item">
          <summary class="lg-faq-summary">
            <span>Is it worth repairing my LG phone in Winnipeg?</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="lg-faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m6 9 6 6 6-6"/></svg>
