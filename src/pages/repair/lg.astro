---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "LG Phone Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "LG phone repair specialists in Winnipeg. Screen, battery, charging port repair for LG Velvet, Wing, V series, G series, Stylo & all legacy models. Parts still available.";
const canonical = "https://mobiletechlab.ca/repair/lg";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "LG Phone Repair", "item": "https://mobiletechlab.ca/repair/lg" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "LG Phone Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repair/lg",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "LG Phone Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Speaker and Boombox Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Power and Button Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Do you still repair LG phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we're one of the few repair shops in Winnipeg still specialising in LG devices after the brand exited the smartphone market in 2021. We maintained our supplier relationships specifically to keep supporting LG owners who don't want to be forced into a replacement." } },
    { "@type": "Question", "name": "Can you still get LG phone parts in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we maintain active supplier relationships for LG Velvet, V series, G series, Stylo, and K series parts. Popular models are often in stock for same-day repairs, while rarer models like the LG Wing may require a short sourcing window — contact us to confirm availability for your specific model." } },
    { "@type": "Question", "name": "How long does LG screen repair take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most LG screen replacements are completed same-day in 1–2 hours at our Winnipeg St. Vital location once parts are in stock. If your model requires a special order, we'll give you an estimated wait time when you contact us for a quote." } },
    { "@type": "Question", "name": "Is it worth repairing my LG phone in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the model and the repair needed — a battery or screen replacement on an LG Velvet or V60 often makes excellent financial sense given how well-built these devices are. We always give you an honest assessment before starting any repair so you can decide with full information." } },
    { "@type": "Question", "name": "Can you repair LG Dual Screen accessories and the LG Wing?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair LG Dual Screen cases and the unique LG Wing swivel mechanism. These are specialist repairs that virtually no other Winnipeg shop has experience with — contact us before visiting to discuss your specific issue and confirm we have the required components." } },
    { "@type": "Question", "name": "Do you repair LG V series phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all LG V series models from V20 through V60 ThinQ at our Winnipeg location. Screen and battery replacements are the most common V series repairs, and we maintain parts for all current V series generations." } },
    { "@type": "Question", "name": "Can you fix an LG phone that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive LG is often caused by a depleted battery, a failed display connection, or a software boot issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the problem is before spending anything." } },
    { "@type": "Question", "name": "Do you repair LG Stylo phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all LG Stylo models from Stylo 4 through Stylo 6 at our Winnipeg shop. Charging port and screen replacements are the most common Stylo repairs, and parts are readily available for all current Stylo generations." } },
    { "@type": "Question", "name": "Do you offer a warranty on LG repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — screen repairs carry a 30-day to lifetime warranty depending on part tier. Battery replacements include a 90-day warranty, and most other repairs carry a lifetime warranty on parts and labour — even on legacy LG models." } },
    { "@type": "Question", "name": "Do you repair LG phones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts LG repairs Monday through Saturday 10AM–6PM. For less common LG models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="lg-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="lg-container">
      <ol class="lg-breadcrumb-list">
        <li><a href="/" class="lg-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="lg-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="lg-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="lg-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="lg-breadcrumb-current" aria-current="page">LG Phone Repair</li>
      </ol>
    </div>
  </nav>

  <section class="lg-hero-section" id="hero">
    <div class="lg-hero-inner">
      <div class="lg-hero-content">
        <div class="lg-hero-badge-row">
          <span class="lg-service-badge">LG Legacy Repair Specialists</span>
          <span class="lg-location-badge">
            <span class="lg-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="lg-location-badge">
            <span class="lg-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="lg-hero-headline">
          LG Phone Repair <span class="lg-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="lg-hero-subheadline">LG Velvet, Wing, V Series, G Series & Stylo Repair Specialists</p>

        <div class="lg-hero-body">
          <p>LG exited the smartphone market in 2021 — but your phone didn't stop working, and neither did we. We repair all LG models at our Winnipeg shop including the LG Velvet, Wing, V60, V50, G8, G7, Stylo series, and all K series devices. Common repairs include screen replacements, battery swaps, USB-C and Micro-USB charging port fixes, camera repairs, speaker issues, and power button repairs.</p>
          <p>Parts availability is the biggest challenge with LG repairs in Canada — most shops stopped stocking LG components when the brand exited the market. We've maintained supplier relationships specifically for LG parts so we can keep servicing devices that other Winnipeg shops turn away. We'll always confirm parts availability and give you an honest quote before starting any repair.</p>
        </div>

        <div class="lg-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="lg-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="lg-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="lg-hero-image-wrapper">
        <img
          src="/assets/hero-lg-C59VkA4q.png"
          alt="LG phone repair in Winnipeg — Velvet, Wing, V series and G series specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="lg-annotations-list" aria-label="Common LG issues we fix">
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Charging port issues
          </li>
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Camera not working
          </li>
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
          <li class="lg-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
            Speaker not working
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="lg-services-section" id="services">
    <div class="lg-container">
      <div class="lg-section-header">
        <h2 class="lg-section-title">LG Phone Repair Services in Winnipeg</h2>
        <p class="lg-section-subtitle">Specialist repairs for all LG models. Legacy parts sourced, honest advice, warranty included.</p>
      </div>
      <div class="lg-services-grid">
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="lg-service-title">Screen Replacement</h3>
          <p class="lg-service-body">Cracked or unresponsive LG display? We replace OLED and LCD screens on all LG Velvet, Wing, V series, G series, Stylo, and K series devices. LG flagship screens use P-OLED and OLED panels that require model-specific parts — we source them through specialist suppliers for models that standard channels no longer carry.</p>
        </div>
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="lg-service-title">Battery Replacement</h3>
          <p class="lg-service-body">LG phone not lasting the day? We replace degraded batteries with quality cells on all LG models. Older LG phones with removable batteries are some of the easiest replacements in the industry — newer sealed models like the Velvet require careful disassembly. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="lg-service-title">Charging Port Repair</h3>
          <p class="lg-service-body">LG not charging or connecting intermittently? We repair USB-C ports on newer LG models and Micro-USB on older devices. We clean the port before recommending replacement since debris is a common cause of charging failures — particularly on the LG Stylo and K series which are heavy daily-use devices.</p>
        </div>
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="lg-service-title">Camera Repair</h3>
          <p class="lg-service-body">Blurry photos, black camera screen, or cracked lens on your LG? We repair front, rear, and wide-angle cameras on all LG models. The LG V60 and G8 feature wide-angle and depth cameras that require precise module replacement to maintain the full camera system functionality.</p>
        </div>
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
          <h3 class="lg-service-title">Speaker & Boombox Repair</h3>
          <p class="lg-service-body">Muffled audio, crackling speakers, or a dead earpiece on your LG? We repair speaker assemblies across all LG models including the Boombox speaker system on select V and G series devices. Most speaker repairs are completed same-day.</p>
        </div>
        <div class="lg-service-card">
          <div class="lg-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="lg-service-title">Power & Button Repair</h3>
          <p class="lg-service-body">Stuck, unresponsive, or broken power button or volume rocker on your LG? We repair and replace buttons across all LG models. The LG Wing's unique swivel mechanism and Dual Screen case connectors are also serviced — contact us for these specialist repairs.</p>
        </div>
      </div>
      <div class="lg-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="lg-models-section" id="models">
    <div class="lg-container">
      <div class="lg-section-header">
        <h2 class="lg-section-title">All LG Phone Models We Repair in Winnipeg</h2>
        <p class="lg-section-subtitle">Velvet, Wing, V series, G series, Stylo, K series and all legacy LG devices</p>
      </div>
      <div class="lg-models-grid">
        <div class="lg-model-card">
          <div class="lg-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="lg-model-title">LG Velvet & Wing</h3>
          <p class="lg-model-description">LG's innovative final flagship devices. The Wing's unique swivel mechanism is a specialist repair — contact us to confirm parts availability before visiting.</p>
          <div class="lg-model-pills">
            <span class="lg-pill">LG Velvet 5G</span>
            <span class="lg-pill">LG Wing 5G</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="lg-model-card">
          <div class="lg-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="lg-model-title">LG V Series</h3>
          <p class="lg-model-description">Premium V series phones with Quad DAC audio and wide-angle cameras. Screen and battery repairs are the most common V series fixes — parts available for V30 through V60.</p>
          <div class="lg-model-pills">
            <span class="lg-pill">V60 ThinQ</span>
            <span class="lg-pill">V50 ThinQ</span>
            <span class="lg-pill">V40 ThinQ</span>
            <span class="lg-pill">V35 ThinQ</span>
            <span class="lg-pill">V30</span>
            <span class="lg-pill">V20</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="lg-model-card">
          <div class="lg-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="lg-model-title">LG G Series</h3>
          <p class="lg-model-description">Classic G series flagship lineup from G3 through G8X ThinQ. Battery and screen replacements are the most common repairs across all G series generations.</p>
          <div class="lg-model-pills">
            <span class="lg-pill">G8X ThinQ</span>
            <span class="lg-pill">G8 ThinQ</span>
            <span class="lg-pill">G7 ThinQ</span>
            <span class="lg-pill">G6</span>
            <span class="lg-pill">G5</span>
            <span class="lg-pill">G4</span>
            <span class="lg-pill">G3</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="lg-model-card">
          <div class="lg-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="lg-model-title">LG Stylo & K Series</h3>
          <p class="lg-model-description">Budget-friendly LG devices with large screens and stylus support. Charging port and screen repairs are the most common issues — parts available for most Stylo and K series models.</p>
          <div class="lg-model-pills">
            <span class="lg-pill">Stylo 6</span>
            <span class="lg-pill">Stylo 5</span>
            <span class="lg-pill">Stylo 4</span>
            <span class="lg-pill">K92</span>
            <span class="lg-pill">K71</span>
            <span class="lg-pill">K62</span>
            <span class="lg-pill">K51</span>
            <span class="lg-pill">K42</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lg-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="lg-why-section" id="why-choose-us">
    <div class="lg-container">
      <div class="lg-section-header">
        <h2 class="lg-section-title">The Mobile Tech Lab Advantage: Winnipeg's LG Repair Experts</h2>
        <p class="lg-section-subtitle">Why Winnipeg LG owners come to us when every other shop says no</p>
      </div>
      <div class="lg-pillars-grid">
        <div class="lg-pillar-card">
          <div class="lg-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="lg-pillar-title">LG Legacy Specialists</h3>
          <p class="lg-pillar-body">Most Winnipeg repair shops stopped stocking LG parts when the brand exited the smartphone market in 2021. We kept our supplier relationships specifically so we could keep servicing LG owners who love their devices and don't want to be forced into a replacement.</p>
        </div>
        <div class="lg-pillar-card">
          <div class="lg-pillar-icon-wrapper">
