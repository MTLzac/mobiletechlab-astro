---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "ZTE Repair Winnipeg | nubia & Blade Screen Fix | Mobile Tech Lab";
const description = "ZTE phone repair in Winnipeg. Screen, battery, charging repair for ZTE nubia, Red Magic, Blade & Axon series. Rare device specialists.";
const canonical = "https://mobiletechlab.ca/repair/zte";

const services = [
  {
    name: "Screen Replacement",
    description: "Replace cracked ZTE and nubia screens—including Red Magic gaming displays.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-3"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="m22 3-5 5"/><path d="m17 3 5 5"/></svg>`
  },
  {
    name: "Battery Replacement",
    description: "Restore battery life to your ZTE or nubia device.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect width="16" height="10" x="2" y="7" rx="2" ry="2"/><line x1="22" x2="22" y1="11" y2="13"/></svg>`
  },
  {
    name: "Charging Port Repair",
    description: "Fix USB-C charging port issues.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22V11"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M5 5v3"/><path d="M19 5v3"/><path d="M5 8h14"/></svg>`
  },
  {
    name: "Camera Repair",
    description: "Repair under-display and traditional cameras on ZTE devices.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`
  },
  {
    name: "Speaker Repair",
    description: "Fix dual stereo speakers and audio issues.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>`
  },
  {
    name: "Power Issues",
    description: "Diagnose and fix power, boot, and cooling system problems.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" x2="12" y1="2" y2="12"/></svg>`
  }
];

const modelCategories = [
  {
    title: "nubia Gaming Series",
    description: "Red Magic gaming phones with cooling system expertise.",
    models: ["Red Magic 9 Pro", "Red Magic 8 Pro", "Red Magic 7", "Red Magic 6"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15" y1="12" y2="12"/><line x1="17" x2="17" y1="12" y2="12"/><rect width="20" height="12" x="2" y="6" rx="2"/></svg>`
  },
  {
    title: "nubia Flagships",
    description: "Premium nubia flagships and foldables.",
    models: ["nubia Z60 Ultra", "nubia Z50 Ultra", "nubia Z50", "nubia Flip", "nubia Fold"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>`
  },
  {
    title: "Blade Series",
    description: "Budget-friendly Blade series.",
    models: ["Blade V50", "Blade V40", "Blade V30", "Blade A73", "Blade A53 Pro", "Blade A33"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>`
  },
  {
    title: "Axon Flagships",
    description: "Premium Axon series with under-display camera.",
    models: ["Axon 40 Ultra", "Axon 40 Pro", "Axon 30 Ultra"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>`
  }
];

const pillars = [
  {
    title: "ZTE & nubia Specialists",
    description: "Winnipeg's experts in ZTE and nubia gaming devices.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>`
  },
  {
    title: "Gaming Phone Experts",
    description: "Specialized in Red Magic cooling systems and gaming features.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15" y1="12" y2="12"/><line x1="17" x2="17" y1="12" y2="12"/><rect width="20" height="12" x="2" y="6" rx="2"/></svg>`
  },
  {
    title: "Rare Device Parts",
    description: "Sourcing network for hard-to-find ZTE and nubia components.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/></svg>`
  },
  {
    title: "Warranty on Every Repair",
    description: "Screen repair warranties vary by part tier (30 days to lifetime). 90-day battery warranty. Lifetime warranty on most other repairs.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  }
];

const faqs = [
  {
    question: "Do you repair ZTE phones in Winnipeg?",
    answer: "Yes! We're one of the few shops in Winnipeg that services ZTE devices."
  },
  {
    question: "Can you repair ZTE nubia Red Magic gaming phones?",
    answer: "Absolutely! We service all Red Magic models."
  },
  {
    question: "Are ZTE and nubia parts available in Winnipeg?",
    answer: "We can source parts for most ZTE models."
  },
  {
    question: "Do you repair ZTE foldable phones?",
    answer: "Yes! We service the nubia Fold and nubia Flip."
  },
  {
    question: "How long does ZTE repair take?",
    answer: "Most repairs are completed same-day if parts are in stock."
  }
];

const locations = [
  {
    name: "St. Vital Centre",
    address: "1225 St Mary's Rd, Winnipeg, MB R2M 5E5",
    phone: "(204) 500-9757",
    phoneHref: "tel:2045009757",
    hours: "Mon–Sat 10am–7pm, Sun 12pm–5pm",
    mapUrl: "https://maps.google.com/?q=Mobile+Tech+Lab+St+Vital",
    badge: "Walk-ins Welcome"
  },
  {
    name: "Garden City Shopping Centre",
    address: "2305 McPhillips St, Winnipeg, MB R2V 3E1",
    phone: "(204) 515-7736",
    phoneHref: "tel:2045157736",
    hours: "Mon–Sat 10am–7pm, Sun 12pm–5pm",
    mapUrl: "https://maps.google.com/?q=Mobile+Tech+Lab+Garden+City",
    badge: "Walk-ins Welcome"
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repair" },
    { "@type": "ListItem", "position": 3, "name": "ZTE" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "ZTE Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repair/zte",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "ZTE Repair Services",
    "itemListElement": services.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.name }
    }))
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumbs -->
  <nav class="border-b border-border bg-background" aria-label="Breadcrumb">
    <div class="container mx-auto px-4 py-3">
      <ol class="zte-breadcrumb-list">
        <li><a href="/" class="zte-breadcrumb-link">Home</a></li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" class="zte-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li><a href="/repair" class="zte-breadcrumb-link">Repairs</a></li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" class="zte-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="zte-breadcrumb-current" aria-current="page">ZTE</li>
      </ol>
    </div>
  </nav>

  <!-- Section 1: Hero -->
  <section class="zte-hero-section" id="hero">
    <div class="zte-hero-inner">
      <div class="zte-hero-content">
        <div class="zte-hero-badge-row">
          <span class="zte-hero-service-badge">Professional ZTE Repair</span>
          <span class="zte-hero-location-badge">
            <span class="zte-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="zte-hero-location-badge">
            <span class="zte-badge-dot"></span>
            Garden City — Open
          </span>
        </div>

        <h1 class="zte-hero-headline">
          ZTE &amp; nubia Repair Specialists in <span class="zte-highlight">Winnipeg</span>
        </h1>
        <p class="zte-hero-subheadline">ZTE nubia, Red Magic, Blade &amp; Axon Repair</p>
        <div class="zte-hero-body">
          <p>
            From nubia Red Magic gaming phones to budget Blade devices, we repair all <a href="https://www.ztedevices.com/en-gl/support/" target="_blank" rel="noopener noreferrer">ZTE phones</a> in Winnipeg. Hard to find parts? We've got the sourcing connections.
          </p>
          <p>
            Cracked AMOLED screen, dead battery, broken charging port, malfunctioning under-display camera — our technicians handle every ZTE and nubia model. We're one of the few shops in Winnipeg that stocks and sources rare ZTE components.
          </p>
        </div>

        <div class="zte-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="zte-cta-primary">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="tel:2045009757" class="zte-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (204) 500-9757
          </a>
        </div>
        <p class="zte-hero-pricing-note">
          Not sure what affects the cost? <a href="/repair-pricing">How repair pricing works</a>
        </p>
      </div>

      <div class="zte-hero-image-wrapper">
        <img
          src="/assets/hero-zte-C3Rbhohj.png"
          alt="ZTE repair services in Winnipeg"
          width="600"
          height="400"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <style>
    .zte-breadcrumb-list {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      color: #6b7280;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .zte-breadcrumb-link {
      color: #6b7280;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .zte-breadcrumb-link:hover {
      color: #111827;
    }

    .zte-breadcrumb-chevron {
      width: 12px;
      height: 12px;
      flex-shrink: 0;
    }

    .zte-breadcrumb-current {
      color: #111827;
      font-weight: 500;
    }

    .zte-hero-section {
      background: linear-gradient(135deg, #fafafa 0%, #ffffff 50%, #fafafa 100%);
      width: 100%;
      padding: 60px 24px 80px;
    }

    .zte-hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }

    .zte-hero-content {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .zte-hero-image-wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .zte-hero-image-wrapper img {
      width: 100%;
      max-width: 580px;
      height: auto;
      display: block;
      object-fit: contain;
    }

    .zte-hero-badge-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .zte-hero-service-badge {
      display: inline-flex;
      align-items: center;
      padding: 5px 14px;
      background: #f1f5f9;
      border: 1px solid #cbd5e1;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      color: #475569;
    }

    .zte-hero-location-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #16a34a;
    }

    .zte-badge-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      flex-shrink: 0;
      background: #16a34a;
    }

    .zte-hero-headline {
      font-size: clamp(2.2rem, 4.5vw, 3.5rem);
      font-weight: 900;
      line-height: 1.1;
      color: #111827;
      margin: 0;
    }

    .zte-highlight {
      color: #0f172a;
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-color: #e11d48;
    }

    .zte-hero-subheadline {
      font-size: 17px;
      font-weight: 600;
      color: #374151;
      margin: 0;
    }

    .zte-hero-body {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .zte-hero-body p {
      font-size: 15px;
      color: #4b5563;
      line-height: 1.7;
      margin: 0;
    }

    .zte-hero-body a {
      color: #e11d48;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .zte-hero-cta-group {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .zte-cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      background: #e11d48;
      color: #ffffff;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      cursor: pointer;
    }

    .zte-cta-primary:hover {
      background-color: #be123c;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(225, 29, 72, 0.35);
    }

    .zte-cta-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      background: #ffffff;
      color: #374151;
      border: 1.5px solid #e5e7eb;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      transition: border-color 0.2s ease, color 0.2s ease;
      cursor: pointer;
    }

    .zte-cta-secondary:hover {
      border-color: #e11d48;
      color: #e11d48;
    }

    .zte-hero-pricing-note {
      font-size: 13px;
      color: #9ca3af;
      margin: 0;
    }

    .zte-hero-pricing-note a {
      color: #e11d48;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    @media (max-width: 900px) {
      .zte-hero-inner {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }
  </style>

  <!-- Section 2: Services -->
  <section class="py-16 md:py-20" id="services">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-2xl font-bold md:text-3xl">ZTE Repair Services in Winnipeg</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Every repair backed by our warranty. Free diagnostics on all ZTE issues.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <div class="rounded-lg border border-border bg-card p-6">
            <div class="zte-service-icon mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-primary/10 text-primary" set:html={service.icon} />
            <h3 class="mb-2 font-semibold text-foreground">{service.name}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Request Repair
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <style>
    .zte-service-icon svg {
      width: 24px;
      height: 24px;
    }
  </style>

  <!-- Section 3: Models -->
  <section class="bg-secondary/40 py-16 md:py-20" id="models">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-2xl font-bold md:text-3xl">All ZTE Models We Repair in Winnipeg</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">We repair all ZTE devices including nubia gaming phones, Blade series, Axon flagships, and foldables.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {modelCategories.map(cat => (
          <div class="rounded-lg border border-border bg-background p-6">
            <div class="zte-model-icon mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-primary/10 text-primary" set:html={cat.icon} />
            <h3 class="mb-2 font-semibold text-foreground">{cat.title}</h3>
            <p class="mb-4 text-sm text-muted-foreground leading-relaxed">{cat.description}</p>
