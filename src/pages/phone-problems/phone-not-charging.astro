---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Why Is My Phone Not Charging? 9 Common Causes and Fixes | Mobile Tech Lab";
const description = "Phone not charging? Discover the 9 most common causes — from dirty ports to bad batteries — and learn what you can fix yourself vs. when to bring it in for repair.";
const canonical = "https://mobiletechlab.ca/phone-problems/phone-not-charging";

const causes = [
  {
    title: "Dirty or Blocked Charging Port",
    description: "Lint, dust, and debris accumulate inside the charging port over time. This is the most common cause of charging problems and is often a quick fix.",
    fix: "Try carefully cleaning the port with a toothpick, compressed air, or a soft brush. Avoid metal objects that could damage the pins.",
    canDIY: true,
  },
  {
    title: "Damaged or Faulty Cable",
    description: "Cables fray at stress points near the connector or end. A damaged cable may charge intermittently or not at all.",
    fix: "Test with a different MFi-certified cable (iPhone) or USB-C cable (Android). If charging resumes with a new cable, replace your old one.",
    canDIY: true,
  },
  {
    title: "Faulty Charger or Adapter",
    description: "Power bricks can fail over time, especially cheaper third-party adapters. The adapter may not deliver enough wattage to charge your device.",
    fix: "Test with a different charger from a trusted brand. Always use a charger rated for your device.",
    canDIY: true,
  },
  {
    title: "Worn-Out Battery",
    description: "Lithium-ion batteries degrade over time. A battery at low capacity may appear to charge but drains extremely quickly or refuses to charge past a certain percentage.",
    fix: "Check battery health in settings (iPhone: Settings > Battery > Battery Health). If below 80%, a battery replacement is recommended.",
    canDIY: false,
  },
  {
    title: "Damaged Charging Port",
    description: "Physical damage, bent pins, or corrosion inside the charging port can prevent a proper electrical connection, making charging impossible.",
    fix: "If cleaning didn't resolve it, the port likely needs professional replacement. Attempting DIY port replacement risks further damage.",
    canDIY: false,
  },
  {
    title: "Software or Firmware Bug",
    description: "A software glitch can cause your phone to fail to recognise that it's plugged in, or to incorrectly report battery status.",
    fix: "Try a force restart. For iPhone: press Volume Up, Volume Down, then hold Side Button until Apple logo appears. For Android: hold Power + Volume Down.",
    canDIY: true,
  },
  {
    title: "Water Damage",
    description: "Moisture inside the charging port triggers safety mechanisms that prevent charging. Even splash resistance doesn't mean full waterproofing.",
    fix: "Do NOT charge a wet phone. Let it dry completely, or bring it in for a professional water damage inspection.",
    canDIY: false,
  },
  {
    title: "Third-Party Accessories Incompatibility",
    description: "Cheap, uncertified cables and adapters may not be recognised by your phone's charging system, particularly iPhones with MFi enforcement.",
    fix: "Switch to Apple MFi-certified or manufacturer-approved accessories only.",
    canDIY: true,
  },
  {
    title: "Logic Board or Charging IC Failure",
    description: "The charging integrated circuit (IC) on the logic board can fail due to power surges, water damage, or component wear, preventing charging entirely.",
    fix: "This requires component-level board repair by a professional technician. Not a DIY repair.",
    canDIY: false,
  },
];

const subPages = [
  { title: "iPhone Not Charging", href: "/phone-problems/phone-not-charging/iphone", desc: "iPhone-specific causes including Lightning port issues, iOS bugs, and battery health problems." },
  { title: "Samsung Not Charging", href: "/phone-problems/phone-not-charging/samsung", desc: "Galaxy-specific causes including USB-C port wear, Adaptive Charging issues, and moisture detection." },
  { title: "Charging Port Issues", href: "/phone-problems/phone-not-charging/charging-port", desc: "Deep dive into charging port problems, damage types, cleaning tips, and when to replace." },
  { title: "Phone Charging Slowly", href: "/phone-problems/phone-not-charging/slow-charging", desc: "Why your phone charges slowly and how to fix it — cables, adapters, settings, and more." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Phone Problems</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Why Is My Phone Not Charging?</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        9 common causes of phone charging problems, what you can try yourself, and when it's time to bring it in for professional repair.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Causes and Fixes -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">9 Common Causes & Fixes</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Work through these causes from most to least common. Many can be resolved at home — but some require a professional repair.</p>
      </div>
      <div class="space-y-4">
        {causes.map((cause, i) => (
          <div class="rounded-lg border border-border bg-card p-6">
            <div class="flex items-start gap-4">
              <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</div>
              <div class="flex-1">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  <h3 class="font-semibold text-foreground">{cause.title}</h3>
                  <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${cause.canDIY ? 'bg-green-500/10 text-green-600' : 'bg-orange-500/10 text-orange-600'}`}>
                    {cause.canDIY ? 'Can try at home' : 'Professional repair recommended'}
                  </span>
                </div>
                <p class="mb-2 text-sm text-muted-foreground">{cause.description}</p>
                <p class="text-sm text-foreground"><span class="font-medium">Fix:</span> {cause.fix}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Guides -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Device-Specific Charging Guides</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Get more detailed help for your specific device or charging problem.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {subPages.map(page => (
          <a href={page.href} class="group rounded-lg border border-border bg-card p-6 hover:border-primary/50 hover:bg-accent transition-colors">
            <h3 class="mb-2 font-semibold text-foreground group-hover:text-primary transition-colors">{page.title}</h3>
            <p class="text-sm text-muted-foreground">{page.desc}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary">
              Read guide
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Still Not Charging? We Can Help.</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        If none of the above fixes worked, bring your phone in for a free diagnostic. We'll identify the problem and give you a transparent repair quote.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
