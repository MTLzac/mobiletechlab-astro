---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Phone Charging Port Not Working? Causes & Fixes | Mobile Tech Lab";
const description = "Charging port problems? Learn how to identify port damage, clean it safely, and when professional charging port replacement is the right call. iPhone and Android covered.";
const canonical = "https://mobiletechlab.ca/phone-problems/phone-not-charging/charging-port";

const symptoms = [
  { symptom: "Cable feels loose or wobbly when plugged in", likely: "Worn port — the internal contacts are bent or worn down from frequent insertion." },
  { symptom: "Phone only charges at a certain angle", likely: "Debris or bent pins inside the port are creating a partial connection." },
  { symptom: "Charging works intermittently", likely: "Damaged pins, corrosion, or debris creating an unreliable connection." },
  { symptom: "Port completely won't accept cable", likely: "Physical damage, bent housing, or blockage inside the port." },
  { symptom: "Phone charges when plugged in but shows 'not charging'", likely: "Software issue or a partially functioning port — run a force restart first." },
  { symptom: "Sparking or burning smell from port", likely: "Electrical damage — stop using immediately and bring it in for inspection." },
];

const cleaningSteps = [
  { step: "1", title: "Power Off First", desc: "Always turn off your phone before attempting to clean the charging port." },
  { step: "2", title: "Use a Wooden Toothpick", desc: "Gently insert a toothpick and carefully scrape debris from the sides and bottom of the port. Move slowly — do not force it." },
  { step: "3", title: "Use a Soft Brush", desc: "A clean, dry toothbrush or anti-static brush can help dislodge finer debris. Brush gently in multiple directions." },
  { step: "4", title: "Compressed Air", desc: "A short blast of compressed air (not canned air held upside down) can remove loose debris. Keep the can upright." },
  { step: "5", title: "Inspect With a Flashlight", desc: "Use a bright flashlight to check if the port looks clear and if pins appear straight. If pins are bent, stop — professional repair is needed." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Breadcrumb -->
  <nav class="border-b border-border bg-secondary/20 py-3">
    <div class="container mx-auto px-4">
      <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li><a href="/phone-problems/phone-not-charging" class="hover:text-foreground transition-colors">Phone Not Charging</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li class="text-foreground">Charging Port</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Charging Port Guide</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Phone Charging Port Not Working?</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        How to diagnose charging port problems, safely clean your port at home, and know when professional replacement is needed.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Book a Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Symptoms Diagnosis -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Identify Your Symptoms</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Match your symptom to the likely cause to narrow down the problem.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-border bg-secondary/40">
              <th class="px-4 py-3 text-left font-semibold text-foreground">Symptom</th>
              <th class="px-4 py-3 text-left font-semibold text-foreground">Likely Cause</th>
            </tr>
          </thead>
          <tbody>
            {symptoms.map((row, i) => (
              <tr class={`border-b border-border ${i % 2 === 0 ? 'bg-card' : 'bg-background'}`}>
                <td class="px-4 py-3 text-foreground">{row.symptom}</td>
                <td class="px-4 py-3 text-muted-foreground">{row.likely}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- How to Clean Your Port -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">How to Safely Clean Your Charging Port</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Before paying for a repair, try these steps. A dirty port is the most common and easiest fix.</p>
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {cleaningSteps.map(item => (
          <div class="flex gap-4 rounded-lg border border-border bg-card p-5">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">{item.step}</div>
            <div>
              <h3 class="mb-1 font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mx-auto mt-6 max-w-3xl rounded-lg border border-destructive/30 bg-destructive/5 p-5">
        <p class="font-semibold text-foreground">What NOT to do:</p>
        <ul class="mt-2 space-y-1 text-sm text-muted-foreground">
          <li class="flex items-start gap-2"><span class="text-destructive font-bold">X</span> Do not use metal tools like pins or staples — they can short-circuit or bend pins</li>
          <li class="flex items-start gap-2"><span class="text-destructive font-bold">X</span> Do not use water or cleaning fluid — moisture causes corrosion</li>
          <li class="flex items-start gap-2"><span class="text-destructive font-bold">X</span> Do not blow into the port — moisture from breath causes corrosion over time</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- When to Replace -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-4 text-3xl font-bold tracking-tight">When to Get the Port Replaced</h2>
        <p class="mb-8 text-muted-foreground">Cleaning didn't fix it? If the port has physical damage, bent pins, corrosion, or the cable still feels loose after cleaning, the port needs professional replacement. This is a common, affordable repair at Mobile Tech Lab.</p>
        <div class="grid gap-4 sm:grid-cols-3 text-left">
          {[
            { title: "iPhone Lightning Port", desc: "We replace worn or damaged Lightning ports on all iPhone models." },
            { title: "Android USB-C Port", desc: "USB-C port replacement for Samsung, Google Pixel, Motorola, and more." },
            { title: "Same-Day Service", desc: "Most charging port repairs are completed the same day — often within the hour." },
          ].map(item => (
            <div class="rounded-lg border border-border bg-card p-5">
              <h3 class="mb-2 font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Need a Charging Port Repaired?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Walk in or get a free quote online. Charging port repairs are fast, affordable, and backed by our 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
