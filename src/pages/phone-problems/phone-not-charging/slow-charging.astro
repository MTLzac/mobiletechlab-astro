---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Phone Charging Slowly? Causes and Fixes | Mobile Tech Lab";
const description = "Phone charging slowly? Discover the most common reasons — from underpowered adapters to battery wear — and practical fixes to get fast charging working again.";
const canonical = "https://mobiletechlab.ca/phone-problems/phone-not-charging/slow-charging";

const causes = [
  {
    title: "Using a Low-Wattage Charger",
    desc: "Many phone chargers ship with 5W or 10W adapters, while your device may support 25W, 45W, or faster charging. Charging speed is only as fast as the weakest link in the chain.",
    fix: "Check your phone's fast charging specification and use a compatible high-wattage adapter. Look for Samsung Adaptive Fast Charging, Apple 20W, or USB Power Delivery (PD) adapters.",
  },
  {
    title: "Using a Cheap or Uncertified Cable",
    desc: "Inexpensive cables often use thinner wire gauges that restrict current flow, significantly reducing charging speed even with a fast charger.",
    fix: "Use a USB-C or Lightning cable rated for fast charging. Look for cables rated at 3A or higher for USB-C, and Apple MFi-certified for Lightning.",
  },
  {
    title: "Charging Through a USB Hub or PC Port",
    desc: "USB ports on computers and hubs typically output only 0.5A to 0.9A — far less than a wall charger. This results in very slow charging.",
    fix: "Always charge from a wall outlet with a quality adapter for the fastest charge speeds.",
  },
  {
    title: "Dirty or Damaged Charging Port",
    desc: "Debris inside the charging port creates resistance in the electrical connection, reducing the amount of power that can flow to your battery.",
    fix: "Clean the charging port with a toothpick and soft brush. If charging speed doesn't improve after cleaning, the port may need professional inspection.",
  },
  {
    title: "Degraded Battery",
    desc: "As lithium-ion batteries age, they charge more slowly and hold less capacity. A battery at 70% health may take significantly longer to charge than a new one.",
    fix: "Check your battery health. iPhone: Settings > Battery > Battery Health. Android: check in Device Care or use a third-party diagnostic app. If below 80%, consider a replacement.",
  },
  {
    title: "Charging While Using the Phone",
    desc: "Running apps, streaming video, or gaming while charging draws power from the battery simultaneously, dramatically slowing net charging speed.",
    fix: "Put your phone in airplane mode or leave it idle while charging to significantly increase charging speed.",
  },
  {
    title: "Overheating",
    desc: "Phones reduce charging speed automatically when the battery gets too hot. This is a built-in protection to extend battery lifespan.",
    fix: "Remove your phone case while charging, avoid leaving it in direct sunlight or on warm surfaces, and don't use it heavily while charging.",
  },
  {
    title: "Fast Charging is Disabled in Settings",
    desc: "Some Android phones let you toggle fast charging on or off in settings. If it was accidentally disabled, charging will fall back to standard speed.",
    fix: "For Samsung: Settings > Battery and Device Care > Battery > More Battery Settings > Fast Charging. Make sure it's enabled.",
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Breadcrumb -->
  <nav class="border-b border-border bg-secondary/20 py-3">
    <div class="container mx-auto px-4">
      <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li><a href="/phone-problems/phone-not-charging" class="hover:text-foreground transition-colors">Phone Not Charging</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li class="text-foreground">Slow Charging</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Charging Guide</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Why Is My Phone Charging Slowly?</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        8 common reasons your phone charges slowly — and practical fixes to restore fast charging speeds.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Book a Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Causes and Fixes -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">8 Causes of Slow Phone Charging</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Start with the easiest fixes first. Most slow-charging issues can be solved without hardware repairs.</p>
      </div>
      <div class="space-y-4">
        {causes.map((cause, i) => (
          <div class="rounded-lg border border-border bg-card p-6">
            <div class="flex items-start gap-4">
              <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</div>
              <div class="flex-1">
                <h3 class="mb-2 font-semibold text-foreground">{cause.title}</h3>
                <p class="mb-2 text-sm text-muted-foreground">{cause.desc}</p>
                <p class="text-sm text-foreground"><span class="font-medium">Fix:</span> {cause.fix}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Tips -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Quick Tips to Charge Faster Right Now</h2>
      </div>
      <div class="mx-auto max-w-3xl grid gap-4 sm:grid-cols-2">
        {[
          { tip: "Enable Airplane Mode", desc: "Cuts off all radios — the biggest battery drain — while keeping charging on." },
          { tip: "Use a Wall Adapter", desc: "Always faster than a computer, hub, or car charger." },
          { tip: "Use a Fast Charging Cable", desc: "Don't use old or thin cables. Quality matters." },
          { tip: "Remove Your Case", desc: "Heavy cases trap heat and slow charging. Remove while charging if possible." },
          { tip: "Keep Screen Off", desc: "The display is a major power consumer. Let the screen timeout during charging." },
          { tip: "Close Background Apps", desc: "Background processes draw power that competes with charging." },
        ].map(item => (
          <div class="flex gap-3 rounded-lg border border-border bg-card p-4">
            <div class="mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <p class="font-semibold text-foreground">{item.tip}</p>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Still Charging Slowly After Trying Everything?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        If your phone still charges slowly after switching cables and adapters, a degraded battery or damaged charging port is likely the cause. Bring it in for a free diagnostic.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
