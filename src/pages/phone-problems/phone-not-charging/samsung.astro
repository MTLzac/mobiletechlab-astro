---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Samsung Phone Not Charging? Causes and Fixes | Mobile Tech Lab";
const description = "Samsung Galaxy not charging? Diagnose USB-C port problems, Adaptive Charging issues, moisture detection triggers, and battery health. When to get a professional repair.";
const canonical = "https://mobiletechlab.ca/phone-problems/phone-not-charging/samsung";

const steps = [
  {
    step: "1",
    title: "Try a Different USB-C Cable and Charger",
    desc: "USB-C cables degrade at the connector end. Test with a Samsung-certified or high-quality USB-C cable and a compatible charger (preferably the original adapter or a Samsung-branded one).",
  },
  {
    step: "2",
    title: "Clean the USB-C Port",
    desc: "Samsung's USB-C ports accumulate lint and debris. Use a wooden toothpick or soft brush to gently remove debris from the port. Avoid sharp metal objects that could damage the pins.",
  },
  {
    step: "3",
    title: "Check for Moisture Detected Warning",
    desc: "Samsung Galaxy phones detect moisture in the USB-C port and block charging as a safety measure. If you see a moisture warning, leave your phone in a dry, warm place for 30+ minutes before trying again.",
  },
  {
    step: "4",
    title: "Restart or Force Restart",
    desc: "A software bug can prevent charging from initiating. Hold the Power and Volume Down buttons simultaneously for 10-15 seconds to force restart most Galaxy devices.",
  },
  {
    step: "5",
    title: "Disable Adaptive Charging Temporarily",
    desc: "Samsung's Adaptive Charging can slow or pause charging under certain conditions. Go to Settings > Battery and Device Care > Battery > More Battery Settings and toggle Adaptive Charging off temporarily.",
  },
  {
    step: "6",
    title: "Check Battery Percentage and Software",
    desc: "Update your Samsung's software via Settings > Software Update. Also check Device Care > Battery for battery capacity info. If capacity is significantly degraded, a replacement is recommended.",
  },
];

const professionalRepairs = [
  { name: "USB-C Port Replacement", desc: "Worn, bent, or corroded USB-C charging ports replaced by component-level repair." },
  { name: "Battery Replacement", desc: "Samsung Galaxy battery replacement to restore full capacity and fast-charging support." },
  { name: "Charging IC Repair", desc: "Logic board-level repair for Galaxies that fail to charge despite a clean port and new cable." },
  { name: "Water Damage Recovery", desc: "Ultrasonic cleaning and board diagnostics for moisture-damaged Samsung devices." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Breadcrumb -->
  <nav class="border-b border-border bg-secondary/20 py-3">
    <div class="container mx-auto px-4">
      <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li><a href="/phone-problems/phone-not-charging" class="hover:text-foreground transition-colors">Phone Not Charging</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li class="text-foreground">Samsung</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Samsung Troubleshooting</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Samsung Phone Not Charging?</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        A step-by-step guide to diagnosing Samsung Galaxy charging issues — from USB-C port problems to moisture detection and hardware faults.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Book a Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Troubleshooting Steps -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Troubleshooting Steps</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Follow these steps in order. Many Samsung charging problems have simple solutions.</p>
      </div>
      <div class="mx-auto max-w-3xl space-y-6">
        {steps.map(item => (
          <div class="flex gap-4 rounded-lg border border-border bg-card p-6">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">{item.step}</div>
            <div>
              <h3 class="mb-2 font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- When to Get Professional Help -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">When to Get a Professional Repair</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">If none of the above steps resolved the issue, these hardware repairs are likely needed.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {professionalRepairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Samsung Still Not Charging?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Bring your Galaxy in for a free diagnostic. We'll identify the root cause and provide a transparent repair quote before doing any work.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
