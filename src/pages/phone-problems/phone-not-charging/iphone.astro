---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "iPhone Not Charging? Causes and Fixes (Troubleshooting Guide) | Mobile Tech Lab";
const description = "iPhone not charging? Step-by-step guide to diagnosing Lightning port issues, battery problems, iOS bugs, and hardware faults. Know when to repair vs. replace.";
const canonical = "https://mobiletechlab.ca/phone-problems/phone-not-charging/iphone";

const steps = [
  {
    step: "1",
    title: "Try a Different Cable and Adapter",
    desc: "Start with the simplest fix. Swap out your Lightning cable and charger for a different Apple MFi-certified set. Faulty cables are the most common cause of iPhone charging issues.",
  },
  {
    step: "2",
    title: "Clean the Lightning Port",
    desc: "Lint and dust compact inside the Lightning port over time, preventing a solid connection. Use a wooden toothpick or a dry soft brush to gently clear debris. Never use metal tools.",
  },
  {
    step: "3",
    title: "Force Restart Your iPhone",
    desc: "A software glitch can freeze charging detection. For iPhone 8 and later: press Volume Up, then Volume Down, then hold Side Button until the Apple logo appears. For iPhone 7: hold Volume Down + Side Button.",
  },
  {
    step: "4",
    title: "Check Battery Health",
    desc: "Go to Settings > Battery > Battery Health & Charging. If capacity is below 80%, the battery may refuse to charge properly. A replacement is strongly recommended at this point.",
  },
  {
    step: "5",
    title: "Update iOS",
    desc: "Known iOS bugs can sometimes interfere with charging. Go to Settings > General > Software Update and install any pending updates.",
  },
  {
    step: "6",
    title: "Try Wireless Charging (MagSafe or Qi)",
    desc: "If your iPhone supports wireless charging (iPhone 8 and later), try a wireless pad. If it charges wirelessly but not via cable, the Lightning port is likely the issue.",
  },
];

const professionalRepairs = [
  { name: "Lightning Port Replacement", desc: "Worn or damaged Lightning connectors are replaced at the component level." },
  { name: "Battery Replacement", desc: "Genuine-spec batteries restored to full capacity with proper calibration." },
  { name: "Charging IC / Logic Board Repair", desc: "Component-level board repair for devices that won't charge at all." },
  { name: "Water Damage Recovery", desc: "Ultrasonic cleaning and board-level diagnostics for moisture damage." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Breadcrumb -->
  <nav class="border-b border-border bg-secondary/20 py-3">
    <div class="container mx-auto px-4">
      <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li><a href="/phone-problems/phone-not-charging" class="hover:text-foreground transition-colors">Phone Not Charging</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li class="text-foreground">iPhone</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">iPhone Troubleshooting</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">iPhone Not Charging?</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        A step-by-step guide to diagnosing and fixing iPhone charging problems — from simple cable swaps to Lightning port replacement.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Book a Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Troubleshooting Steps -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Troubleshooting Steps</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">Work through these steps in order before deciding on a professional repair.</p>
      </div>
      <div class="mx-auto max-w-3xl space-y-6">
        {steps.map(item => (
          <div class="flex gap-4 rounded-lg border border-border bg-card p-6">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">{item.step}</div>
            <div>
              <h3 class="mb-2 font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- When to Get Professional Help -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">When to Get a Professional Repair</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">If the steps above didn't resolve your iPhone's charging problem, one of these hardware issues is likely to blame.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {professionalRepairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">iPhone Still Not Charging?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Bring it in for a free diagnostic at our Winnipeg location. We'll identify the fault and give you a clear, upfront repair quote — no obligation.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
