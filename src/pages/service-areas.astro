---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Mobile Tech Lab | Manitoba Mail-In Phone Repair Service Areas";
const description = "Mobile Tech Lab serves all of Manitoba with walk-in locations in Winnipeg and Thompson, plus a mail-in repair service for customers across the province.";
const canonical = "https://mobiletechlab.ca/service-areas";

const serviceAreas = [
  { city: "Brandon", href: "/service-area/brandon", description: "Mail-in repair service for Brandon and surrounding area." },
  { city: "Portage la Prairie", href: "/service-area/portage-la-prairie", description: "Mail-in device repair for Portage la Prairie residents." },
  { city: "Selkirk", href: "/service-area/selkirk", description: "Mail-in phone and tablet repair for Selkirk and the Interlake." },
  { city: "Steinbach", href: "/service-area/steinbach", description: "Mail-in repairs for Steinbach and the southeast Manitoba region." },
  { city: "The Pas", href: "/service-area/the-pas", description: "Mail-in and Thompson-location service for The Pas area." },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Service Areas Across Manitoba
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        We have walk-in locations in Winnipeg and Thompson, and offer convenient mail-in repair service for customers anywhere in Manitoba.
      </p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Walk-In Locations</h2>
      <p class="mb-10 text-center text-muted-foreground">Visit us in person at either of our Manitoba stores</p>
      <div class="mx-auto grid max-w-3xl gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-1 flex items-center justify-between">
            <h3 class="font-semibold text-lg">Winnipeg — St. Vital</h3>
            <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">Walk-In</span>
          </div>
          <p class="mb-3 text-sm text-muted-foreground">845 Dakota St #25, Winnipeg, MB R2M 5M3</p>
          <div class="space-y-1 text-sm text-muted-foreground mb-4">
            <p>Mon–Sat: 9AM – 7PM</p>
            <p>Sun: 12PM – 7PM</p>
          </div>
          <div class="flex gap-2">
            <a href="tel:2045009757" class="flex-1 flex items-center justify-center gap-1 rounded-md bg-primary px-3 py-2 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              (204) 500-9757
            </a>
            <a href="/location/winnipeg" class="flex-1 flex items-center justify-center gap-1 rounded-md border border-input px-3 py-2 text-xs font-medium hover:bg-accent transition-colors">
              View Location
            </a>
          </div>
        </div>
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-1 flex items-center justify-between">
            <h3 class="font-semibold text-lg">Thompson</h3>
            <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">Walk-In</span>
          </div>
          <p class="mb-3 text-sm text-muted-foreground">300 Mystery Lake Rd #1530, Thompson, MB R8N 0M2</p>
          <div class="space-y-1 text-sm text-muted-foreground mb-4">
            <p>Mon–Sat: 10AM – 6PM</p>
            <p>Sun: Closed</p>
          </div>
          <div class="flex gap-2">
            <a href="tel:2044100262" class="flex-1 flex items-center justify-center gap-1 rounded-md bg-primary px-3 py-2 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              (204) 410-0262
            </a>
            <a href="/location/thompson" class="flex-1 flex items-center justify-center gap-1 rounded-md border border-input px-3 py-2 text-xs font-medium hover:bg-accent transition-colors">
              View Location
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Mail-In Service Areas</h2>
      <p class="mb-10 text-center text-muted-foreground">Can't make it in? Ship your device to us — fast, reliable mail-in repair for all of Manitoba</p>
      <div class="mx-auto max-w-3xl grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {serviceAreas.map(area => (
          <a
            href={area.href}
            class="group rounded-lg border border-border bg-background p-5 hover:border-primary/50 hover:shadow-sm transition-all duration-200"
          >
            <h3 class="mb-1 font-semibold group-hover:text-primary transition-colors">{area.city}</h3>
            <p class="text-sm text-muted-foreground">{area.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-4 text-2xl font-bold md:text-3xl">How Mail-In Repair Works</h2>
        <p class="mb-8 text-muted-foreground">Our mail-in service makes it easy to get your device repaired from anywhere in Manitoba.</p>
        <div class="grid gap-4 text-left sm:grid-cols-3">
          <div class="rounded-lg border border-border bg-card p-4 text-center">
            <div class="mb-2 text-2xl font-bold text-primary">1</div>
            <h3 class="mb-1 text-sm font-semibold">Get a Quote</h3>
            <p class="text-xs text-muted-foreground">Submit your repair request online and receive pricing.</p>
          </div>
          <div class="rounded-lg border border-border bg-card p-4 text-center">
            <div class="mb-2 text-2xl font-bold text-primary">2</div>
            <h3 class="mb-1 text-sm font-semibold">Ship Your Device</h3>
            <p class="text-xs text-muted-foreground">Pack your device securely and mail it to our Winnipeg location.</p>
          </div>
          <div class="rounded-lg border border-border bg-card p-4 text-center">
            <div class="mb-2 text-2xl font-bold text-primary">3</div>
            <h3 class="mb-1 text-sm font-semibold">Get It Back</h3>
            <p class="text-xs text-muted-foreground">We repair and return your device, usually within 1–3 business days.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Get Your Device Fixed?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or call us to arrange mail-in repair service.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
