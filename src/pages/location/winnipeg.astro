---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Mobile Tech Lab Winnipeg | Phone & Device Repair Shop";
const description = "Visit Mobile Tech Lab in Winnipeg for fast, affordable phone, tablet, laptop, and game console repairs. Walk-ins welcome. Same-day service available.";
const canonical = "https://mobiletechlab.ca/location/winnipeg";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Winnipeg Location</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">Mobile Tech Lab — Winnipeg</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Your local device repair shop in Winnipeg. We fix iPhones, Samsung phones, iPads, MacBooks, laptops, and game consoles — fast turnaround, 90-day warranty on all repairs.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Location Info Cards -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Address -->
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h2 class="mb-2 font-semibold text-foreground">Address</h2>
          <p class="text-sm text-muted-foreground">1450 Portage Ave</p>
          <p class="text-sm text-muted-foreground">Winnipeg, MB R3G 0W4</p>
          <a
            href="https://maps.google.com/?q=1450+Portage+Ave+Winnipeg+MB"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
          >
            Get Directions
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Hours -->
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h2 class="mb-2 font-semibold text-foreground">Store Hours</h2>
          <ul class="space-y-1 text-sm text-muted-foreground">
            <li class="flex justify-between gap-4"><span>Monday – Friday</span><span>10:00 AM – 7:00 PM</span></li>
            <li class="flex justify-between gap-4"><span>Saturday</span><span>11:00 AM – 6:00 PM</span></li>
            <li class="flex justify-between gap-4"><span>Sunday</span><span>12:00 PM – 5:00 PM</span></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          </div>
          <h2 class="mb-2 font-semibold text-foreground">Contact</h2>
          <p class="text-sm text-muted-foreground">Phone:</p>
          <a href="tel:2045009757" class="text-sm font-medium text-primary hover:underline">(204) 500-9757</a>
          <p class="mt-3 text-sm text-muted-foreground">Walk-ins welcome. No appointment needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Embed -->
  <section class="py-4 md:py-8">
    <div class="container mx-auto px-4">
      <div class="overflow-hidden rounded-lg border border-border">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2570.5!2d-97.17!3d49.89!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1450+Portage+Ave%2C+Winnipeg%2C+MB!5e0!3m2!1sen!2sca!4v1"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mobile Tech Lab Winnipeg on Google Maps"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Services at this Location -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Repairs Available in Winnipeg</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">We service all major devices at our Winnipeg location. Same-day repairs available on most common fixes.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { name: "iPhone Repair", href: "/repair/iphone", desc: "Screen, battery, charging port, back glass, and more." },
          { name: "Samsung Repair", href: "/repair/samsung", desc: "Screen replacements, battery, charging port for Galaxy devices." },
          { name: "iPad Repair", href: "/repair/ipad", desc: "Screen, battery, home button, and charging port repairs." },
          { name: "MacBook Repair", href: "/repair/macbook", desc: "Screen, keyboard, battery, logic board, and SSD upgrades." },
          { name: "Laptop Repair", href: "/repair/laptop", desc: "All major Windows laptop brands serviced." },
          { name: "Game Console Repair", href: "/consoles", desc: "PS5, PS4, Xbox, Nintendo Switch, Steam Deck." },
          { name: "Google Pixel Repair", href: "/repair/google-pixel", desc: "Screen, battery, charging port, camera repairs." },
          { name: "Water Damage Recovery", href: "/repair/water-damage", desc: "Ultrasonic cleaning and component-level diagnostics." },
          { name: "Controller Repair", href: "/repair/controller-repair-winnipeg", desc: "Joystick drift, button, trigger, and charging port repairs." },
        ].map(service => (
          <a href={service.href} class="group rounded-lg border border-border bg-card p-5 hover:border-primary/50 hover:bg-accent transition-colors">
            <h3 class="mb-1 font-semibold text-foreground group-hover:text-primary transition-colors">{service.name}</h3>
            <p class="text-sm text-muted-foreground">{service.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Why Winnipeg Chooses Mobile Tech Lab</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Same-Day Repairs", desc: "Most common repairs completed within the hour while you wait." },
          { title: "90-Day Warranty", desc: "Every repair backed by our 90-day parts and labour warranty." },
          { title: "Walk-Ins Welcome", desc: "No appointment necessary. Drop in anytime during business hours." },
          { title: "Genuine Parts", desc: "We use high-quality replacement parts for reliable, lasting repairs." },
          { title: "Free Diagnostics", desc: "Not sure what's wrong? We'll diagnose your device for free." },
          { title: "Transparent Pricing", desc: "Upfront quotes before any work begins — no surprise charges." },
        ].map(item => (
          <div class="flex gap-3">
            <div class="mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Ready to Get Your Device Fixed?</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Stop by our Winnipeg store or get a free quote online. Fast repairs, fair prices, and a 90-day warranty on every job.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
