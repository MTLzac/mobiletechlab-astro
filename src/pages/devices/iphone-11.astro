---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "iPhone 11 Repair Winnipeg | Screen, Battery & More | Mobile Tech Lab";
const description = "Expert iPhone 11 repair in Winnipeg. LCD screen replacement, battery, charging port, back glass, dual camera repairs. 90-day warranty. Walk-ins welcome.";
const canonical = "https://mobiletechlab.ca/devices/iphone-11";

const repairs = [
  {
    name: "Screen Replacement",
    description: "Cracked or unresponsive Liquid Retina LCD? We replace iPhone 11 screens with quality panels that restore full colour accuracy and touch response.",
  },
  {
    name: "Battery Replacement",
    description: "iPhone 11 battery draining too fast? We install a fresh battery to restore all-day battery life and peak performance.",
  },
  {
    name: "Charging Port Repair",
    description: "Charging port loose or not connecting? We clean or replace the Lightning port on your iPhone 11 for reliable, consistent charging.",
  },
  {
    name: "Back Glass Repair",
    description: "Shattered rear glass panel? We replace the back glass on your iPhone 11 to restore its appearance and structural integrity.",
  },
  {
    name: "Camera Repair",
    description: "Wide or ultra-wide camera problems — blurry shots, black camera, or night mode issues? We diagnose and repair all camera issues on the iPhone 11.",
  },
  {
    name: "Water Damage Recovery",
    description: "iPhone 11 got wet despite IP68 rating? We perform ultrasonic cleaning and board-level diagnostics to give your device the best recovery chance.",
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Device Repair</p>
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">iPhone 11 Repair in Winnipeg</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Fast, affordable iPhone 11 repairs by certified technicians. Screen, battery, charging port, and more — most repairs completed same day with a 90-day warranty.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <!-- Repair Services -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">iPhone 11 Repair Services</h2>
        <p class="mx-auto max-w-2xl text-muted-foreground">
          We handle all common iPhone 11 repairs. Bring it in for a free diagnostic and same-day repair quote.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairs.map(repair => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class="mb-2 font-semibold text-foreground">{repair.name}</h3>
            <p class="text-sm text-muted-foreground">{repair.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About the Device -->
  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-3xl font-bold tracking-tight">About the iPhone 11</h2>
        <div class="space-y-4 text-muted-foreground">
          <p>
            The iPhone 11, released in September 2019, brought a major camera upgrade with its dual 12MP wide and ultra-wide rear cameras, along with Night Mode for the first time. It features a 6.1-inch Liquid Retina LCD display and the A13 Bionic chip.
          </p>
          <p>
            The iPhone 11 was Apple's best-selling iPhone of 2019 and 2020, known for its excellent battery life, improved Face ID speed, and the introduction of wide and ultra-wide photography. It uses a Lightning connector and supports IP68 water resistance.
          </p>
          <p>
            The iPhone 11 is still a very capable device and worth repairing. Battery replacements and screen repairs are among the most cost-effective fixes for this model, keeping it running for several more years.
          </p>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {[
            { label: "Released", value: "September 2019" },
            { label: "Display", value: "6.1-inch LCD" },
            { label: "Chip", value: "Apple A13 Bionic" },
          ].map(spec => (
            <div class="rounded-lg border border-border bg-card p-4 text-center">
              <p class="text-xs text-muted-foreground">{spec.label}</p>
              <p class="font-semibold text-foreground">{spec.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight">Why Choose Mobile Tech Lab</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Same-Day Repairs", desc: "Most iPhone 11 repairs completed within the hour while you wait." },
          { title: "90-Day Warranty", desc: "Every repair covered by our 90-day parts and labour warranty." },
          { title: "Free Diagnostics", desc: "We diagnose your iPhone 11 for free before any work begins." },
          { title: "Quality Parts", desc: "High-quality replacement parts for lasting, reliable repairs." },
          { title: "Walk-Ins Welcome", desc: "No appointment needed. Drop in during business hours." },
          { title: "Transparent Pricing", desc: "Upfront quotes — no hidden fees or surprise charges." },
        ].map(item => (
          <div class="flex gap-3">
            <div class="mt-0.5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Get Your iPhone 11 Fixed Today</h2>
      <p class="mx-auto mb-8 max-w-xl text-muted-foreground">
        Walk in or get a free online quote. Same-day iPhone 11 repairs in Winnipeg with a 90-day warranty on every job.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21.52 16.92z"/></svg>
          Call (204) 500-9757
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
