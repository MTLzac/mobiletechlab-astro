---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Device Repair Services in Winnipeg | Mobile Tech Lab";
const description = "Expert phone, tablet, laptop & console repair in Winnipeg. Same-day service, lifetime warranty on screens. iPhone, Samsung, MacBook, Nintendo Switch & more.";
const canonical = "https://mobiletechlab.ca/repairs";

const repairCategories = [
  {
    title: "iPhone Repair",
    href: "/repair/iphone",
    description: "Screen replacements, battery service, charging port repair, and water damage recovery for all iPhone models.",
  },
  {
    title: "Samsung Repair",
    href: "/repair/samsung",
    description: "Galaxy phone screen replacements, battery replacements, and charging port repairs.",
  },
  {
    title: "iPad Repair",
    href: "/repair/ipad",
    description: "Screen replacements, battery service, and charging repairs for all iPad models.",
  },
  {
    title: "MacBook Repair",
    href: "/repair/macbook",
    description: "Keyboard, screen, battery, and logic board repairs for MacBook Air and MacBook Pro.",
  },
  {
    title: "Laptop Repair",
    href: "/repair/laptop",
    description: "Screen replacements, keyboard repairs, battery service, and software troubleshooting for Windows laptops.",
  },
  {
    title: "PS5 Repair",
    href: "/repair/ps5",
    description: "HDMI port repair, overheating fixes, disc drive issues, and general console troubleshooting.",
  },
  {
    title: "PS4 Repair",
    href: "/repair/ps4",
    description: "HDMI port repair, BLOD fixes, overheating issues, and controller repair for PS4 and PS4 Pro.",
  },
  {
    title: "Xbox Repair",
    href: "/repair/xbox",
    description: "HDMI, power supply, disc drive, and overheating repairs for Xbox One, Series S and Series X.",
  },
  {
    title: "Nintendo Switch Repair",
    href: "/repair/nintendo-switch",
    description: "Joy-Con drift fixes, screen replacements, charging port repair, and battery replacement.",
  },
  {
    title: "Steam Deck Repair",
    href: "/repair/steam-deck",
    description: "Screen replacements, joystick drift repairs, battery service, and button replacements.",
  },
  {
    title: "Google Pixel Repair",
    href: "/repair/google-pixel",
    description: "Screen replacements, battery service, and charging port repairs for Google Pixel phones.",
  },
  {
    title: "Motorola Repair",
    href: "/repair/motorola",
    description: "Screen, battery, and charging port repairs for Motorola Moto G and Edge series phones.",
  },
  {
    title: "Apple Watch Repair",
    href: "/repair/apple-watch",
    description: "Screen replacement, battery service, and general Apple Watch repairs for all series.",
  },
  {
    title: "Water Damage Repair",
    href: "/repair/water-damage",
    description: "Professional water damage recovery for phones, tablets, and laptops using ultrasonic cleaning.",
  },
  {
    title: "Samsung Galaxy Tab Repair",
    href: "/repair/samsung-galaxy-tab",
    description: "Screen replacements, battery service, and charging port repairs for Samsung Galaxy tablets.",
  },
  {
    title: "Surface Repair",
    href: "/repair/surface",
    description: "Screen replacements, keyboard/type cover issues, and battery service for Microsoft Surface devices.",
  },
  {
    title: "TCL Phone Repair",
    href: "/repair/tcl",
    description: "Affordable screen, battery, and charging port repairs for TCL smartphones.",
  },
  {
    title: "Controller Repair",
    href: "/repair/controller-repair-winnipeg",
    description: "Joystick drift, button replacements, and trigger repairs for PlayStation, Xbox, and Switch controllers.",
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Device Repair Services in Winnipeg
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Professional repairs for phones, tablets, laptops, and game consoles. Same-day service available, with a 90-day warranty on all repairs.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">All Repair Services</h2>
      <p class="mb-10 text-center text-muted-foreground">Walk-ins welcome — no appointment needed</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {repairCategories.map(category => (
          <a
            href={category.href}
            class="group flex flex-col rounded-lg border border-border bg-card p-6 hover:border-primary/50 hover:shadow-md transition-all duration-200"
          >
            <h3 class="mb-2 font-semibold text-foreground group-hover:text-primary transition-colors">{category.title}</h3>
            <p class="flex-1 text-sm text-muted-foreground">{category.description}</p>
            <div class="mt-4 flex items-center gap-1 text-sm font-medium text-primary">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Mobile Tech Lab?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Same-day repairs on most devices",
            "Certified technicians with years of experience",
            "Quality OEM and aftermarket parts",
            "90-day warranty on all repairs",
            "Walk-ins welcome, no appointment needed",
            "Serving Winnipeg and Thompson, Manitoba",
          ].map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Get Your Device Fixed?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to either of our Manitoba locations.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .group {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .group:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(239, 68, 68, 0.12);
    border-color: #ef4444;
  }

  .group .mt-4 svg {
    transition: transform 0.2s ease;
  }

  .group:hover .mt-4 svg {
    transform: translateX(5px);
  }
</style>
