---
const title = "Professional Phone, Tablet, and Computer Repair | Mobile Tech Lab";
const description = "Expert phone repair, tablet repair, computer repair, and console repair in Winnipeg and Thompson. Fast service, quality parts, and professional technicians.";
---

<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="stylesheet" href="/assets/index-BVp9Zw8H.css" />

<!-- AlpineJS for dropdown / mega menu -->
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

</head>

<body>

<!-- HEADER -->

<header class="sticky top-0 z-50 bg-background/95 backdrop-blur border-b">
<div class="container mx-auto px-4 flex h-16 items-center justify-between">

<a href="/" class="flex items-center space-x-2">
<img src="/assets/logo-CFQZ01r1.png" alt="Mobile Tech Lab" class="h-8">
</a>

<nav class="hidden md:flex items-center space-x-6 text-sm font-medium">

<a href="/repair/iphone" class="hover:text-primary">iPhone Repair</a>

<a href="/repair/samsung" class="hover:text-primary">Samsung Repair</a>

<a href="/repair/ipad" class="hover:text-primary">iPad Repair</a>

<a href="/repair/ps5" class="hover:text-primary">PS5 Repair</a>

<a href="/contact" class="hover:text-primary">Contact</a>

</nav>

</div>
</header>


<!-- MAIN CONTENT -->

<main>

<!-- HERO -->

<section class="container mx-auto px-4 py-16 text-center">

<h1 class="text-4xl font-bold mb-4">
Professional Phone, Tablet, and Computer Repair
</h1>

<p class="text-lg max-w-2xl mx-auto mb-8">
Fast and reliable repair services in Winnipeg and Thompson.
Our technicians fix phones, tablets, computers, and game consoles using quality parts.
</p>

<a
href="/contact"
class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-medium"
>
Get a Repair Quote
</a>

</section>


<!-- SERVICES -->

<section class="container mx-auto px-4 py-16 grid md:grid-cols-3 gap-8">

<a href="/repair/iphone" class="block border rounded-lg p-6 hover:shadow">
<h2 class="text-xl font-semibold mb-2">iPhone Repair</h2>
<p>Screen replacements, battery replacements, and water damage repair.</p>
</a>

<a href="/repair/samsung" class="block border rounded-lg p-6 hover:shadow">
<h2 class="text-xl font-semibold mb-2">Samsung Repair</h2>
<p>Fast repairs for Galaxy phones, screens, batteries, and charging issues.</p>
</a>

<a href="/repair/ps5" class="block border rounded-lg p-6 hover:shadow">
<h2 class="text-xl font-semibold mb-2">PS5 Repair</h2>
<p>HDMI port repair, overheating fixes, and console troubleshooting.</p>
</a>

</section>

</main>


<!-- FOOTER -->

<footer class="border-t py-10 mt-20">
<div class="container mx-auto px-4 text-center text-sm text-muted-foreground">

<p>© {new Date().getFullYear()} Mobile Tech Lab</p>

<p class="mt-2">
Phone repair and tech repair services in Winnipeg and Thompson, Manitoba.
</p>

</div>
</footer>


</body>
</html>