---
import MainLayout from '../layouts/MainLayout.astro';
import RepairOptions from '../components/RepairOptions.astro';
import WhyTrustUs from '../components/WhyTrustUs.astro';

const title = "Professional Phone, Tablet, and Computer Repair | Mobile Tech Lab";
const description = "Expert phone repair, tablet repair, computer repair, and console repair in Winnipeg and Thompson. Fast service, quality parts, and professional technicians.";
const canonical = "https://mobiletechlab.ca";

const services = [
  {
    title: "iPhone Repair",
    href: "/repair/iphone",
    description: "Screen replacements, battery replacements, charging ports, and water damage repair for all iPhone models.",
    icon: `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  },
  {
    title: "Samsung Repair",
    href: "/repair/samsung",
    description: "Fast repairs for Galaxy phones — screens, batteries, and charging issues.",
    icon: `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  },
  {
    title: "iPad Repair",
    href: "/repair/ipad",
    description: "Screen replacements, battery service, and charging repairs for all iPad models.",
    icon: `<rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/>`,
  },
  {
    title: "MacBook Repair",
    href: "/repair/macbook",
    description: "Keyboard, screen, battery, and logic board repairs for MacBook Air and Pro.",
    icon: `<rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/>`,
  },
  {
    title: "PS5 Repair",
    href: "/repair/ps5",
    description: "HDMI port repair, overheating fixes, and console troubleshooting.",
    icon: `<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>`,
  },
  {
    title: "Nintendo Switch",
    href: "/repair/nintendo-switch",
    description: "Joy-Con drift fixes, screen repairs, and charging port replacement.",
    icon: `<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>`,
  },
];

---

<MainLayout title={title} description={description} canonical={canonical}>

  <section style="background: linear-gradient(to bottom, #fff5f5, #ffffff); padding: 4rem 1.5rem 3rem;">
    <div style="max-width: 52rem; margin: 0 auto; text-align: center;">

      <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem;">
        <span style="display: inline-flex; align-items: center; gap: 0.35rem; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 9999px; padding: 0.3rem 0.75rem; font-size: 0.75rem; font-weight: 500; color: #374151;">
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 13px; width: 13px; fill: #e8472a; color: #e8472a;" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          4.8/5 Google Rating
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 10px; width: 10px; color: #9ca3af;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </span>
        <span style="display: inline-flex; align-items: center; gap: 0.35rem; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 9999px; padding: 0.3rem 0.75rem; font-size: 0.75rem; font-weight: 500; color: #374151;">
          500+ Reviews
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 10px; width: 10px; color: #9ca3af;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </span>
        <span style="display: inline-flex; align-items: center; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 9999px; padding: 0.3rem 0.75rem; font-size: 0.75rem; font-weight: 500; color: #374151;">
          Price Match Guarantee
        </span>
      </div>

      <h1 style="font-weight: 800; font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.15; color: #111827; margin: 0 0 1rem 0; letter-spacing: -0.02em;">
        Professional Phone, Tablet,<br>Computer &amp; Console <span style="color: #e8472a;">Repair in<br>Winnipeg</span>
      </h1>

      <p style="font-size: clamp(0.95rem, 2vw, 1.1rem); font-weight: 500; color: #374151; margin: 0 0 0.75rem 0;">
        iPhones, iPads, Samsung, Laptops, Consoles &amp; More &mdash; Fixed Fast, Priced Fair
      </p>

      <p style="font-size: 0.85rem; color: #6b7280; max-width: 36rem; margin: 0 auto 2rem; line-height: 1.6;">
        Mobile Tech Lab is Winnipeg's trusted destination for professional device repair. Our certified technicians serve customers across Manitoba with same-day service, transparent pricing, and a warranty on every repair.
      </p>

      <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.75rem;">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: #e8472a; color: #ffffff; font-size: 0.9rem; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none;">
          Get Repair Quote
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="tel:2045009757" style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: #ffffff; color: #111827; font-size: 0.9rem; font-weight: 500; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; border: 1px solid #d1d5db;">
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call For Quote
        </a>
        <a href="/trade-in" style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: #ffffff; color: #111827; font-size: 0.9rem; font-weight: 500; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; border: 1px solid #d1d5db;">
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
          Shop Devices
        </a>
      </div>

    </div>

    <div style="max-width: 52rem; margin: 2.5rem auto 0; border-top: 1px solid #f3f4f6; padding-top: 1.25rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 1.5rem 2.5rem;">
      <span style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #374151;">
        <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px; color: #e8472a;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        500+ 5-Star Reviews
      </span>
      <span style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #374151;">
        <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px; color: #e8472a;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        4.8&#9733; Google Rating
      </span>
      <span style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #374151;">
        <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px; color: #e8472a;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        2 Manitoba Locations
      </span>
      <span style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #374151;">
        <svg xmlns="http://www.w3.org/2000/svg" style="height: 15px; width: 15px; color: #e8472a;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        Price Match Guarantee
      </span>
    </div>

  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Repair Services We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Expert repairs for all major devices — walk-ins welcome</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a
            href={service.href}
            class="group flex flex-col rounded-lg border border-border bg-card p-6 hover:border-primary/50 hover:shadow-md transition-all duration-200"
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={service.icon} />
            </div>
            <h3 class="mb-2 font-semibold text-foreground group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="flex-1 text-sm text-muted-foreground">{service.description}</p>
            <div class="mt-4 flex items-center gap-1 text-sm font-medium text-primary">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a
          href="/repairs"
          class="inline-flex items-center gap-2 rounded-md border border-input px-6 py-2.5 text-sm font-medium hover:bg-accent transition-colors"
        >
          View all repair services
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-[#f5f5f5] py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <div class="mb-3 flex justify-center gap-1">
          {[1,2,3,4,5].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-[#e8472a] text-[#e8472a]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <h2 class="mb-2 text-3xl font-bold tracking-tight md:text-4xl">Trusted by Hundreds of Winnipeg Repair Customers</h2>
        <p class="text-muted-foreground">500+ 5-star reviews on Google from real Manitoba customers</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            text: "Got recommended to this place by my sister... The service is very quick, I was told it would take 2-3 hours to fix and they had it done in under an hour and a half... Overall, very good experience.",
            name: "J Moneyas",
            initials: "JM",
          },
          {
            text: "Really happy with the service. Tanvin, he is the best guy. Helped me right away. My phone was hanging and stopped work. He fixed it within minutes. Saved me from losing all my data.",
            name: "Sourav Sourav",
            initials: "SS",
          },
          {
            text: "My iPhone XR was completely dead no charging whatsoever or signs of life. I bring it into this shop and a friendly guy fixed it in a matter of seconds and didn't charge a dime. Best repair shop in Winnipeg, thanks again!",
            name: "GuitarCharlie S",
            initials: "GS",
          },
          {
            text: "Super fast and very friendly service... Me and my wife brought in an xbox with an unknown issue and they very quickly got back to us... repaired for us a day before they said it would be done. These guys are good I highly recommend.",
            name: "Kaptain Chronic",
            initials: "KC",
          },
        ].map(review => (
          <div class="flex flex-col rounded-lg border border-border bg-white p-5">
            <div class="mb-4 text-2xl font-serif text-[#e8472a] opacity-60 leading-none">&ldquo;&rdquo;</div>
            <p class="flex-1 text-sm text-muted-foreground leading-relaxed mb-6">&ldquo;{review.text}&rdquo;</p>
            <div class="border-t border-border pt-4 flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#c0392b] text-white text-xs font-bold">
                {review.initials}
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">{review.name}</p>
                <div class="flex gap-0.5 mt-0.5">
                  {[1,2,3,4,5].map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 fill-[#e8472a] text-[#e8472a]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="https://www.google.com/maps/place/Mobile+Tech+Lab"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-6 py-2.5 text-sm font-medium hover:bg-accent transition-colors"
        >
          See All 500+ Reviews on Google
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <RepairOptions />

  <WhyTrustUs />

  <section style="padding: 4rem 1.5rem;">
    <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
      <h2 style="font-weight: 700; font-size: clamp(1.5rem, 3vw, 2rem); color: #111827; margin: 0;">Choose the Location Closest to You</h2>
      <p style="color: #6b7280; font-size: 0.9rem; margin-top: 0.5rem;">Walk in today or call ahead for faster service.</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 2rem; text-align: left;">

        <div style="border-radius: 0.75rem; border: 1.5px solid #e8472a; background: #ffffff; padding: 1.5rem;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
            <h3 style="font-weight: 700; font-size: 1rem; color: #111827; margin: 0;">St. Vital — Winnipeg</h3>
            <span style="background-color: #e8472a; color: #ffffff; font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 9999px; letter-spacing: 0.05em; text-transform: uppercase;">Primary</span>
          </div>
          <p style="color: #6b7280; font-size: 0.8rem; margin: 0 0 1.25rem 0;">845 Dakota St #25, Winnipeg, MB R2M 5M3</p>
          <a href="tel:2045009757" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background-color: #e8472a; color: #ffffff; font-size: 0.875rem; font-weight: 600; padding: 0.6rem 1rem; border-radius: 0.5rem; text-decoration: none; margin-bottom: 0.625rem;">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (204) 500-9757
          </a>
          <a href="https://maps.google.com/?q=845+Dakota+St+25+Winnipeg+MB+R2M+5M3" target="_blank" rel="noopener noreferrer" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background-color: #ffffff; color: #374151; font-size: 0.875rem; font-weight: 500; padding: 0.6rem 1rem; border-radius: 0.5rem; text-decoration: none; border: 1px solid #d1d5db;">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Open in Maps
          </a>
          <p style="color: #9ca3af; font-size: 0.75rem; margin: 0.875rem 0 0 0; text-align: center;">Walk-ins welcome &bull; Same-day repairs available</p>
        </div>

        <div style="border-radius: 0.75rem; border: 1px solid #e5e7eb; background: #ffffff; padding: 1.5rem;">
          <h3 style="font-weight: 700; font-size: 1rem; color: #111827; margin: 0 0 0.5rem 0;">Thompson Location</h3>
          <p style="color: #6b7280; font-size: 0.8rem; margin: 0 0 1.25rem 0;">300 Mystery Lake Rd #1530, Thompson, MB R8N 0M2</p>
          <a href="tel:2044100262" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background-color: #e8472a; color: #ffffff; font-size: 0.875rem; font-weight: 600; padding: 0.6rem 1rem; border-radius: 0.5rem; text-decoration: none; margin-bottom: 0.625rem;">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (204) 410-0262
          </a>
          <a href="https://maps.google.com/?q=300+Mystery+Lake+Rd+1530+Thompson+MB+R8N+0M2" target="_blank" rel="noopener noreferrer" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background-color: #ffffff; color: #374151; font-size: 0.875rem; font-weight: 500; padding: 0.6rem 1rem; border-radius: 0.5rem; text-decoration: none; border: 1px solid #d1d5db;">
            <svg xmlns="http://www.w3.org/2000/svg" style="height: 14px; width: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
