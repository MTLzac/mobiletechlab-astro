---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Professional Phone, Tablet, and Computer Repair | Mobile Tech Lab";
const description = "Expert phone repair, tablet repair, computer repair, and console repair in Winnipeg and Thompson. Fast service, quality parts, and professional technicians.";
const canonical = "https://mobiletechlab.ca";

const services = [
  {
    title: "iPhone Repair",
    href: "/repair/iphone",
    description: "Screen replacements, battery replacements, charging ports, and water damage repair for all iPhone models.",
    icon: `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  },
  {
    title: "Samsung Repair",
    href: "/repair/samsung",
    description: "Fast repairs for Galaxy phones — screens, batteries, and charging issues.",
    icon: `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  },
  {
    title: "iPad Repair",
    href: "/repair/ipad",
    description: "Screen replacements, battery service, and charging repairs for all iPad models.",
    icon: `<rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/>`,
  },
  {
    title: "MacBook Repair",
    href: "/repair/macbook",
    description: "Keyboard, screen, battery, and logic board repairs for MacBook Air and Pro.",
    icon: `<rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/>`,
  },
  {
    title: "PS5 Repair",
    href: "/repair/ps5",
    description: "HDMI port repair, overheating fixes, and console troubleshooting.",
    icon: `<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>`,
  },
  {
    title: "Nintendo Switch",
    href: "/repair/nintendo-switch",
    description: "Joy-Con drift fixes, screen repairs, and charging port replacement.",
    icon: `<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>`,
  },
];

const trustPoints = [
  { label: "Same-day repairs on most devices" },
  { label: "Certified technicians with years of experience" },
  { label: "Quality OEM and aftermarket parts" },
  { label: "90-day warranty on all repairs" },
  { label: "Walk-ins welcome, no appointment needed" },
  { label: "Serving Winnipeg and Thompson, Manitoba" },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
        Professional Phone, Tablet<br class="hidden md:block" /> &amp; Computer Repair
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Fast and reliable repair services in Winnipeg and Thompson.
        Our certified technicians fix phones, tablets, computers, and game consoles using quality parts.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Get a Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="tel:2045009757"
          class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Repair Services We Offer</h2>
      <p class="mb-10 text-center text-muted-foreground">Expert repairs for all major devices — walk-ins welcome</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a
            href={service.href}
            class="group flex flex-col rounded-lg border border-border bg-card p-6 hover:border-primary/50 hover:shadow-md transition-all duration-200"
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={service.icon} />
            </div>
            <h3 class="mb-2 font-semibold text-foreground group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="flex-1 text-sm text-muted-foreground">{service.description}</p>
            <div class="mt-4 flex items-center gap-1 text-sm font-medium text-primary">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a
          href="/repairs"
          class="inline-flex items-center gap-2 rounded-md border border-input px-6 py-2.5 text-sm font-medium hover:bg-accent transition-colors"
        >
          View all repair services
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Why Choose Mobile Tech Lab?</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {trustPoints.map(point => (
            <div class="flex items-center gap-3 rounded-lg border border-border bg-background p-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-sm font-medium">{point.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">Our Locations</h2>
      <p class="mb-10 text-center text-muted-foreground">Two convenient locations serving all of Manitoba</p>
      <div class="mx-auto grid max-w-3xl gap-6 md:grid-cols-2">

        <div class="rounded-lg border border-border bg-card p-6">
          <div class="mb-1 flex items-center justify-between">
            <h3 class="font-semibold text-lg">St. Vital — Winnipeg</h3>
            <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">Primary</span>
          </div>
          <p class="mb-3 text-sm text-muted-foreground">845 Dakota St #25, Winnipeg, MB R2M 5M3</p>
          <div class="space-y-1 text-sm text-muted-foreground mb-4">
            <p>Mon–Sat: 9AM – 7PM</p>
            <p>Sun: 12PM – 7PM</p>
          </div>
          <div class="flex gap-2">
            <a href="tel:2045009757" class="flex-1 flex items-center justify-center gap-1 rounded-md bg-primary px-3 py-2 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Call
            </a>
            <a href="https://maps.google.com/?q=845+Dakota+St+25+Winnipeg+MB+R2M+5M3" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-1 rounded-md border border-input px-3 py-2 text-xs font-medium hover:bg-accent transition-colors">
              Directions
            </a>
          </div>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class="mb-1 font-semibold text-lg">Thompson</h3>
          <p class="mb-3 text-sm text-muted-foreground">300 Mystery Lake Rd #1530, Thompson, MB R8N 0M2</p>
          <div class="space-y-1 text-sm text-muted-foreground mb-4">
            <p>Mon–Sat: 10AM – 6PM</p>
            <p>Sun: Closed</p>
          </div>
          <div class="flex gap-2">
            <a href="tel:2044100262" class="flex-1 flex items-center justify-center gap-1 rounded-md bg-primary px-3 py-2 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Call
            </a>
            <a href="https://maps.google.com/?q=300+Mystery+Lake+Rd+1530+Thompson+MB+R8N+0M2" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-1 rounded-md border border-input px-3 py-2 text-xs font-medium hover:bg-accent transition-colors">
              Directions
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Get Your Device Fixed?</h2>
      <p class="mb-8 text-muted-foreground">Get a free quote online or walk in to either of our Manitoba locations.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
