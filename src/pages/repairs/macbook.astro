---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "MacBook Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Professional MacBook repair in Winnipeg. Screen, battery, keyboard, liquid damage and data recovery for all MacBook Air and Pro models. M1, M2, M3 specialists.";
const canonical = "https://mobiletechlab.ca/repairs/macbook";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "MacBook Repair", "item": "https://mobiletechlab.ca/repairs/macbook" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "MacBook Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Laptop Repair",
  "url": "https://mobiletechlab.ca/repairs/macbook",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "MacBook Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Keyboard Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Data Recovery" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Liquid Damage Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging and MagSafe Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does MacBook screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most MacBook screen replacements are completed within 1–3 business days at our Winnipeg location depending on parts availability for your specific model and year. M3 MacBook Pro Liquid Retina XDR screens may take longer to source — contact us to confirm availability before visiting." } },
    { "@type": "Question", "name": "Can you recover data from a water-damaged MacBook in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — in many cases we can recover data from liquid-damaged MacBooks using component-level diagnostics and specialised data recovery tools. Apple Silicon MacBooks store data on chips soldered to the logic board, which makes recovery more complex but still possible in many cases — bring it in as soon as possible for the best outcome." } },
    { "@type": "Question", "name": "Do you repair MacBooks with Apple Silicon M1, M2, and M3?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair the full Apple Silicon MacBook lineup including M1, M2, and M3 Air and Pro models. Apple Silicon repairs require different techniques than Intel models due to the tighter integration of logic board, battery, and storage components — our Winnipeg technicians are trained on all generations." } },
    { "@type": "Question", "name": "How much does MacBook battery replacement cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "MacBook battery replacement costs vary by model and generation — older Intel models are generally less expensive than M-chip models due to differences in battery integration. Contact us or use our online quote tool for a free upfront price on your specific MacBook model." } },
    { "@type": "Question", "name": "Is my data safe during MacBook repair at Mobile Tech Lab?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — your files remain untouched during all hardware repairs. For liquid damage or data recovery cases, we document the device state on arrival and walk you through the process step by step. We recommend backing up your data before any repair when possible." } },
    { "@type": "Question", "name": "Can you fix a MacBook with a swollen battery in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — swollen MacBook batteries are a safety issue we treat as urgent. A swollen battery can warp the trackpad and chassis if left unaddressed. We replace swollen batteries on all MacBook models and dispose of the old battery safely. Do not leave a swollen battery unattended — bring it in as soon as possible." } },
    { "@type": "Question", "name": "Do you repair MacBook keyboard issues including butterfly keyboard?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we replace keyboards on all MacBook models including the notorious butterfly mechanism on 2016–2019 MacBook Pros. We replace the full keyboard assembly rather than individual keys for a lasting fix. Most keyboard replacements are completed within 1–2 business days." } },
    { "@type": "Question", "name": "Can you fix a MacBook that won't turn on in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a MacBook that won't power on is often caused by a depleted or failed battery, a liquid-damaged logic board, or a firmware issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the problem is before spending anything." } },
    { "@type": "Question", "name": "Do you repair MacBook charging issues in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we diagnose and repair all MacBook charging problems including MagSafe connector damage, USB-C port repairs, charging IC faults, and battery connector issues. We test the full charging chain before replacing any parts to avoid unnecessary repairs." } },
    { "@type": "Question", "name": "Do you repair MacBooks in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts MacBook repairs Monday through Saturday 10AM–6PM. For screen replacements or less common models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="mb-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="mb-container">
      <ol class="mb-breadcrumb-list">
        <li><a href="/" class="mb-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="mb-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="mb-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="mb-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="mb-breadcrumb-current" aria-current="page">MacBook Repair</li>
      </ol>
    </div>
  </nav>

  <section class="mb-hero-section" id="hero">
    <div class="mb-hero-inner">
      <div class="mb-hero-content">
        <div class="mb-hero-badge-row">
          <span class="mb-service-badge">MacBook Air & Pro Repair Specialists</span>
          <span class="mb-location-badge">
            <span class="mb-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="mb-location-badge">
            <span class="mb-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="mb-hero-headline">
          MacBook Repair <span class="mb-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="mb-hero-subheadline">MacBook Air & Pro Repair Specialists — M1, M2 & M3 Models</p>

        <div class="mb-hero-body">
          <p>Cracked Retina display, swollen battery, liquid damage, or unresponsive keyboard? We repair all MacBook Air and Pro models at our Winnipeg shop — from Intel-based machines through the latest M3 Apple Silicon. Common repairs include screen replacements, battery swaps, keyboard replacements, MagSafe and USB-C charging fixes, liquid damage restoration, and data recovery from failed SSDs.</p>
          <p>MacBook repairs require specialised tools and model-specific parts — particularly for Apple Silicon models where the logic board, battery, and display are tightly integrated. Our Winnipeg technicians perform component-level diagnostics before recommending any repair, so you get an honest assessment of what's wrong and what it will cost before we touch your machine.</p>
        </div>

        <div class="mb-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="mb-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="mb-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="mb-hero-image-wrapper">
        <img
          src="/assets/hero-macbook-Cp0WkrNX.png"
          alt="MacBook repair in Winnipeg — screen, battery and keyboard specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="mb-annotations-list" aria-label="Common MacBook issues we fix">
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Cracked screen
          </li>
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery swollen or dead
          </li>
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M7 16h10"/></svg>
            Keyboard not working
          </li>
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            Liquid damage
          </li>
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
            Won't charge
          </li>
          <li class="mb-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            Data recovery
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mb-services-section" id="services">
    <div class="mb-container">
      <div class="mb-section-header">
        <h2 class="mb-section-title">MacBook Repair Services in Winnipeg</h2>
        <p class="mb-section-subtitle">Expert repairs for all MacBook Air and Pro models. Free diagnostics, quality parts, warranty included.</p>
      </div>
      <div class="mb-services-grid">
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="mb-service-title">Screen Replacement</h3>
          <p class="mb-service-body">Cracked Retina display, dead pixels, or backlight failure on your MacBook? We replace screens on all MacBook Air and Pro models including the Liquid Retina XDR display on M3 Pro and Max models. MacBook screen replacements typically take 1–3 business days depending on parts availability for your specific model and year.</p>
        </div>
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="mb-service-title">Battery Replacement</h3>
          <p class="mb-service-body">MacBook battery swelling, not holding charge, or showing Service Recommended? We replace batteries on all MacBook models with quality cells. Apple Silicon MacBook batteries are more tightly integrated than Intel models — we disassemble carefully to avoid logic board damage during the swap. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M7 16h10"/></svg>
          </div>
          <h3 class="mb-service-title">Keyboard Replacement</h3>
          <p class="mb-service-body">Sticky butterfly keys, unresponsive Magic Keyboard, or keys not registering on your MacBook? We perform complete keyboard replacements on all MacBook models. The notorious butterfly keyboard mechanism on 2016–2019 MacBook Pros is a common repair we handle regularly — we replace the full keyboard assembly rather than individual keys for a lasting fix.</p>
        </div>
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3 class="mb-service-title">Data Recovery</h3>
          <p class="mb-service-body">Lost files from a failed SSD or corrupted drive on your MacBook? We recover data from damaged, water-affected, and non-booting MacBooks. Apple Silicon MacBooks use onboard storage soldered to the logic board — data recovery requires specialised tools and expertise. We assess recovery feasibility before charging anything.</p>
        </div>
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          </div>
          <h3 class="mb-service-title">Liquid Damage Repair</h3>
          <p class="mb-service-body">Coffee or water spill on your MacBook? We specialise in liquid damage restoration using ultrasonic cleaning and component-level diagnostics. MacBook liquid damage can affect the keyboard, logic board, and battery simultaneously — we assess all affected components before recommending a repair path. Bring it in as soon as possible for the best outcome.</p>
        </div>
        <div class="mb-service-card">
          <div class="mb-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="mb-service-title">Charging & MagSafe Repair</h3>
          <p class="mb-service-body">MacBook not charging via MagSafe or USB-C? We diagnose and repair charging issues across all MacBook models — including MagSafe connector damage, USB-C port repairs, battery connector faults, and charging IC failures. We test the full charging chain before recommending any part replacement.</p>
        </div>
      </div>
      <div class="mb-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="mb-models-section" id="models">
    <div class="mb-container">
      <div class="mb-section-header">
        <h2 class="mb-section-title">All MacBook Models We Repair in Winnipeg</h2>
        <p class="mb-section-subtitle">From Intel MacBooks through the latest M3 Apple Silicon — all generations serviced</p>
      </div>
      <div class="mb-models-grid">
        <div class="mb-model-card">
          <div class="mb-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="mb-model-title">MacBook Air</h3>
          <p class="mb-model-description">Ultralight MacBook repairs for all Air generations. M-series MacBook Air batteries and screens are tightly integrated — we use model-specific parts for every generation.</p>
          <div class="mb-model-pills">
            <span class="mb-pill">MacBook Air M3 (2024)</span>
            <span class="mb-pill">MacBook Air M2 (2022)</span>
            <span class="mb-pill">MacBook Air M1 (2020)</span>
            <span class="mb-pill">MacBook Air Retina (2018–2020)</span>
            <span class="mb-pill">MacBook Air (2015–2017)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="mb-model-card">
          <div class="mb-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="mb-model-title">MacBook Pro 14" & 16"</h3>
          <p class="mb-model-description">Pro-level MacBook repairs including Liquid Retina XDR displays and MagSafe charging. Notch-era and M-chip models require model-specific screen assemblies — contact us to confirm parts availability.</p>
          <div class="mb-model-pills">
            <span class="mb-pill">MacBook Pro 16" M3 (2023)</span>
            <span class="mb-pill">MacBook Pro 14" M3 (2023)</span>
            <span class="mb-pill">MacBook Pro 16" M2 (2023)</span>
            <span class="mb-pill">MacBook Pro 14" M2 (2023)</span>
            <span class="mb-pill">MacBook Pro 16" M1 (2021)</span>
            <span class="mb-pill">MacBook Pro 14" M1 (2021)</span>
            <span class="mb-pill">MacBook Pro 16" (2019)</span>
            <span class="mb-pill">MacBook Pro 15" (2015–2019)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="mb-model-card">
          <div class="mb-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="mb-model-title">MacBook Pro 13"</h3>
          <p class="mb-model-description">Compact MacBook Pro repairs including the Touch Bar models. The 2016–2019 butterfly keyboard is one of our most common MacBook Pro repairs — we replace the full assembly for a lasting fix.</p>
          <div class="mb-model-pills">
            <span class="mb-pill">MacBook Pro 13" M2 (2022)</span>
            <span class="mb-pill">MacBook Pro 13" M1 (2020)</span>
            <span class="mb-pill">MacBook Pro 13" (2016–2020)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="mb-model-card">
          <div class="mb-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="mb-model-title">MacBook 12"</h3>
          <p class="mb-model-description">Retina MacBook repairs for the ultra-slim 12-inch models. These use a USB-C only design and have one of the most compact battery and keyboard assemblies Apple has made.</p>
          <div class="mb-model-pills">
            <span class="mb-pill">MacBook 12" (2017)</span>
            <span class="mb-pill">MacBook 12" (2016)</span>
            <span class="mb-pill">MacBook 12" (2015)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="mb-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-why-section" id="why-choose-us">
    <div class="mb-container">
      <div class="mb-section-header">
        <h2 class="mb-section-title">The Mobile Tech Lab Advantage: Winnipeg's MacBook Repair Experts</h2>
        <p class="mb-section-subtitle">Why Winnipeg customers trust us with their MacBooks</p>
      </div>
      <div class="mb-pillars-grid">
        <div class="mb-pillar-card">
          <div class="mb-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="mb-pillar-title">M1, M2 & M3 Specialists</h3>
          <p class="mb-pillar-body">Apple Silicon MacBooks require different repair techniques than Intel models — the logic board, battery, and display are far more integrated. Our Winnipeg technicians are experienced with the full M-chip MacBook lineup including the latest M3 Air, M3 Pro, and M3 Max configurations.</p>
        </div>
        <div class="mb-pillar-card">
          <div class="mb-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
