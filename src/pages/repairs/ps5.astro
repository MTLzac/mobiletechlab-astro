---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "PS5 Repair Winnipeg | PlayStation 5 Fix | Mobile Tech Lab";
const description = "PS5 repair specialists in Winnipeg. HDMI port micro-soldering, overheating, disc drive, DualSense controller & PS5 Pro repair. Same-day service available.";
const canonical = "https://mobiletechlab.ca/repairs/ps5";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "PS5 Repair", "item": "https://mobiletechlab.ca/repairs/ps5" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "PlayStation 5 Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Console Repair",
  "url": "https://mobiletechlab.ca/repairs/ps5",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "PS5 Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Overheating Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HDMI Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Disc Drive Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "DualSense Controller Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SSD Upgrade" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Display and Power Issues" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Can you fix PS5 overheating in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we fully disassemble the PS5, deep clean all cooling channels, and apply high-performance thermal paste to the APU and VRAM. Most overheating repairs are completed same-day when dropped off before noon at our Winnipeg St. Vital location." } },
    { "@type": "Question", "name": "Do you repair DualSense controller stick drift in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair analog stick drift on both standard DualSense and DualSense Edge controllers, typically within 1–2 hours at our Winnipeg location. We also repair adaptive trigger failures, unresponsive touchpads, broken bumpers, and USB-C charging port damage." } },
    { "@type": "Question", "name": "Can you fix PS5 HDMI port issues in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — HDMI port repair is one of our most common PS5 repairs and our technicians perform precision board-level micro-soldering under magnification. We repair broken HDMI connectors, lifted solder pads, and motherboard trace damage that most general repair shops in Winnipeg cannot handle." } },
    { "@type": "Question", "name": "Do you upgrade PS5 storage in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we install larger NVMe M.2 PCIe 4.0 SSDs in PS5 consoles up to 4TB capacity. We'll recommend the right drive for your budget, install it correctly, and ensure the required heatsink is properly fitted as per Sony's official installation guidance." } },
    { "@type": "Question", "name": "Can you fix PS5 disc drive problems?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we diagnose and repair PS5 disc reading issues, stuck discs, ejecting problems, and drive mechanism failures. We also discuss disc drive upgrade options for PS5 Digital Edition owners — contact us to confirm availability before visiting." } },
    { "@type": "Question", "name": "How much does PS5 HDMI repair cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "PS5 HDMI repair costs depend on the extent of the damage — a straightforward port replacement costs less than a repair involving lifted motherboard pads and trace damage. We provide a clear diagnostic and upfront quote before starting any work so you know exactly what you're paying for." } },
    { "@type": "Question", "name": "Is PS5 HDMI repair done the same day in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Many PS5 HDMI repairs are completed same-day when dropped off at our Winnipeg St. Vital location before noon. Cases involving significant motherboard trace damage may require additional time — we'll give you an accurate estimate after the initial diagnostic." } },
    { "@type": "Question", "name": "Why does my PS5 keep overheating and shutting down?", "acceptedAnswer": { "@type": "Answer", "text": "PS5 overheating is almost always caused by dust buildup clogging the heatsink fins and degraded thermal compound on the APU pushing temperatures past safe limits. A full disassembly, deep clean, and thermal paste replacement typically resolves the issue completely — and is one of the best value repairs you can do on a PS5 to extend its lifespan." } },
    { "@type": "Question", "name": "Do you offer a warranty on PS5 repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we offer a lifetime warranty on most PS5 HDMI port and DualSense controller repairs. Overheating repairs include a 90-day warranty. If the same issue returns within the warranty period, we repair it at no charge." } },
    { "@type": "Question", "name": "Do you repair PS5 consoles in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts PS5 repairs Monday through Saturday 10AM–6PM. Calling ahead helps us confirm parts availability and give you an accurate turnaround estimate before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="ps5-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="ps5-container">
      <ol class="ps5-breadcrumb-list">
        <li><a href="/" class="ps5-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ps5-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="ps5-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ps5-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="ps5-breadcrumb-current" aria-current="page">PS5 Repair</li>
      </ol>
    </div>
  </nav>

  <section class="ps5-hero-section" id="hero">
    <div class="ps5-hero-inner">
      <div class="ps5-hero-content">
        <div class="ps5-hero-badge-row">
          <span class="ps5-service-badge">PlayStation 5 Repair Specialists</span>
          <span class="ps5-location-badge">
            <span class="ps5-badge-dot"></span>
            St. Vital - Open
          </span>
          <span class="ps5-location-badge ps5-location-badge-secondary">
            <span class="ps5-badge-dot ps5-badge-dot-secondary"></span>
            Thompson - Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="ps5-hero-headline">
          PS5 Repair <span class="ps5-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="ps5-hero-subheadline">PlayStation 5 Console & DualSense Controller Repair Specialists</p>

        <div class="ps5-hero-body">
          <p>PS5 overheating? HDMI not working? Disc drive not reading? We repair all PlayStation 5 models at our Winnipeg shop — PS5 Disc Edition, Digital Edition, Slim, and PS5 Pro. The most common PS5 issue we see is HDMI port damage — our technicians perform precision board-level micro-soldering under magnification to restore broken ports, lifted pads, and trace damage that most console repair shops in Winnipeg cannot perform.</p>
          <p>PS5 overheating is the second most common issue — caused by years of dust buildup clogging the heatsink and degraded thermal compound pushing the APU past safe temperatures. We fully disassemble the console, deep clean every cooling channel, and apply high-performance thermal paste. Most PS5 HDMI and overheating repairs are completed same-day when dropped off early enough.</p>
        </div>

        <div class="ps5-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ps5-cta-primary">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="tel:2045009757" class="ps5-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="ps5-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="ps5-hero-image-wrapper">
        <img
          src="/assets/hero-playstation-U7zMrpV6.png"
          alt="PS5 repair in Winnipeg — HDMI port, overheating, disc drive and DualSense controller specialists"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="ps5-annotations-list" aria-label="Common PS5 issues we fix">
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18 4H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2z"/><path d="M8 4v16"/></svg>
            HDMI port issues
          </li>
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Power issues / random restarting
          </li>
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M22 10H2"/></svg>
            USB port not working
          </li>
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
            Disc drive problems
          </li>
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Stick drift
          </li>
          <li class="ps5-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="6" y="11" width="4" height="6" rx="1"/><rect x="14" y="11" width="4" height="6" rx="1"/></svg>
            Button issues
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="ps5-services-section" id="services">
    <div class="ps5-container">
      <div class="ps5-section-header">
        <h2 class="ps5-section-title">PS5 Repair Services in Winnipeg</h2>
        <p class="ps5-section-subtitle">Expert repairs for all PlayStation 5 issues. Fast turnaround, quality parts, warranty included.</p>
      </div>
      <div class="ps5-services-grid">
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44l-2.1-8.4A4 4 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44l2.1-8.4A4 4 0 0 0 14.5 2Z"/></svg>
          </div>
          <h3 class="ps5-service-title">Overheating Repair</h3>
          <p class="ps5-service-body">PS5 overheating is caused by years of dust buildup clogging the heatsink and degraded thermal compound pushing the APU past safe operating temperatures — resulting in shutdowns mid-game, loud fan noise, and eventual hardware damage. We fully disassemble the console, deep clean all cooling channels with compressed air and brushes, and apply high-performance thermal paste to the APU and VRAM. Most overheating repairs are completed same-day when dropped off before noon.</p>
        </div>
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18 4H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2z"/><path d="M8 4v16"/></svg>
          </div>
          <h3 class="ps5-service-title">HDMI Port Repair</h3>
          <p class="ps5-service-body">HDMI port damage is the single most common PS5 repair we perform in Winnipeg. A pushed-in, bent, or broken HDMI port leaves you with no video output at all. Our technicians perform precision board-level micro-soldering under magnification to restore the HDMI connector, rebuild lifted solder pads, and repair trace damage on the motherboard — a repair that most general electronics shops in Winnipeg cannot reliably perform. Many HDMI repairs are completed same-day.</p>
        </div>
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="ps5-service-title">Disc Drive Repair</h3>
          <p class="ps5-service-body">PS5 disc drive not reading discs, making grinding noises, or refusing to eject? We diagnose and repair disc reading issues, stuck or jammed discs, and drive mechanism failures. We also perform disc drive upgrades for PS5 Digital Edition consoles that need to be converted to disc capability — contact us to confirm availability for your specific model.</p>
        </div>
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="6" y="11" width="4" height="6" rx="1"/><rect x="14" y="11" width="4" height="6" rx="1"/><path d="M4 9h16a1 1 0 011 1v10a2 2 0 01-2 2H5a2 2 0 01-2-2V10a1 1 0 011-1z"/><circle cx="9" cy="8" r="3"/><circle cx="15" cy="8" r="3"/></svg>
          </div>
          <h3 class="ps5-service-title">DualSense Controller Repair</h3>
          <p class="ps5-service-body">DualSense stick drift, adaptive trigger not working, touchpad unresponsive, or charging port damaged? We repair and replace analog sticks, adaptive trigger mechanisms, touchpad assemblies, USB-C charging ports, and buttons on both standard DualSense and DualSense Edge controllers. Most controller repairs are completed within 1–2 hours.</p>
        </div>
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M22 10H2"/></svg>
          </div>
          <h3 class="ps5-service-title">SSD Upgrade</h3>
          <p class="ps5-service-body">Running out of PS5 storage? We install larger NVMe M.2 SSDs to give you room for more games without deleting your existing library. PS5 supports PCIe 4.0 NVMe drives up to 4TB — we'll recommend the right drive for your budget and install it correctly including the heatsink that Sony's official guidance requires.</p>
        </div>
        <div class="ps5-service-card">
          <div class="ps5-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="ps5-service-title">Display & Power Issues</h3>
          <p class="ps5-service-body">PS5 turns on but no display, blue light blinking, console shutting off randomly, or not powering on at all? These symptoms often indicate HDMI damage, power supply faults, or APU-related issues. We run full diagnostics before recommending any repair — including checking HDMI port integrity, power delivery, and thermal performance — so you know exactly what's wrong before spending anything.</p>
        </div>
      </div>
      <div class="ps5-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ps5-cta-primary">
          Request Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="ps5-models-section" id="models">
    <div class="ps5-container">
      <div class="ps5-section-header">
        <h2 class="ps5-section-title">All PS5 Models & Accessories We Repair in Winnipeg</h2>
        <p class="ps5-section-subtitle">Every PlayStation 5 variant serviced — consoles, controllers, and accessories</p>
      </div>
      <div class="ps5-models-grid">
        <div class="ps5-model-card">
          <div class="ps5-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M22 10H2"/></svg>
          </div>
          <h3 class="ps5-model-title">PS5 Consoles</h3>
          <p class="ps5-model-description">All PlayStation 5 console models repaired. HDMI, overheating, disc drive, and power issues serviced on every PS5 variant including the newer Slim chassis and PS5 Pro.</p>
          <div class="ps5-model-pills">
            <span class="ps5-pill">PS5 Disc Edition</span>
            <span class="ps5-pill">PS5 Digital Edition</span>
            <span class="ps5-pill">PS5 Slim (Disc)</span>
            <span class="ps5-pill">PS5 Slim Digital</span>
            <span class="ps5-pill">PS5 Pro</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ps5-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="ps5-model-card">
          <div class="ps5-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="6" y="11" width="4" height="6" rx="1"/><rect x="14" y="11" width="4" height="6" rx="1"/><path d="M4 9h16a1 1 0 011 1v10a2 2 0 01-2 2H5a2 2 0 01-2-2V10a1 1 0 011-1z"/><circle cx="9" cy="8" r="3"/><circle cx="15" cy="8" r="3"/></svg>
          </div>
          <h3 class="ps5-model-title">DualSense Controllers</h3>
          <p class="ps5-model-description">Stick drift, adaptive trigger failures, touchpad issues, and USB-C charging port repairs for both standard DualSense and the premium DualSense Edge. Most controller repairs are completed within 1–2 hours.</p>
          <div class="ps5-model-pills">
            <span class="ps5-pill">DualSense Controller</span>
            <span class="ps5-pill">DualSense Edge Controller</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ps5-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="ps5-model-card">
          <div class="ps5-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="ps5-model-title">PlayStation Accessories</h3>
          <p class="ps5-model-description">PlayStation VR2 headset repairs including display and lens issues, and Pulse 3D headset audio repairs. Contact us to confirm parts availability before visiting for accessory repairs.</p>
          <div class="ps5-model-pills">
            <span class="ps5-pill">PlayStation VR2</span>
            <span class="ps5-pill">Pulse 3D Headset</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ps5-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="ps5-why-section" id="why-choose-us">
    <div class="ps5-container">
      <div class="ps5-section-header">
        <h2 class="ps5-section-title">The Mobile Tech Lab Advantage: Winnipeg's PS5 Repair Experts</h2>
        <p class="ps5-section-subtitle">Why Winnipeg PlayStation owners trust us with their PS5</p>
      </div>
      <div class="ps5-pillars-grid">
        <div class="ps5-pillar-card">
          <div class="ps5-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44l-2.1-8.4A4 4 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44l2.1-8.4A4 4 0 0 0 14.5 2Z"/></svg>
          </div>
          <h3 class="ps5-pillar-title">PlayStation Specialists</h3>
          <p class="ps5-pillar-body">PS5 repairs require board-level micro-soldering skills and console-specific tools that most general repair shops don't carry. Our Winnipeg technicians have hands-on experience with every PS5 model — from the original launch console through PS5 Slim and PS5 Pro — and perform HDMI repairs under magnification for precision results.</p>
        </div>
        <div class="ps5-pillar-card">
          <div class="ps5-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="ps5-pillar-title">Same-Day Console Repairs</h3>
          <p class="ps5-pillar-body">Most PS5 HDMI port repairs and overheating fixes are completed same-day when dropped off at our Winnipeg St. Vital location before noon. DualSense controller repairs are typically finished within 1–2 hours. We'll give you an honest time estimate when you contact us — no vague 'a few days' timelines.</p>
        </div>
        <div class="ps5-pillar-card">
          <div class="ps5-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9l1.5 9h15L21 9a2 2 0 00-2-2H5a2 2 0 00-2 2zm0 0l2-5h14l2 5"/><line x1="9" y1="22" x2="9" y2="15"/><line x1="15" y1="22" x2="15" y2="15"/></svg>
          </div>
          <h3 class="ps5-pillar-title">Precision Board-Level Repair</h3>
          <p class="ps5-pillar-body">PS5 HDMI port failures often involve lifted solder pads and motherboard trace damage — not just a loose connector. We perform micro-soldering repairs under magnification to rebuild damaged pads and restore trace continuity. This is the repair that separates specialist console repair shops from shops that just swap parts.</p>
        </div>
        <div class="ps5-pillar-card">
          <div class="ps5-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="ps5-pillar-title">Warranty on Every Repair</h3>
          <p class="ps5-pillar-body">We offer a lifetime warranty on most PS5 HDMI and controller repairs. Overheating repairs are covered for 90 days. If the same issue returns within the warranty period, we fix it at no charge. We're confident enough in our work to put that in writing.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ps5-cost-section" id="pricing">
    <div class="ps5-container">
      <div class="ps5-section-header">
        <h2 class="ps5-section-title">Worried About Repair Cost? You Have Options.</h2>
        <p class="ps5-section-subtitle">Most customers use one of these options to lower their repair cost.</p>
      </div>
      <div class="ps5-cost-grid">
        <div class="ps5-cost-card">
          <div class="ps5-cost-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="ps5-cost-title">We'll Match Any Local Repair Price</h3>
          <p class="ps5-cost-body">Found a lower price at another Winnipeg repair shop? We'll match it — so you don't overpay. No pressure. No hassle.</p>
          <a href="sms:2045009757?body=Hey%20Mobile%20Tech%20Lab!%20I%20want%20a%20better%20price%20on%20a%20repair!" class="ps5-price-match-btn">
