---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Motorola Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Motorola repair specialists in Winnipeg. Screen, battery, charging port for Moto G, Edge, Razr foldable & all models. Razr hinge specialists. Same-day service.";
const canonical = "https://mobiletechlab.ca/repairs/motorola";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Motorola Repair", "item": "https://mobiletechlab.ca/repairs/motorola" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motorola Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repairs/motorola",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Motorola Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Speaker and Microphone Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Connectivity Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does Motorola screen repair cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Motorola repair costs vary by model — Moto G and E series screens are generally the most accessible in the lineup, while Edge flagships and Razr foldables cost more due to premium OLED panels and complex disassembly. Contact us or use our online quote tool for a free upfront price on your specific model." } },
    { "@type": "Question", "name": "Do you repair Motorola Razr foldable phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we're one of the few Winnipeg repair shops with experience servicing Motorola Razr foldables including the inner foldable screen, outer display, hinge mechanism, and flex cable assembly. Contact us before visiting to confirm parts availability for your specific Razr model and get an accurate quote." } },
    { "@type": "Question", "name": "How long does Motorola repair take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Motorola Moto G and Edge screen and battery repairs are completed same-day in 1–2 hours at our Winnipeg St. Vital location. Razr foldable repairs take longer due to complexity, and parts for some Razr models may require a short sourcing window — we'll give you an estimated time when you contact us." } },
    { "@type": "Question", "name": "Is it worth repairing my Moto G or Moto E in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "In most cases yes — Moto G and E series phones are well-built devices and screen or battery repairs are typically straightforward. We provide a free diagnostic and upfront quote so you can make an informed decision before committing to any repair." } },
    { "@type": "Question", "name": "Do you stock Motorola parts in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "We stock common parts for all current Moto G and Edge series models for same-day repairs. Razr foldable parts and less common models may require a short sourcing window of 1–3 business days — contact us with your specific model to confirm availability before visiting." } },
    { "@type": "Question", "name": "Do you repair Motorola Edge screens in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we replace OLED screens on all Motorola Edge models including Edge 30, 40, and 50 series at our Winnipeg location. Edge Pro and Ultra models use curved OLED displays that require model-specific panels — we use quality matched parts to maintain the original display quality after repair." } },
    { "@type": "Question", "name": "Can you fix a Motorola that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive Motorola is often caused by a depleted battery, a failed display connection, or a software boot issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the problem is before spending anything." } },
    { "@type": "Question", "name": "Do you repair Motorola charging ports in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair USB-C charging ports on all Motorola models at our Winnipeg location. We always clean the port first before recommending replacement since debris is a common cause of Moto G and Moto E charging issues — most charging port repairs are completed same-day." } },
    { "@type": "Question", "name": "Do you offer a warranty on Motorola repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — screen repairs carry a 30-day to lifetime warranty depending on part tier. Battery replacements include a 90-day warranty, and most other repairs carry a lifetime warranty on parts and labour across the full Motorola lineup." } },
    { "@type": "Question", "name": "Do you repair Motorola phones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts Motorola repairs Monday through Saturday 10AM–6PM. For Razr foldables or less common Edge models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="moto-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="moto-container">
      <ol class="moto-breadcrumb-list">
        <li><a href="/" class="moto-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="moto-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="moto-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="moto-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="moto-breadcrumb-current" aria-current="page">Motorola Repair</li>
      </ol>
    </div>
  </nav>

  <section class="moto-hero-section" id="hero">
    <div class="moto-hero-inner">
      <div class="moto-hero-content">
        <div class="moto-hero-badge-row">
          <span class="moto-service-badge">Motorola & Razr Foldable Specialists</span>
          <span class="moto-location-badge">
            <span class="moto-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="moto-location-badge">
            <span class="moto-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="moto-hero-headline">
          Motorola Repair <span class="moto-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="moto-hero-subheadline">Moto G, Edge, Razr Foldable & ThinkPhone Repair Specialists in Winnipeg</p>

        <div class="moto-hero-body">
          <p>Cracked Motorola screen or battery not lasting the day? We repair all Motorola models at our Winnipeg shop — from budget-friendly Moto G and E series through Edge flagships and the foldable Razr lineup. Common repairs include screen replacements, battery swaps, USB-C charging port fixes, camera repairs, speaker issues, and connectivity diagnostics.</p>
          <p>The Motorola Razr is one of the most technically demanding foldable repairs available — the inner foldable display, hinge mechanism, and flex cable all require specialist parts and techniques. We're one of the few Winnipeg repair shops with experience servicing Razr foldables. We'll always confirm parts availability and give you an upfront quote before starting any repair.</p>
        </div>

        <div class="moto-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="moto-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="moto-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="moto-hero-image-wrapper">
        <img
          src="/assets/hero-motorola-BDicJTEd.png"
          alt="Motorola phone repair in Winnipeg — Moto G, Edge and Razr foldable specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="moto-annotations-list" aria-label="Common Motorola issues we fix">
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Charging port issues
          </li>
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Camera not working
          </li>
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
          <li class="moto-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18"/></svg>
            Razr hinge repair
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="moto-services-section" id="services">
    <div class="moto-container">
      <div class="moto-section-header">
        <h2 class="moto-section-title">Motorola Repair Services in Winnipeg</h2>
        <p class="moto-section-subtitle">Expert repairs for all Motorola models including Razr foldables. Quality parts, warranty included.</p>
      </div>
      <div class="moto-services-grid">
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="moto-service-title">Screen Replacement</h3>
          <p class="moto-service-body">Cracked or unresponsive Motorola display? We replace OLED screens on Moto Edge flagships, LCD and OLED on Moto G series, and the complex foldable inner and outer displays on Motorola Razr models. Razr inner screen replacements require specialist foldable display handling — contact us to confirm parts availability for your specific Razr model.</p>
        </div>
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="moto-service-title">Battery Replacement</h3>
          <p class="moto-service-body">Motorola battery draining too fast or not holding a charge? We replace batteries on all Moto G, Edge, Razr, and ThinkPhone models with quality cells and same-day turnaround where parts are in stock. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="moto-service-title">Charging Port Repair</h3>
          <p class="moto-service-body">Motorola not charging or connecting intermittently? We repair USB-C ports on all Motorola models. We clean the port before recommending replacement since debris and lint are common causes of Moto G and Moto E charging failures. Most charging port repairs are completed same-day.</p>
        </div>
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="moto-service-title">Camera Repair</h3>
          <p class="moto-service-body">Blurry photos, black camera screen, or cracked lens on your Motorola? We fix front, rear, and wide-angle camera modules on all Moto G, Edge, and Razr models. Edge Ultra models feature 200MP main sensors — we use model-matched camera modules to preserve the full resolution and optical zoom capability after repair.</p>
        </div>
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
          <h3 class="moto-service-title">Speaker & Microphone Repair</h3>
          <p class="moto-service-body">Muffled audio, crackling speakers, or microphone not working on your Motorola? We repair speaker assemblies, earpieces, and microphones across all Motorola models. Most speaker repairs are completed same-day at our Winnipeg location.</p>
        </div>
        <div class="moto-service-card">
          <div class="moto-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M1 6s.5-1 2-1 1.5 1 3 1 1.5-1 3-1 1.5 1 3 1 1.5-1 3-1 1.5 1 3 1"/><path d="M1 12s.5-1 2-1 1.5 1 3 1 1.5-1 3-1 1.5 1 3 1 1.5-1 3-1 1.5 1 3 1"/><line x1="12" y1="20" x2="12" y2="20"/></svg>
          </div>
          <h3 class="moto-service-title">Connectivity Repair</h3>
          <p class="moto-service-body">WiFi dropping, Bluetooth not connecting, or poor cellular signal on your Motorola? We diagnose and repair antenna, WiFi, and Bluetooth module issues across all Motorola models. Connectivity problems are often caused by physical damage to internal antennas — we perform component-level diagnosis before recommending any repair.</p>
        </div>
      </div>
      <div class="moto-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="moto-models-section" id="models">
    <div class="moto-container">
      <div class="moto-section-header">
        <h2 class="moto-section-title">All Motorola Models We Repair in Winnipeg</h2>
        <p class="moto-section-subtitle">Edge flagships, Razr foldables, Moto G and E series — every Motorola model serviced</p>
      </div>
      <div class="moto-models-grid">
        <div class="moto-model-card">
          <div class="moto-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="moto-model-title">Motorola Edge Series</h3>
          <p class="moto-model-description">Motorola's flagship OLED phones. Edge Pro and Ultra models feature curved displays and high-resolution camera systems — repairs require model-specific parts to maintain full functionality.</p>
          <div class="moto-model-pills">
            <span class="moto-pill">Edge 50 Ultra</span>
            <span class="moto-pill">Edge 50 Pro</span>
            <span class="moto-pill">Edge 50</span>
            <span class="moto-pill">Edge 40 Pro</span>
            <span class="moto-pill">Edge 40 Neo</span>
            <span class="moto-pill">Edge 40</span>
            <span class="moto-pill">Edge 30 Ultra</span>
            <span class="moto-pill">Edge 30 Pro</span>
            <span class="moto-pill">Edge 30</span>
            <span class="moto-pill">Edge+</span>
            <span class="moto-pill">Edge</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="moto-model-card">
          <div class="moto-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="moto-model-title">Motorola Razr</h3>
          <p class="moto-model-description">Foldable phone repairs including inner screen, outer screen, and hinge mechanism. Razr repairs are among the most complex available — contact us before visiting to confirm parts and get a quote.</p>
          <div class="moto-model-pills">
            <span class="moto-pill">Razr 40 Ultra</span>
            <span class="moto-pill">Razr 40</span>
            <span class="moto-pill">Razr+ (2024)</span>
            <span class="moto-pill">Razr+ (2023)</span>
            <span class="moto-pill">Razr (2023)</span>
            <span class="moto-pill">Razr (2022)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="moto-model-card">
          <div class="moto-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="moto-model-title">Moto G Series</h3>
          <p class="moto-model-description">Popular mid-range lineup. Screen and battery replacements are the most common Moto G repairs and parts are readily available for all current G series models.</p>
          <div class="moto-model-pills">
            <span class="moto-pill">Moto G Power 5G</span>
            <span class="moto-pill">Moto G Stylus 5G</span>
            <span class="moto-pill">Moto G 5G</span>
            <span class="moto-pill">Moto G Power</span>
            <span class="moto-pill">Moto G Stylus</span>
            <span class="moto-pill">Moto G Play</span>
            <span class="moto-pill">Moto G Pure</span>
            <span class="moto-pill">Moto G Fast</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="moto-model-card">
          <div class="moto-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="moto-model-title">Moto E & ThinkPhone</h3>
          <p class="moto-model-description">Budget devices and business-focused phones. Moto E repairs are straightforward — screen and battery are the most common. ThinkPhone repairs require enterprise-grade parts sourcing.</p>
          <div class="moto-model-pills">
            <span class="moto-pill">Moto E</span>
            <span class="moto-pill">Moto E Power</span>
            <span class="moto-pill">ThinkPhone by Motorola</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="moto-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="moto-why-section" id="why-choose-us">
    <div class="moto-container">
      <div class="moto-section-header">
        <h2 class="moto-section-title">The Mobile Tech Lab Advantage: Winnipeg's Motorola Repair Experts</h2>
        <p class="moto-section-subtitle">Why Winnipeg customers trust us with their Motorola phones</p>
