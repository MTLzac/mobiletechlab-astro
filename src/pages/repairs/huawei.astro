---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Huawei Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Expert Huawei repair in Winnipeg. Screen, battery, SuperCharge port and Leica camera repair for P series, Mate, Nova & Honor. Hard-to-find parts specialists.";
const canonical = "https://mobiletechlab.ca/repairs/huawei";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Huawei Repair", "item": "https://mobiletechlab.ca/repairs/huawei" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Huawei Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repairs/huawei",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Huawei Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SuperCharge Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Leica Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Motherboard Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fingerprint Sensor Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Do you repair Huawei phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we're one of the few repair shops in Winnipeg that specializes in Huawei devices including P series, Mate, Nova, and all Honor models. Most shops turn Huawei repairs away due to parts sourcing challenges — we've built dedicated supplier relationships specifically to service these devices." } },
    { "@type": "Question", "name": "Are Huawei parts available in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "We maintain specialist supplier relationships for Huawei and Honor parts that most Canadian shops cannot source. Most common parts are available within 2–3 business days — contact us with your specific model to confirm availability before visiting." } },
    { "@type": "Question", "name": "How long does Huawei screen repair take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Huawei screen replacements are completed same-day in 1–2 hours once parts are in stock at our Winnipeg location. If your model requires a special order, we'll give you an estimated wait time when you contact us for a quote." } },
    { "@type": "Question", "name": "Do you repair Honor phones in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all Honor devices including the Magic series, Honor 50, Honor 70, and all legacy Honor models. Honor shares many components with Huawei and our supplier relationships cover both brands." } },
    { "@type": "Question", "name": "Can you repair Huawei phones without Google services?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all Huawei hardware regardless of whether the device runs Google Mobile Services or Huawei Mobile Services. Our repairs are hardware-only and do not affect the software or app ecosystem on your device." } },
    { "@type": "Question", "name": "Can you fix Huawei SuperCharge not working?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — SuperCharge failures are a common Huawei issue we diagnose and repair regularly. We test the full charging chain including the USB-C port, charging IC, and battery to identify the specific fault before recommending any repair." } },
    { "@type": "Question", "name": "Do you repair Huawei Leica camera issues?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair front and rear camera modules on all Huawei P series and Mate series devices including the Leica-engineered multi-lens systems. Camera repairs include blurry images, black screen, autofocus failures, and cracked lens glass." } },
    { "@type": "Question", "name": "Can you fix a Huawei phone that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive Huawei is often caused by a depleted battery, a software boot loop, or a component-level board fault. We run free diagnostics to identify the root cause before recommending any repair so you know what the issue is before spending anything." } },
    { "@type": "Question", "name": "Do you repair Huawei in-display fingerprint sensors?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair and recalibrate in-display optical fingerprint sensors on Huawei P and Mate series flagships, as well as rear fingerprint sensors on Nova and entry-level models. Fingerprint sensor issues are often caused by screen replacement with incompatible parts — we use model-matched components to avoid this." } },
    { "@type": "Question", "name": "Do you repair Huawei phones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts Huawei repairs Monday through Saturday 10AM–6PM. For less common Huawei models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="hw-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="hw-container">
      <ol class="hw-breadcrumb-list">
        <li><a href="/" class="hw-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="hw-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="hw-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="hw-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="hw-breadcrumb-current" aria-current="page">Huawei Repair</li>
      </ol>
    </div>
  </nav>

  <section class="hw-hero-section" id="hero">
    <div class="hw-hero-inner">
      <div class="hw-hero-content">
        <div class="hw-hero-badge-row">
          <span class="hw-service-badge">Huawei & Honor Repair Specialists</span>
          <span class="hw-location-badge">
            <span class="hw-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="hw-location-badge">
            <span class="hw-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="hw-hero-headline">
          Huawei Repair <span class="hw-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="hw-hero-subheadline">Huawei P Series, Mate, Nova & Honor Repair Specialists in Winnipeg</p>

        <div class="hw-hero-body">
          <p>Cracked Huawei screen or battery not lasting the day? We repair all Huawei models at our Winnipeg shop — from the P30 through P60 Pro, Mate series, Nova lineup, and all Honor devices. Common repairs include screen replacements, battery swaps, SuperCharge port fixes, Leica camera repairs, motherboard diagnostics, and fingerprint sensor issues.</p>
          <p>Parts availability is the biggest challenge with Huawei repairs in Canada — most shops turn them away because they can't source components. We maintain specialist supplier relationships specifically for Huawei and Honor parts so we can service devices that others won't touch. We'll always confirm parts availability and give you a quote before starting any repair.</p>
        </div>

        <div class="hw-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="hw-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="hw-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="hw-hero-image-wrapper">
        <img
          src="/assets/image.png"
          alt="Huawei phone repair in Winnipeg — P series, Mate and Nova specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="hw-annotations-list" aria-label="Common Huawei issues we fix">
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            SuperCharge port issues
          </li>
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Leica camera not working
          </li>
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
          <li class="hw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Fingerprint sensor issues
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="hw-services-section" id="services">
    <div class="hw-container">
      <div class="hw-section-header">
        <h2 class="hw-section-title">Huawei Repair Services in Winnipeg</h2>
        <p class="hw-section-subtitle">Specialist repairs for all Huawei and Honor models. Hard-to-find parts sourced, warranty included.</p>
      </div>
      <div class="hw-services-grid">
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="hw-service-title">Screen Replacement</h3>
          <p class="hw-service-body">Cracked or unresponsive Huawei display? We replace OLED and LCD screens on all P series, Mate, Nova, and Honor devices. Huawei flagship displays use high-quality curved OLED panels that require model-specific parts — we source them through specialist suppliers when standard channels don't carry them.</p>
        </div>
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="hw-service-title">Battery Replacement</h3>
          <p class="hw-service-body">Huawei not lasting all day? We replace degraded batteries with quality cells and same-day turnaround on most models. Huawei batteries are tightly integrated into the device chassis — we disassemble carefully to avoid display or motherboard damage during the swap.</p>
        </div>
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="hw-service-title">SuperCharge Port Repair</h3>
          <p class="hw-service-body">Huawei SuperCharge not working or charging intermittently? We diagnose and repair USB-C charging ports and SuperCharge fast-charging systems across all Huawei and Honor models. We clean the port before replacing it — debris is a common cause of charging failures.</p>
        </div>
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="hw-service-title">Leica Camera Repair</h3>
          <p class="hw-service-body">Blurry photos, black camera screen, or cracked Leica lens on your Huawei P or Mate series? We repair the front and rear camera modules on all Huawei flagships including the Leica-engineered multi-lens systems on P40, P50, P60, and Mate series devices.</p>
        </div>
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
          </div>
          <h3 class="hw-service-title">Motherboard Repair</h3>
          <p class="hw-service-body">Component-level motherboard diagnostics and micro-soldering repair for Huawei devices. We diagnose power failures, no-boot conditions, and water damage at the board level — identifying and repairing the specific component rather than replacing the entire board.</p>
        </div>
        <div class="hw-service-card">
          <div class="hw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="hw-service-title">Fingerprint Sensor Repair</h3>
          <p class="hw-service-body">In-display or rear fingerprint sensor not working on your Huawei? We repair and recalibrate fingerprint sensors across all Huawei and Honor models — including the in-display optical sensors on flagship P and Mate series devices.</p>
        </div>
      </div>
      <div class="hw-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="hw-models-section" id="models">
    <div class="hw-container">
      <div class="hw-section-header">
        <h2 class="hw-section-title">All Huawei & Honor Models We Repair in Winnipeg</h2>
        <p class="hw-section-subtitle">P series, Mate, Nova, and all Honor devices — parts sourced when others can't</p>
      </div>
      <div class="hw-models-grid">
        <div class="hw-model-card">
          <div class="hw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="hw-model-title">Huawei P Series</h3>
          <p class="hw-model-description">Premium Huawei phones with Leica camera systems. Screen and battery repairs are the most common P series fixes — contact us to confirm parts availability for your specific model.</p>
          <div class="hw-model-pills">
            <span class="hw-pill">P60 Pro</span>
            <span class="hw-pill">P60 Art</span>
            <span class="hw-pill">P60</span>
            <span class="hw-pill">P50 Pro</span>
            <span class="hw-pill">P50 Pocket</span>
            <span class="hw-pill">P50</span>
            <span class="hw-pill">P40 Pro+</span>
            <span class="hw-pill">P40 Pro</span>
            <span class="hw-pill">P40</span>
            <span class="hw-pill">P30 Pro</span>
            <span class="hw-pill">P30</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="hw-model-card">
          <div class="hw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="hw-model-title">Huawei Mate Series</h3>
          <p class="hw-model-description">Flagship Mate lineup with large batteries and premium displays. Mate series repairs require specialist parts — we source them through dedicated Huawei supplier channels.</p>
          <div class="hw-model-pills">
            <span class="hw-pill">Mate 60 Pro</span>
            <span class="hw-pill">Mate 60</span>
            <span class="hw-pill">Mate 50 Pro</span>
            <span class="hw-pill">Mate 50</span>
            <span class="hw-pill">Mate 40 Pro</span>
            <span class="hw-pill">Mate 40</span>
            <span class="hw-pill">Mate 30 Pro</span>
            <span class="hw-pill">Mate 20 Pro</span>
            <span class="hw-pill">Mate 20 X</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="hw-model-card">
          <div class="hw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="hw-model-title">Huawei Nova Series</h3>
          <p class="hw-model-description">Mid-range Nova devices with strong camera systems. Nova repairs are generally more accessible than flagship models with better parts availability.</p>
          <div class="hw-model-pills">
            <span class="hw-pill">Nova 11 Pro</span>
            <span class="hw-pill">Nova 11</span>
            <span class="hw-pill">Nova 10 Pro</span>
            <span class="hw-pill">Nova 10</span>
            <span class="hw-pill">Nova 9</span>
            <span class="hw-pill">Nova 8</span>
            <span class="hw-pill">Nova 7</span>
            <span class="hw-pill">Nova 5T</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="hw-model-card">
          <div class="hw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="hw-model-title">Honor Devices</h3>
          <p class="hw-model-description">Honor was formerly a Huawei sub-brand and shares many components. We repair all Honor devices including Magic series, Honor 50, 70, and legacy models.</p>
          <div class="hw-model-pills">
            <span class="hw-pill">Honor Magic5 Pro</span>
            <span class="hw-pill">Honor Magic4 Pro</span>
            <span class="hw-pill">Honor 70</span>
            <span class="hw-pill">Honor 50</span>
            <span class="hw-pill">Honor 20 Pro</span>
            <span class="hw-pill">Honor 10</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="hw-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="hw-why-section" id="why-choose-us">
    <div class="hw-container">
      <div class="hw-section-header">
        <h2 class="hw-section-title">The Mobile Tech Lab Advantage: Winnipeg's Huawei Repair Experts</h2>
        <p class="hw-section-subtitle">Why Winnipeg customers bring their Huawei devices to us when other shops say no</p>
      </div>
      <div class="hw-pillars-grid">
        <div class="hw-pillar-card">
          <div class="hw-pillar-icon-wrapper">
