---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Apple Watch Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Expert Apple Watch repair in Winnipeg. Screen and battery replacement for all models including Series 10, Ultra 2, and SE. Fast same-day service at Mobile Tech Lab.";
const canonical = "https://mobiletechlab.ca/repairs/apple-watch";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Apple Watch Repair", "item": "https://mobiletechlab.ca/repairs/apple-watch" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Apple Watch Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Wearable Repair",
  "url": "https://mobiletechlab.ca/repairs/apple-watch",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Apple Watch Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Crown & Button Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Issues" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Damage Recovery" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Full Diagnostics" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does Apple Watch screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Apple Watch screen replacements at our Winnipeg shop take 1–2 hours. We stock screens for all current Series, SE, and Ultra models so same-day repair is available for walk-ins." } },
    { "@type": "Question", "name": "Is my Apple Watch still water resistant after a screen repair?", "acceptedAnswer": { "@type": "Answer", "text": "We reseal the display adhesive during every screen repair to restore the original water resistance rating. While we cannot guarantee the exact IP rating is fully restored, we take every precaution to maintain the seal quality." } },
    { "@type": "Question", "name": "How much does Apple Watch battery replacement cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Battery replacement costs vary by Apple Watch model and generation — older Series models are typically less expensive than newer ones. Contact our Winnipeg locations or use our online quote tool for an exact price on your specific model." } },
    { "@type": "Question", "name": "Do you repair Apple Watch Ultra and Ultra 2 in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair both Apple Watch Ultra and Ultra 2 at our Winnipeg St. Vital location. The larger 49mm case requires specialized tools that most general repair shops don't carry, but we have them in stock." } },
    { "@type": "Question", "name": "How do I know if my Apple Watch battery needs replacing?", "acceptedAnswer": { "@type": "Answer", "text": "Signs of a worn battery include rapid drain during normal use, unexpected shutdowns at 20–30% charge, the watch not lasting through a full day, or the watch running warm. You can check battery maximum capacity in the Watch app on your iPhone under My Watch > General > Usage > Battery Health." } },
    { "@type": "Question", "name": "Can you fix an Apple Watch that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a completely unresponsive Apple Watch is often caused by a fully depleted battery, a failed display connection, or a logic board fault. We run full diagnostics before recommending a repair so you know exactly what the issue is before spending anything." } },
    { "@type": "Question", "name": "Do you repair Apple Watch SE in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all three generations of Apple Watch SE including the 1st Gen, 2nd Gen, and 3rd Gen models. Screen and battery replacements are the most common SE repairs and are typically completed same-day." } },
    { "@type": "Question", "name": "Can you fix Apple Watch water damage in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "In many cases yes — even water resistant Apple Watches can suffer damage from salt water, pool chemicals, or older degraded seals. We perform component-level cleaning and diagnostics to assess what can be recovered." } },
    { "@type": "Question", "name": "Do you offer a warranty on Apple Watch repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — screen repairs carry a 30-day to lifetime warranty depending on the part tier selected. Battery replacements include a 90-day warranty. All other repairs carry a lifetime warranty on parts and labour." } },
    { "@type": "Question", "name": "Do I need an appointment for Apple Watch repair in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "No appointment is needed — both our St. Vital and Thompson locations accept walk-in Apple Watch repairs. Calling ahead is helpful to confirm we have your specific model's parts in stock, especially for newer Ultra 2 or Series 10 models." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumbs -->
  <nav class="aw-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="aw-container">
      <ol class="aw-breadcrumb-list">
        <li><a href="/" class="aw-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="aw-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="aw-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="aw-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="aw-breadcrumb-current" aria-current="page">Apple Watch Repair</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="aw-hero-section" id="hero">
    <div class="aw-hero-inner">
      <div class="aw-hero-content">
        <div class="aw-hero-badge-row">
          <span class="aw-service-badge">Professional Apple Watch Repair</span>
          <span class="aw-location-badge">
            <span class="aw-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="aw-location-badge">
            <span class="aw-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="aw-hero-headline">
          Apple Watch Repair <span class="aw-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="aw-hero-subheadline">Apple Watch Screen &amp; Battery Specialists in Winnipeg</p>

        <div class="aw-hero-body">
          <p>Cracked Apple Watch screen or battery draining fast? We repair all Apple Watch models at our Winnipeg shop — from Series 3 through Series 10, both SE generations, and the rugged Ultra and Ultra 2. Common repairs include screen replacements, battery swaps, crown and button issues, and charging port problems.</p>
          <p>Apple Watch screens require precision micro-tools and model-specific OLED panels — a repair most general electronics shops in Winnipeg cannot perform reliably. Our technicians work under magnification to ensure adhesive seals are restored and water resistance is maintained after every repair.</p>
        </div>

        <div class="aw-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="aw-cta-primary">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="tel:2045009757" class="aw-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="aw-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="aw-hero-image-wrapper">
        <img
          src="/assets/hero-apple-watch.png"
          alt="Apple Watch repair in Winnipeg — screen and battery replacement specialists"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="aw-annotations-list" aria-label="Common Apple Watch issues we fix">
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Cracked screen
          </li>
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
            Digital Crown issues
          </li>
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
            Won't charge
          </li>
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Water damage
          </li>
          <li class="aw-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Unresponsive display
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Repair Services -->
  <section class="aw-services-section" id="services">
    <div class="aw-container">
      <div class="aw-section-header">
        <h2 class="aw-section-title">Apple Watch Repair Services in Winnipeg</h2>
        <p class="aw-section-subtitle">Expert repairs for all Apple Watch models. Fast turnaround, quality parts, and warranty included.</p>
      </div>
      <div class="aw-services-grid">
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
          </div>
          <h3 class="aw-service-title">Screen Replacement</h3>
          <p class="aw-service-body">Cracked or unresponsive Apple Watch display? We replace OLED and LTPO AMOLED screens on all Apple Watch models — Series 3 through Series 10, SE, and Ultra. Each screen replacement includes precision resealing to maintain the original water resistance rating.</p>
        </div>
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="16" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>
          </div>
          <h3 class="aw-service-title">Battery Replacement</h3>
          <p class="aw-service-body">Apple Watch not lasting all day? We replace degraded batteries with quality cells and same-day turnaround on most models. We check battery health before and after replacement and provide a 90-day warranty on every battery swap.</p>
        </div>
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          </div>
          <h3 class="aw-service-title">Digital Crown &amp; Button Repair</h3>
          <p class="aw-service-body">Sticky or unresponsive Digital Crown, stuck side button, or haptic feedback issues. We clean and repair crown mechanisms and replace buttons on all Apple Watch models.</p>
        </div>
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22V11"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M5 5v3"/><path d="M19 5v3"/><path d="M5 8h14"/></svg>
          </div>
          <h3 class="aw-service-title">Charging Issues</h3>
          <p class="aw-service-body">Apple Watch not charging or showing intermittent charging? We diagnose charging pad contact issues, port corrosion, and battery faults. Most charging issues are resolved same-day.</p>
        </div>
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="aw-service-title">Water Damage Recovery</h3>
          <p class="aw-service-body">Despite water resistance ratings, Apple Watches can still suffer water damage from salt water, deep submersion, or older models with degraded seals. We perform full diagnostics and component-level cleaning.</p>
        </div>
        <div class="aw-service-card">
          <div class="aw-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="aw-service-title">Full Diagnostics</h3>
          <p class="aw-service-body">Not sure what's wrong with your Apple Watch? We run a full diagnostic before recommending any repair — so you only pay for what's actually needed.</p>
        </div>
      </div>
      <div class="aw-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="aw-cta-primary">
          Request Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Models -->
  <section class="aw-models-section" id="models">
    <div class="aw-container">
      <div class="aw-section-header">
        <h2 class="aw-section-title">All Apple Watch Models We Repair in Winnipeg</h2>
        <p class="aw-section-subtitle">From the original Series 3 to the latest Series 10 and Ultra 2</p>
      </div>
      <div class="aw-models-grid">
        <div class="aw-model-card">
          <div class="aw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="aw-model-title">Apple Watch Series</h3>
          <p class="aw-model-description">All standard Apple Watch Series models from Series 3 through Series 10. Screen and battery repairs available for every generation.</p>
          <div class="aw-model-pills">
            <span class="aw-pill">Series 10</span>
            <span class="aw-pill">Series 9</span>
            <span class="aw-pill">Series 8</span>
            <span class="aw-pill">Series 7</span>
            <span class="aw-pill">Series 6</span>
            <span class="aw-pill">Series 5</span>
            <span class="aw-pill">Series 4</span>
            <span class="aw-pill">Series 3</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="aw-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="aw-model-card">
          <div class="aw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="aw-model-title">Apple Watch SE</h3>
          <p class="aw-model-description">Budget-friendly Apple Watch repairs for all SE generations. Same quality parts and warranty as Series repairs.</p>
          <div class="aw-model-pills">
            <span class="aw-pill">SE (3rd Gen)</span>
            <span class="aw-pill">SE (2nd Gen)</span>
            <span class="aw-pill">SE (1st Gen)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="aw-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="aw-model-card">
          <div class="aw-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="aw-model-title">Apple Watch Ultra</h3>
          <p class="aw-model-description">Precision repairs for the rugged Ultra and Ultra 2. The larger 49mm case requires specialized tools — we have them.</p>
          <div class="aw-model-pills">
            <span class="aw-pill">Ultra 2</span>
            <span class="aw-pill">Ultra</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="aw-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="aw-why-section" id="why-choose-us">
    <div class="aw-container">
      <div class="aw-section-header">
        <h2 class="aw-section-title">The Mobile Tech Lab Advantage: Winnipeg's Apple Watch Repair Experts</h2>
        <p class="aw-section-subtitle">Why Winnipeg customers trust us with their Apple Watch</p>
      </div>
      <div class="aw-pillars-grid">
        <div class="aw-pillar-card">
          <div class="aw-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="aw-pillar-title">Apple Watch Specialists</h3>
          <p class="aw-pillar-body">Apple Watch repairs require model-specific OLED panels, micro-tools, and precision resealing — skills most general repair shops don't have. Our Winnipeg technicians are trained on every Apple Watch generation from Series 3 to Ultra 2.</p>
        </div>
        <div class="aw-pillar-card">
          <div class="aw-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="aw-pillar-title">Fast Turnaround — Often Same Day</h3>
          <p class="aw-pillar-body">Many Apple Watch repairs are completed the same day when parts are in stock. For less common models, we typically need 24 hours to source the right parts. Call ahead and we'll confirm availability before you come in — no waiting weeks, no mailing your watch away.</p>
        </div>
        <div class="aw-pillar-card">
          <div class="aw-pillar-icon-wrapper">
