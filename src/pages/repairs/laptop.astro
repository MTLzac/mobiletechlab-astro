  <section class="lp-why-section" id="why-choose-us">
    <div class="lp-container">
      <div class="lp-section-header">
        <h2 class="lp-section-heading">The Mobile Tech Lab Advantage: Winnipeg's Laptop Repair Experts</h2>
        <p class="lp-section-subheading">Why Winnipeg brings us laptops that other shops can't fix</p>
      </div>

      <div class="lp-why-grid">
        <div class="lp-why-card">
          <div class="lp-why-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
