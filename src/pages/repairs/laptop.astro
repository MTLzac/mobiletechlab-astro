---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Laptop Repair Winnipeg | All Brands | Mobile Tech Lab";
const description = "Expert laptop repair in Winnipeg. Screen, battery, keyboard, charging port, SSD upgrades for Asus, Acer, Lenovo, HP, Dell, Chromebook & all brands. Same-day available.";
const canonical = "https://mobiletechlab.ca/repairs/laptop";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Laptop Repair", "item": "https://mobiletechlab.ca/repairs/laptop" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Laptop Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Laptop Repair",
  "url": "https://mobiletechlab.ca/repairs/laptop",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Laptop Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Keyboard Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Overheating and Fan Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SSD and RAM Upgrades" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hinge Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Motherboard Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does a laptop screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most laptop screen replacements are completed within 1–2 hours at our Winnipeg St. Vital location when parts are in stock. For less common laptop models or premium display panels, we may need to order a part — we'll give you an estimated wait time when you contact us." } },
    { "@type": "Question", "name": "Can you upgrade my laptop's RAM and SSD in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we perform SSD and RAM upgrades on most laptops at our Winnipeg location. An SSD upgrade is the single most impactful performance improvement you can make on an older laptop — replacing a spinning hard drive with an NVMe SSD can make a years-old machine boot in seconds and feel completely new again." } },
    { "@type": "Question", "name": "My laptop won't turn on. Can you fix it in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we diagnose and repair laptop power failures ranging from simple battery or charger problems through to complex motherboard-level faults. We perform component-level diagnostics and micro-soldering for charging IC failures, power delivery faults, and display connection issues that most Winnipeg laptop shops won't attempt." } },
    { "@type": "Question", "name": "Do you repair Chromebooks in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we service all Chromebook brands including Asus, Acer, Lenovo, HP, Dell, and Google Pixelbook at our Winnipeg location. Chromebook screen replacements and keyboard repairs are the most common Chromebook fixes we perform." } },
    { "@type": "Question", "name": "Is it worth repairing my old laptop?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the repair cost versus the laptop's current value and remaining useful life — a battery replacement or SSD upgrade on a well-built 5-year-old laptop almost always makes sense, while a motherboard repair on a budget 7-year-old machine may not. We provide a free diagnostic and honest assessment at our Winnipeg location before you commit to anything." } },
    { "@type": "Question", "name": "Do you repair gaming laptops in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair Asus ROG, Acer Nitro and Predator, Lenovo Legion, HP Omen, Dell Alienware, Razer Blade, and MSI gaming laptops at our Winnipeg shop. Gaming laptops frequently need thermal paste replacement and heatsink cleaning due to the high sustained loads they run under — overheating is by far the most common gaming laptop repair we perform." } },
    { "@type": "Question", "name": "Can you fix a laptop with a broken or loose hinge?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — hinge repairs are a common laptop fix we perform at our Winnipeg location. Loose or broken hinges often cause the screen to wobble or crack the plastic chassis around the hinge mounting points. We repair hinges and reinforce or replace the chassis damage they cause on all laptop brands." } },
    { "@type": "Question", "name": "Do you repair laptop charging ports in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair both DC barrel jack charging ports on older laptops and USB-C charging ports on modern thin-and-light models at our Winnipeg shop. Most charging port repairs are completed same-day and we always test the full charging chain before recommending a port replacement." } },
    { "@type": "Question", "name": "Do you offer free laptop diagnostics in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we provide free diagnostics on all laptops at our Winnipeg St. Vital location. Walk in any time during business hours and we'll assess your laptop and give you a clear upfront quote before starting any repair — no obligation and no fee for the diagnostic itself." } },
    { "@type": "Question", "name": "Do you repair laptops in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts laptop repairs Monday through Saturday 10AM–6PM. For screen replacements or less common brands, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="lp-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="lp-container">
      <ol class="lp-breadcrumb-list">
        <li><a href="/" class="lp-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="lp-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="lp-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="lp-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="lp-breadcrumb-current" aria-current="page">Laptop Repair</li>
      </ol>
    </div>
  </nav>

  <section class="lp-hero-section" id="hero">
    <div class="lp-hero-inner">
      <div class="lp-hero-content">
        <div class="lp-hero-badge-row">
          <span class="lp-service-badge">All Laptop Brands Serviced in Winnipeg</span>
          <span class="lp-location-badge">
            <span class="lp-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="lp-location-badge">
            <span class="lp-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="lp-hero-headline">
          Laptop Repair <span class="lp-highlight">Winnipeg</span> &amp; Manitoba
        </h1>

        <p class="lp-hero-subhead">Asus, Acer, Lenovo, HP, Dell, Chromebook &amp; All Brands — Same-Day Service Available</p>

        <div class="lp-hero-body">
          <p>Cracked laptop screen, dead battery, overheating, or keyboard not working? We repair all Windows laptops and Chromebooks at our Winnipeg shop — Asus, Acer, Lenovo, HP, Dell, Toshiba, MSI, Razer, Samsung Galaxy Book, LG Gram, Huawei MateBook, and every Chromebook brand. Common repairs include screen replacements, battery swaps, keyboard replacements, charging port fixes, overheating cleans, hinge repairs, and SSD and RAM upgrades. We also repair <a href="/repairs/macbook">MacBooks</a> and <a href="/repair/surface">Microsoft Surface</a> devices.</p>
          <p>Not sure what's wrong? Walk in for a free diagnostic and we'll give you a clear assessment and upfront quote before starting any work. Most screen and battery repairs are completed same-day. We perform component-level motherboard diagnostics and micro-soldering for laptops that won't turn on — repairs that most Winnipeg laptop shops send out or refuse entirely.</p>
        </div>

        <div class="lp-hero-cta-row">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lp-btn-primary">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="tel:2045009757" class="lp-btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>

        <p class="lp-pricing-note">
          Not sure what affects the cost? <a href="/repair-pricing" class="lp-pricing-link">How repair pricing works</a>
        </p>
      </div>

      <div class="lp-hero-image-wrap">
        <img
          src="/assets/hero-laptop.png"
          alt="Laptop repair in Winnipeg — all brands including Asus, Acer, Lenovo, HP, Dell and Chromebook at Mobile Tech Lab"
          width="520"
          height="400"
          loading="eager"
          class="lp-hero-image"
        />
        <div class="lp-hero-annotations">
          <span class="lp-annotation lp-annotation-1">Cracked screen</span>
          <span class="lp-annotation lp-annotation-2">Battery won't hold charge</span>
          <span class="lp-annotation lp-annotation-3">Keyboard not working</span>
          <span class="lp-annotation lp-annotation-4">Won't turn on</span>
          <span class="lp-annotation lp-annotation-5">Overheating</span>
          <span class="lp-annotation lp-annotation-6">Hinge broken</span>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-services-section" id="services">
    <div class="lp-container">
      <div class="lp-section-header">
        <h2 class="lp-section-heading">Laptop Repair Services in Winnipeg</h2>
        <p class="lp-section-subheading">Every repair your laptop needs — all brands, all models, free diagnostics, warranty included.</p>
      </div>

      <div class="lp-services-grid">
        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lp-service-title">Screen Replacement &amp; Hinge Repair</h3>
          <p class="lp-service-body">Cracked, flickering, or dead laptop screen? We replace LCD and LED displays on all laptop brands and sizes — from budget 15-inch Acer Aspire screens through premium Dell XPS OLED panels. We also repair broken and loose hinges that prevent the screen from staying open or closed properly, and reinforce hinge mounting points that have cracked the chassis. Most screen replacements are completed within 1–2 hours when parts are in stock.</p>
        </div>

        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="lp-service-title">Battery Replacement</h3>
          <p class="lp-service-body">Laptop dying after 30 minutes or not charging at all? We replace batteries on all laptop brands with quality cells that restore original runtime. Battery replacement is one of the most cost-effective ways to extend the life of a laptop that still has years of use left in it. All battery replacements include a 90-day warranty.</p>
        </div>

        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M7 16h10"/></svg>
          </div>
          <h3 class="lp-service-title">Keyboard Replacement</h3>
          <p class="lp-service-body">Broken keys, keys not registering, or liquid damage to the keyboard? We replace full keyboard assemblies on all laptop brands. We also diagnose and address trackpad issues, palm rest damage, and USB port failures that often occur alongside keyboard damage from liquid spills. Most keyboard replacements are completed within 1–2 business days.</p>
        </div>

        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="lp-service-title">Charging Port &amp; Power Repair</h3>
          <p class="lp-service-body">Laptop not charging, power brick getting hot, or USB-C not working? We diagnose and repair DC barrel jacks on older laptops and USB-C charging ports on modern thin-and-light models. We test the full charging chain — adapter, cable, port, and charging IC — before recommending any replacement to avoid unnecessary repairs.</p>
        </div>

        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44l-2.1-8.4A4 4 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44l2.1-8.4A4 4 0 0 0 14.5 2Z"/></svg>
          </div>
          <h3 class="lp-service-title">Overheating &amp; Fan Repair</h3>
          <p class="lp-service-body">Laptop shutting down mid-use, fan running at full speed constantly, or chassis hot to the touch? Overheating is almost always caused by dust-clogged heatsink fins and degraded thermal paste. We fully disassemble the cooling system, deep clean the heatsink and fan, and apply fresh high-performance thermal paste. Gaming laptops from Asus ROG, Acer Nitro, Lenovo Legion, HP Omen, and Dell Alienware are especially prone to thermal degradation.</p>
        </div>

        <div class="lp-service-card">
          <div class="lp-service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M22 10H2"/></svg>
          </div>
          <h3 class="lp-service-title">SSD, RAM Upgrades &amp; Motherboard Repair</h3>
          <p class="lp-service-body">Slow laptop? An SSD upgrade is the single most impactful performance improvement you can make — replacing a spinning hard drive with an NVMe SSD can make a 5-year-old laptop feel new again. We also perform RAM upgrades on laptops with upgradeable memory. For laptops that won't turn on at all, we perform component-level motherboard diagnostics and micro-soldering to identify and repair power delivery failures, broken charging IC chips, and display connector issues.</p>
        </div>
      </div>

      <div class="lp-services-cta-wrap">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lp-btn-primary">
          Request Repair
          <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="lp-models-section" id="models">
    <div class="lp-container">
      <div class="lp-section-header">
        <h2 class="lp-section-heading">All Laptop Brands We Repair in Winnipeg</h2>
        <p class="lp-section-subheading">Every Windows laptop and Chromebook brand — if it has a screen and a keyboard, we service it</p>
      </div>

      <div class="lp-models-grid">
        <div class="lp-model-card">
          <div class="lp-model-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-model-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lp-model-title">Asus &amp; Acer</h3>
          <p class="lp-model-desc">Gaming, ultrabook, and budget laptop repairs. Asus ROG and Acer Nitro gaming laptops are especially common for overheating and screen repairs. All Chromebook models from both brands also serviced.</p>
          <div class="lp-model-pills">
            <span class="lp-pill">ROG Zephyrus</span>
            <span class="lp-pill">ROG Strix</span>
            <span class="lp-pill">TUF Gaming</span>
            <span class="lp-pill">ZenBook</span>
            <span class="lp-pill">VivoBook</span>
            <span class="lp-pill">Acer Aspire</span>
            <span class="lp-pill">Acer Swift</span>
            <span class="lp-pill">Acer Nitro 5</span>
            <span class="lp-pill">Predator Helios</span>
            <span class="lp-pill">Chromebook</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lp-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="lp-model-card">
          <div class="lp-model-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-model-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lp-model-title">Lenovo &amp; HP</h3>
          <p class="lp-model-desc">Business, consumer, and gaming laptops. ThinkPad keyboard and screen repairs are among our most common Lenovo repairs. HP Spectre and Envy hinge repairs are frequently needed on premium thin-and-light models.</p>
          <div class="lp-model-pills">
            <span class="lp-pill">ThinkPad X1</span>
            <span class="lp-pill">ThinkPad T Series</span>
            <span class="lp-pill">IdeaPad</span>
            <span class="lp-pill">Lenovo Legion</span>
            <span class="lp-pill">Yoga</span>
            <span class="lp-pill">HP Spectre x360</span>
            <span class="lp-pill">HP Envy</span>
            <span class="lp-pill">HP Pavilion</span>
            <span class="lp-pill">HP EliteBook</span>
            <span class="lp-pill">HP Omen</span>
            <span class="lp-pill">Chromebook Duet</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lp-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="lp-model-card">
          <div class="lp-model-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-model-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lp-model-title">Dell</h3>
          <p class="lp-model-desc">Consumer, business, and workstation laptops. Dell XPS hinges and screens are common repairs. Alienware gaming laptops frequently need thermal paste replacement and overheating fixes.</p>
          <div class="lp-model-pills">
            <span class="lp-pill">Dell XPS 13</span>
            <span class="lp-pill">Dell XPS 15</span>
            <span class="lp-pill">Dell XPS 17</span>
            <span class="lp-pill">Dell Inspiron</span>
            <span class="lp-pill">Dell Latitude</span>
            <span class="lp-pill">Dell Precision</span>
            <span class="lp-pill">Alienware</span>
            <span class="lp-pill">Dell Chromebook</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="lp-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-btn-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="lp-model-card">
          <div class="lp-model-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="lp-model-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lp-model-title">Other Brands</h3>
          <p class="lp-model-desc">We service virtually every Windows laptop and Chromebook brand. If your laptop brand isn't listed, contact us — if it runs Windows or ChromeOS, we almost certainly repair it.</p>
          <div class="lp-model-pills">
            <span class="lp-pill">Toshiba / Dynabook</span>
            <span class="lp-pill">MSI</span>
            <span class="lp-pill">Razer Blade</span>
            <span class="lp-pill">Samsung Galaxy Book</span>
            <span class="lp-pill">LG Gram</span>
            <span class="lp-pill">Huawei MateBook</span>
            <span class="lp-pill">Google Pixelbook</span>
