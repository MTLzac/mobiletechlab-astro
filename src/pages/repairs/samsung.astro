---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Samsung Repair Winnipeg | Galaxy Screen & Battery Fix";
const description = "Expert Samsung Galaxy repair in Winnipeg. Screen, battery, charging port, water damage for Galaxy S, Z Fold, Z Flip, A series & Note. Same-day service at Mobile Tech Lab.";
const canonical = "https://mobiletechlab.ca/repairs/samsung";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Samsung Repair", "item": "https://mobiletechlab.ca/repairs/samsung" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Samsung Galaxy Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repairs/samsung",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Samsung Galaxy Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Damage Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Speaker and Microphone Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does Samsung Galaxy screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Samsung Galaxy screen replacements are completed in 1-2 hours at our Winnipeg St. Vital location. Galaxy Z Fold and Z Flip foldable devices may take 2-4 hours due to their complex inner display and hinge assemblies." } },
    { "@type": "Question", "name": "Do you repair Samsung Galaxy Z Fold and Z Flip in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes - we're one of the few Winnipeg repair shops with genuine experience servicing Samsung Z Fold and Z Flip foldables including inner screen, outer screen, hinge mechanism, and flex cable repairs. Contact us before visiting to confirm parts availability for your specific model and generation." } },
    { "@type": "Question", "name": "How much does Samsung Galaxy repair cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Samsung repair costs vary significantly by model - Galaxy A series repairs are generally the most straightforward, while flagship S series and foldable Z series cost more due to premium AMOLED and foldable display components. Contact us or use our online quote tool for a free upfront price on your specific model." } },
    { "@type": "Question", "name": "Do you use genuine Samsung parts for repairs?", "acceptedAnswer": { "@type": "Answer", "text": "We use high-quality parts that meet or exceed OEM specifications, and OEM Samsung displays are available for models where aftermarket screens cannot be reliably warrantied. We discuss part options and pricing with you before starting any repair so you can choose the level that fits your budget." } },
    { "@type": "Question", "name": "Will I lose my data during Samsung Galaxy repair?", "acceptedAnswer": { "@type": "Answer", "text": "For most repairs including screen, battery, and charging port, your data remains completely intact. We recommend backing up your Galaxy before any repair as a precaution - for water damage cases, data recovery is prioritised and we document the device state on arrival." } },
    { "@type": "Question", "name": "Do you repair Samsung Galaxy water damage in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes - despite IP ratings, Samsung Galaxy phones can still suffer liquid damage from salt water, pool chemicals, or older models with degraded seals. We perform ultrasonic cleaning and component-level diagnostics to assess what can be recovered - bring it in as soon as possible for the best outcome." } },
    { "@type": "Question", "name": "Do you repair Samsung Galaxy cameras in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes - we repair all Galaxy camera modules including the 200MP main sensor on Galaxy S24 Ultra, periscope telephoto lenses on Pro models, and front selfie cameras across all Galaxy generations. Camera repairs restore full resolution, optical zoom, and video recording quality." } },
    { "@type": "Question", "name": "Can you fix a Samsung Galaxy that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes - a non-responsive Galaxy is often caused by a depleted battery, a failed display connection, or a software boot issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the problem is before spending anything." } },
    { "@type": "Question", "name": "Do I need an appointment for Samsung repair in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "No appointment is needed - walk-ins are welcome at both our St. Vital and Thompson locations during business hours. Calling ahead is helpful for Z Fold or Z Flip repairs so we can confirm parts availability and give you an accurate time estimate before your visit." } },
    { "@type": "Question", "name": "Do you repair Samsung Galaxy phones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes - our Thompson location at 300 Mystery Lake Rd #1530 accepts Samsung Galaxy repairs Monday through Saturday 10AM-6PM. We stock parts for common Galaxy A and S series models - calling ahead helps confirm availability for Z Fold, Z Flip, or newer flagship models." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="samsung-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="samsung-container">
      <ol class="samsung-breadcrumb-list">
        <li><a href="/" class="samsung-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="samsung-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="samsung-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="samsung-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="samsung-breadcrumb-current" aria-current="page">Samsung Repair</li>
      </ol>
    </div>
  </nav>

  <section class="samsung-hero-section" id="hero">
    <div class="samsung-hero-inner">
      <div class="samsung-hero-content">
        <div class="samsung-hero-badge-row">
          <span class="samsung-service-badge">Samsung Galaxy Repair Specialists</span>
          <span class="samsung-location-badge">
            <span class="samsung-badge-dot"></span>
            St. Vital - Open
          </span>
          <span class="samsung-location-badge">
            <span class="samsung-badge-dot"></span>
            Thompson - Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="samsung-hero-headline">
          Samsung Repair <span class="samsung-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="samsung-hero-subheadline">Galaxy S, Z Fold, Z Flip, A Series & Note Repair Specialists in Winnipeg</p>

        <div class="samsung-hero-body">
          <p>Cracked Galaxy screen, dead battery, or water damage? We repair all Samsung Galaxy models at our Winnipeg shop - from the Galaxy A series through Galaxy S24 Ultra, Z Fold 6, and Z Flip 6. Common repairs include AMOLED screen replacements, battery swaps, USB-C charging port fixes, water damage restoration, camera repairs, and speaker issues.</p>
          <p>Samsung Galaxy Z Fold and Z Flip foldables are among the most technically demanding repairs available - the inner foldable display, hinge mechanism, and ultra-thin flex cables require specialist parts and techniques. We're one of the few Winnipeg repair shops with genuine experience servicing both Z Fold and Z Flip generations. Every repair is backed by our warranty and delivered with an honest upfront quote.</p>
        </div>

        <div class="samsung-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-cta-primary">
            Get a Free Quote
          </a>
          <a href="tel:2045009757" class="samsung-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="samsung-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="samsung-hero-image-wrapper">
        <img
          src="/assets/hero-samsung.png"
          alt="Samsung Galaxy repair in Winnipeg - Galaxy S, Z Fold, Z Flip and A series specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="samsung-annotations-list" aria-label="Common Samsung Galaxy issues we fix">
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Charging port issues
          </li>
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            Water damage
          </li>
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Camera not working
          </li>
          <li class="samsung-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="samsung-services-section" id="services">
    <div class="samsung-container">
      <div class="samsung-section-header">
        <h2 class="samsung-section-title">Samsung Galaxy Repair Services in Winnipeg</h2>
        <p class="samsung-section-subtitle">Expert repairs for all Galaxy models including foldables. Quality parts, fast turnaround, warranty included.</p>
      </div>
      <div class="samsung-services-grid">
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="samsung-service-title">Screen Replacement</h3>
          <p class="samsung-service-body">Cracked or unresponsive Samsung Galaxy display? We replace AMOLED screens on all Galaxy S, A, and Note models, and the complex inner and outer foldable displays on Z Fold and Z Flip. For many Samsung flagships, OEM Samsung displays are used to maintain the original colour accuracy, brightness, and touch sensitivity. We discuss part options and pricing with you before starting any repair.</p>
        </div>
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="samsung-service-title">Battery Replacement</h3>
          <p class="samsung-service-body">Samsung Galaxy battery draining too fast or not lasting the day? We replace batteries on all Galaxy models with quality cells and same-day turnaround where parts are in stock. Galaxy batteries typically degrade noticeably after 2-3 years - a replacement can restore full-day battery life. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="samsung-service-title">Charging Port Repair</h3>
          <p class="samsung-service-body">Samsung Galaxy not charging or connecting intermittently? We repair USB-C ports on all Galaxy models - including cleaning, testing, and component replacement if needed. We clean the port first before recommending replacement since lint and debris are common causes of Galaxy charging failures. Most charging port repairs are completed same-day.</p>
        </div>
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          </div>
          <h3 class="samsung-service-title">Water Damage Repair</h3>
          <p class="samsung-service-body">Dropped your Galaxy in water? Despite IP ratings, Samsung phones can still suffer liquid damage. We perform ultrasonic cleaning and component-level diagnostics to assess what can be recovered - giving your Galaxy the best chance of survival. Bring it in as soon as possible for the best outcome.</p>
        </div>
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="samsung-service-title">Camera Repair</h3>
          <p class="samsung-service-body">Blurry photos, black camera screen, or cracked camera lens on your Galaxy? We repair front selfie cameras and all rear camera modules across the Galaxy lineup - including the 200MP main sensor on Galaxy S24 Ultra and the periscope telephoto on Pro models. Camera repairs restore full resolution, optical zoom, and video quality.</p>
        </div>
        <div class="samsung-service-card">
          <div class="samsung-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
          <h3 class="samsung-service-title">Speaker & Mic Repair</h3>
          <p class="samsung-service-body">Can't hear calls or be heard on your Galaxy? We repair speakers, earpieces, and microphones across all Samsung Galaxy models. Speaker failures are often caused by water ingress or physical damage - we diagnose the specific fault before recommending any replacement. Most speaker repairs are completed same-day.</p>
        </div>
      </div>
      <div class="samsung-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-cta-primary">
          Request Repair
        </a>
      </div>
    </div>
  </section>

  <section class="samsung-models-section" id="models">
    <div class="samsung-container">
      <div class="samsung-section-header">
        <h2 class="samsung-section-title">All Samsung Galaxy Models We Repair in Winnipeg</h2>
        <p class="samsung-section-subtitle">Galaxy S, Z Fold, Z Flip, A series, and Note - every Samsung model serviced</p>
      </div>
      <div class="samsung-models-grid">
        <div class="samsung-model-card">
          <div class="samsung-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="samsung-model-title">Galaxy S Series</h3>
          <p class="samsung-model-description">Samsung's flagship AMOLED phones. S24 Ultra features a 200MP sensor and titanium frame - repairs require OEM-matched parts to maintain full camera and display performance.</p>
          <div class="samsung-model-pills">
            <span class="samsung-pill">Galaxy S24 Ultra</span>
            <span class="samsung-pill">Galaxy S24+</span>
            <span class="samsung-pill">Galaxy S24</span>
            <span class="samsung-pill">Galaxy S23 Ultra</span>
            <span class="samsung-pill">Galaxy S23+</span>
            <span class="samsung-pill">Galaxy S23</span>
            <span class="samsung-pill">Galaxy S22 Ultra</span>
            <span class="samsung-pill">Galaxy S22+</span>
            <span class="samsung-pill">Galaxy S22</span>
            <span class="samsung-pill">Galaxy S21 Ultra</span>
            <span class="samsung-pill">Galaxy S21+</span>
            <span class="samsung-pill">Galaxy S21</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-model-cta">
            Get Quote
          </a>
        </div>
        <div class="samsung-model-card">
          <div class="samsung-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="samsung-model-title">Galaxy Z Fold & Z Flip</h3>
          <p class="samsung-model-description">Foldable phone repairs including inner screen, outer screen, and hinge mechanism. Among the most complex repairs available - contact us before visiting to confirm parts and get an accurate quote.</p>
          <div class="samsung-model-pills">
            <span class="samsung-pill">Galaxy Z Fold 6</span>
            <span class="samsung-pill">Galaxy Z Fold 5</span>
            <span class="samsung-pill">Galaxy Z Fold 4</span>
            <span class="samsung-pill">Galaxy Z Fold 3</span>
            <span class="samsung-pill">Galaxy Z Flip 6</span>
            <span class="samsung-pill">Galaxy Z Flip 5</span>
            <span class="samsung-pill">Galaxy Z Flip 4</span>
            <span class="samsung-pill">Galaxy Z Flip 3</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-model-cta">
            Get Quote
          </a>
        </div>
        <div class="samsung-model-card">
          <div class="samsung-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="samsung-model-title">Galaxy A Series</h3>
          <p class="samsung-model-description">Popular mid-range Samsung lineup. Screen and battery repairs are the most common A series fixes - parts are readily available for all current A series generations with same-day turnaround.</p>
          <div class="samsung-model-pills">
            <span class="samsung-pill">Galaxy A54</span>
            <span class="samsung-pill">Galaxy A53</span>
            <span class="samsung-pill">Galaxy A52</span>
            <span class="samsung-pill">Galaxy A51</span>
            <span class="samsung-pill">Galaxy A34</span>
            <span class="samsung-pill">Galaxy A33</span>
            <span class="samsung-pill">Galaxy A32</span>
            <span class="samsung-pill">Galaxy A14</span>
            <span class="samsung-pill">Galaxy A13</span>
            <span class="samsung-pill">Galaxy A12</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-model-cta">
            Get Quote
          </a>
        </div>
        <div class="samsung-model-card">
          <div class="samsung-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="samsung-model-title">Galaxy Note Series</h3>
          <p class="samsung-model-description">Premium Note devices with S Pen stylus support. Note 20 Ultra uses a curved Dynamic AMOLED display - screen repairs require model-specific parts to maintain the 120Hz refresh and S Pen digitizer.</p>
          <div class="samsung-model-pills">
            <span class="samsung-pill">Galaxy Note 20 Ultra</span>
            <span class="samsung-pill">Galaxy Note 20</span>
            <span class="samsung-pill">Galaxy Note 10+</span>
            <span class="samsung-pill">Galaxy Note 10</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="samsung-model-cta">
            Get Quote
