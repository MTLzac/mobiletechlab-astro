---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Google Pixel Repair Winnipeg | Screen & Battery Fix";
const description = "Professional Google Pixel repair in Winnipeg. Screen, battery, charging port for Pixel 9, 8, 7, 6, Fold & all models. Same-day service at Mobile Tech Lab.";
const canonical = "https://mobiletechlab.ca/repairs/google-pixel";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Google Pixel Repair", "item": "https://mobiletechlab.ca/repairs/google-pixel" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Google Pixel Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repairs/google-pixel",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Google Pixel Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Speaker Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fingerprint Sensor Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does Google Pixel screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Pixel screen replacements are completed within 1–2 hours at our Winnipeg St. Vital location. Pixel Fold and Pixel 9 Pro Fold devices require 2–4 hours due to their complex folding display assemblies and hinge mechanisms." } },
    { "@type": "Question", "name": "Do you repair Pixel Fold and Pixel 9 Pro Fold in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we specialise in Pixel Fold and Pixel 9 Pro Fold repairs including inner screen, outer screen, hinge mechanism, and flex cable issues. Foldable screen repairs are among the most complex phone repairs available — contact us to confirm parts availability and get a quote before visiting." } },
    { "@type": "Question", "name": "Will my Pixel still receive software updates after repair?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — your Pixel will continue receiving all Google software updates, security patches, and Pixel Feature Drops after our repair. Our repairs are hardware-only and do not affect the Android OS, Google services, or any software functionality on your device." } },
    { "@type": "Question", "name": "How much does Google Pixel repair cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Pixel repair costs vary by model and repair type — Pixel a-series repairs are typically the most affordable, while Pro models and Fold devices cost more due to premium OLED and LTPO display components. Contact us or use our online quote tool for a free upfront price on your specific model." } },
    { "@type": "Question", "name": "Do Pixel repairs affect camera quality or AI features?", "acceptedAnswer": { "@type": "Answer", "text": "No — our repairs preserve all of your Pixel's AI photography features including Night Sight, Magic Eraser, Photo Unblur, and computational zoom. We use quality parts that maintain the hardware specifications required for Pixel's camera software to function correctly." } },
    { "@type": "Question", "name": "Do you repair Google Pixel batteries in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — same-day Pixel battery replacement is available for all models at our Winnipeg St. Vital location. Pixel batteries typically degrade noticeably after 2–3 years and a replacement can restore full Adaptive Battery life — all battery replacements include a 90-day warranty." } },
    { "@type": "Question", "name": "Can you fix a Google Pixel that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive Pixel is often caused by a depleted battery, a failed display connection, or a software boot issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the problem is before spending anything." } },
    { "@type": "Question", "name": "Do you repair Pixel under-display fingerprint sensors?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair and recalibrate under-display optical fingerprint sensors on Pixel 6, 7, 8, and 9 series devices. Fingerprint sensor issues often occur after screen replacements that use incompatible panels — we use model-matched screens to prevent this." } },
    { "@type": "Question", "name": "Do I need an appointment for Pixel repair in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "No appointment is needed — walk-ins are welcome at both our St. Vital and Thompson locations during business hours. Calling ahead is helpful for Pixel Fold or Pro model repairs so we can confirm we have your specific parts in stock before your visit." } },
    { "@type": "Question", "name": "Do you repair Google Pixel phones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts Pixel repairs and walk-ins Monday through Saturday 10AM–6PM. We stock parts for common Pixel models — calling ahead helps confirm availability for newer or Pro models." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="gp-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="gp-container">
      <ol class="gp-breadcrumb-list">
        <li><a href="/" class="gp-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="gp-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="gp-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="gp-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="gp-breadcrumb-current" aria-current="page">Google Pixel Repair</li>
      </ol>
    </div>
  </nav>

  <section class="gp-hero-section" id="hero">
    <div class="gp-hero-inner">
      <div class="gp-hero-content">
        <div class="gp-hero-badge-row">
          <span class="gp-service-badge">Google Pixel Repair Specialists</span>
          <span class="gp-location-badge">
            <span class="gp-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="gp-location-badge">
            <span class="gp-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="gp-hero-headline">
          Google Pixel Repair <span class="gp-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="gp-hero-subheadline">Pixel 9, 8, 7, 6, Fold & All Models — Repair Specialists in Winnipeg</p>

        <div class="gp-hero-body">
          <p>Cracked Pixel screen or battery not lasting the day? We repair all Google Pixel models at our Winnipeg shop — from Pixel 3 through Pixel 9 Pro XL and Pixel 9 Pro Fold. Common repairs include OLED screen replacements, battery swaps, USB-C charging port fixes, Pixel camera repairs, speaker issues, and under-display fingerprint sensor calibration.</p>
          <p>Google Pixel phones use OLED and LTPO displays with tight software-hardware integration — a repair that requires Pixel-specific parts to maintain the 120Hz ProMotion and computational photography features your phone is known for. Our Winnipeg technicians use quality parts and back every repair with our warranty so your Pixel performs exactly as it should after the fix.</p>
        </div>

        <div class="gp-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="gp-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="gp-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="gp-hero-image-wrapper">
        <img
          src="/assets/hero-google-pixel-DbVhE6PQ.png"
          alt="Google Pixel repair in Winnipeg — screen, battery and camera specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="gp-annotations-list" aria-label="Common Pixel issues we fix">
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Charging port issues
          </li>
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Camera not working
          </li>
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
          <li class="gp-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Fingerprint sensor issues
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="gp-services-section" id="services">
    <div class="gp-container">
      <div class="gp-section-header">
        <h2 class="gp-section-title">Google Pixel Repair Services in Winnipeg</h2>
        <p class="gp-section-subtitle">Expert repairs for all Pixel models. Fast turnaround, quality parts, and warranty included.</p>
      </div>
      <div class="gp-services-grid">
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="gp-service-title">Screen Replacement</h3>
          <p class="gp-service-body">Cracked or unresponsive Pixel display? We replace OLED and LTPO screens on all Pixel models — restoring smooth 120Hz scrolling on Pixel 7 Pro, 8 Pro, and 9 Pro models. Pixel Fold inner and outer screen replacements are also available, including the complex hinge-adjacent display assembly that most shops won't attempt.</p>
        </div>
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="gp-service-title">Battery Replacement</h3>
          <p class="gp-service-body">Pixel batteries typically degrade noticeably after 2–3 years of use. We replace batteries on all Pixel models with quality cells that restore full Adaptive Battery life. Same-day turnaround at our Winnipeg location — all battery replacements include a 90-day warranty.</p>
        </div>
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="gp-service-title">Charging Port Repair</h3>
          <p class="gp-service-body">Pixel not charging or connecting intermittently? We repair USB-C ports on all Pixel models — fixing charging issues, loose connections, and data transfer problems. We clean the port before recommending replacement since debris is a common cause of Pixel charging failures.</p>
        </div>
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="gp-service-title">Camera Repair</h3>
          <p class="gp-service-body">Pixel cameras are renowned for computational photography — a blurry, black, or cracked camera module undermines the whole device. We repair rear cameras, ultrawide, telephoto, and front cameras on all Pixel models. Camera repairs preserve your Pixel's AI photography features including Night Sight, Magic Eraser, and Photo Unblur.</p>
        </div>
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
          <h3 class="gp-service-title">Speaker Repair</h3>
          <p class="gp-service-body">Muffled audio, crackling speakers, or a dead earpiece on your Pixel? We repair and replace speaker assemblies and earpieces across all Pixel generations. Most speaker repairs are completed same-day.</p>
        </div>
        <div class="gp-service-card">
          <div class="gp-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="gp-service-title">Fingerprint Sensor Repair</h3>
          <p class="gp-service-body">Under-display fingerprint sensor not registering or failing on your Pixel 6, 7, 8, or 9? We repair and recalibrate optical in-display fingerprint sensors — a component that requires precise calibration to the screen assembly after any screen replacement.</p>
        </div>
      </div>
      <div class="gp-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="gp-models-section" id="models">
    <div class="gp-container">
      <div class="gp-section-header">
        <h2 class="gp-section-title">All Google Pixel Models We Repair in Winnipeg</h2>
        <p class="gp-section-subtitle">From Pixel 3 through Pixel 9 Pro Fold — every generation serviced</p>
      </div>
      <div class="gp-models-grid">
        <div class="gp-model-card">
          <div class="gp-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="gp-model-title">Pixel 9 Series</h3>
          <p class="gp-model-description">Latest generation powered by Tensor G4. OLED screen and battery repairs available same-day for all Pixel 9 models including the Pixel 9 Pro Fold.</p>
          <div class="gp-model-pills">
            <span class="gp-pill">Pixel 9 Pro XL</span>
            <span class="gp-pill">Pixel 9 Pro</span>
            <span class="gp-pill">Pixel 9</span>
            <span class="gp-pill">Pixel 9 Pro Fold</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="gp-model-card">
          <div class="gp-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="gp-model-title">Pixel 8 Series</h3>
          <p class="gp-model-description">Tensor G3 powered devices with advanced AI features. Screen, battery, and camera repairs available. Pixel 8a repairs are typically the most affordable in the lineup.</p>
          <div class="gp-model-pills">
            <span class="gp-pill">Pixel 8 Pro</span>
            <span class="gp-pill">Pixel 8</span>
            <span class="gp-pill">Pixel 8a</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="gp-model-card">
          <div class="gp-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="gp-model-title">Pixel 7 Series</h3>
          <p class="gp-model-description">First-generation Tensor G2 phones. Pixel 7 Pro uses a curved LTPO OLED display — repairs require model-specific parts to maintain the 120Hz refresh rate.</p>
          <div class="gp-model-pills">
            <span class="gp-pill">Pixel 7 Pro</span>
            <span class="gp-pill">Pixel 7</span>
            <span class="gp-pill">Pixel 7a</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="gp-model-card">
          <div class="gp-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="gp-model-title">Pixel Fold & Legacy</h3>
          <p class="gp-model-description">Foldable Pixel specialists plus continued support for Pixel 6, 5, 4, and 3 generations. Pixel Fold inner screen and hinge repairs available — contact us to confirm parts availability.</p>
          <div class="gp-model-pills">
            <span class="gp-pill">Pixel Fold</span>
            <span class="gp-pill">Pixel 6 Pro</span>
            <span class="gp-pill">Pixel 6</span>
            <span class="gp-pill">Pixel 6a</span>
            <span class="gp-pill">Pixel 5</span>
            <span class="gp-pill">Pixel 5a</span>
            <span class="gp-pill">Pixel 4 XL</span>
            <span class="gp-pill">Pixel 4</span>
            <span class="gp-pill">Pixel 4a</span>
            <span class="gp-pill">Pixel 3 XL</span>
            <span class="gp-pill">Pixel 3</span>
            <span class="gp-pill">Pixel 3a</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="gp-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="gp-why-section" id="why-choose-us">
    <div class="gp-container">
      <div class="gp-section-header">
        <h2 class="gp-section-title">The Mobile Tech Lab Advantage: Winnipeg's Pixel Repair Experts</h2>
        <p class="gp-section-subtitle">Why Winnipeg customers trust us with their Google Pixel devices</p>
      </div>
      <div class="gp-pillars-grid">
        <div class="gp-pillar-card">
          <div class="gp-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="gp-pillar-title">Pure Android & Tensor Experts</h3>
          <p class="gp-pillar-body">Google Pixel devices have unique hardware-software integration built around the Tensor chip and Android's AI features. Our Winnipeg technicians understand Pixel's architecture — ensuring screen replacements maintain touch sensitivity calibration and camera repairs preserve computational photography performance.</p>
        </div>
        <div class="gp-pillar-card">
          <div class="gp-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="gp-pillar-title">Same-Day Pixel Repairs</h3>
          <p class="gp-pillar-body">Most Pixel screen and battery repairs are completed within 2 hours at our Winnipeg St. Vital location. Walk in any time during business hours — we stock parts for all current Pixel generations so same-day service is available without pre-ordering.</p>
        </div>
        <div class="gp-pillar-card">
          <div class="gp-pillar-icon-wrapper">
