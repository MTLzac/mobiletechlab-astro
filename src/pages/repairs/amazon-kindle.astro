---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Kindle & Fire Tablet Repair Winnipeg | Mobile Tech Lab";
const description = "Amazon Kindle and Fire tablet repair in Winnipeg. E-Ink screen, battery, charging port repair for all Kindle and Fire models. Same-day service available.";
const canonical = "https://mobiletechlab.ca/repairs/amazon-kindle";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "Kindle & Fire Repair", "item": "https://mobiletechlab.ca/repairs/amazon-kindle" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Amazon Kindle and Fire Tablet Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "E-Reader and Tablet Repair",
  "url": "https://mobiletechlab.ca/repairs/amazon-kindle",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Kindle and Fire Tablet Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Speaker Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Damage Recovery" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wi-Fi and Connectivity Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Can you replace a cracked E-Ink screen on my Kindle in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we replace damaged E-Ink electrophoretic displays on most Kindle e-reader models including Kindle Paperwhite, Oasis, Scribe, and standard Kindle generations. E-Ink screens require model-specific replacement modules — contact us to confirm availability for your specific Kindle before visiting." } },
    { "@type": "Question", "name": "How long does a Kindle battery replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most Kindle battery replacements are completed within 1–2 hours at our Winnipeg St. Vital location. Kindle e-reader batteries are designed to last weeks between charges — if yours is dying in hours, a battery replacement can fully restore that extended reading life." } },
    { "@type": "Question", "name": "My Fire tablet won't charge. Can you fix it in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — Fire tablet charging port failures are one of our most common repairs, especially on devices used by children where ports get debris pushed in. We clean the port first before recommending replacement — most Fire tablet charging port repairs are completed same-day." } },
    { "@type": "Question", "name": "Do you repair older Kindle models in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "We service most current Kindle and Fire generations — parts availability varies for older discontinued models. Contact us with your specific model name and generation so we can confirm whether we have parts in stock before your visit." } },
    { "@type": "Question", "name": "Will I lose my books and content after Kindle or Fire repair?", "acceptedAnswer": { "@type": "Answer", "text": "No — your Amazon account content including books, magazines, apps, and settings is stored in the cloud and will automatically sync back to your repaired device. Data loss is rarely a concern for Kindle and Fire repairs since everything is tied to your Amazon account." } },
    { "@type": "Question", "name": "Is it worth repairing my Kindle or should I buy a new one?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the model and repair needed — a battery replacement on any Kindle almost always makes financial sense, while an E-Ink screen replacement on an older Kindle may approach the cost of a new entry-level model. We always give you an honest comparison before starting so you can make an informed decision." } },
    { "@type": "Question", "name": "Do you repair Fire HD Kids tablets in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all Fire Kids Edition tablets including Fire HD 8 Kids, Fire HD 10 Kids, and Fire 7 Kids. Kids Edition devices have rubber protective cases that help with drops, but the internal screens still crack — we repair all Kids Edition models at our Winnipeg location." } },
    { "@type": "Question", "name": "Can you fix a Kindle that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a Kindle that won't power on is usually caused by a fully depleted battery, a software hang, or a charging port fault. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what the issue is before spending anything." } },
    { "@type": "Question", "name": "Do you repair Fire Max 11 tablets in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair the Fire Max 11 including screen, battery, and charging port repairs at our Winnipeg St. Vital location. The Fire Max 11 is Amazon's largest and most premium tablet — contact us to confirm current parts availability for your specific repair." } },
    { "@type": "Question", "name": "Do you repair Kindle and Fire tablets in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts Kindle and Fire tablet repairs Monday through Saturday 10AM–6PM. For E-Ink screen repairs or less common models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="kindle-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="kindle-container">
      <ol class="kindle-breadcrumb-list">
        <li><a href="/" class="kindle-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="kindle-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="kindle-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="kindle-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="kindle-breadcrumb-current" aria-current="page">Kindle & Fire Repair</li>
      </ol>
    </div>
  </nav>

  <section class="kindle-hero-section" id="hero">
    <div class="kindle-hero-inner">
      <div class="kindle-hero-content">
        <div class="kindle-hero-badge-row">
          <span class="kindle-service-badge">Amazon Kindle & Fire Tablet Specialists</span>
          <span class="kindle-location-badge">
            <span class="kindle-badge-dot"></span>
            St. Vital - Open
          </span>
          <span class="kindle-location-badge kindle-location-badge-secondary">
            <span class="kindle-badge-dot kindle-badge-dot-secondary"></span>
            Thompson - Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="kindle-hero-headline">
          Kindle & Fire Repair <span class="kindle-highlight">Winnipeg</span> & Manitoba
        </h1>
        <p class="kindle-hero-subheadline">Kindle E-Reader & Fire Tablet Repair Specialists in Winnipeg</p>

        <div class="kindle-hero-body">
          <p>Cracked Kindle E-Ink display, dead battery, or Fire tablet that won't charge? We repair all Amazon Kindle and Fire tablet models at our Winnipeg shop — from Kindle Paperwhite and Oasis through Fire HD 8, Fire HD 10, Fire Max 11, and all Kids Edition tablets. Common repairs include E-Ink and LCD screen replacements, battery swaps, USB-C and Micro-USB charging port fixes, speaker repairs, and water damage assessment.</p>
          <p>E-Ink screen replacement is the most technically involved Kindle repair — the electrophoretic display used in Kindle e-readers is a completely different technology from standard LCD or OLED panels, requiring careful handling and model-specific replacement modules. We stock E-Ink panels for current Kindle generations and provide an honest assessment of whether repair cost makes sense given the device's value before starting any work.</p>
        </div>

        <div class="kindle-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="kindle-cta-primary">
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="tel:2045009757" class="kindle-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="kindle-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="kindle-hero-image-wrapper">
        <img
          src="/assets/hero-amazon-kindle-D6l7Y2Vv.png"
          alt="Amazon Kindle and Fire tablet repair in Winnipeg — E-Ink screen and battery specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="kindle-annotations-list" aria-label="Common Kindle and Fire issues we fix">
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked E-Ink screen
          </li>
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery won't hold charge
          </li>
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
            Won't charge
          </li>
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            Screen unresponsive
          </li>
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            Water damage
          </li>
          <li class="kindle-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/></svg>
            Speaker not working
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="kindle-services-section" id="services">
    <div class="kindle-container">
      <div class="kindle-section-header">
        <h2 class="kindle-section-title">Kindle & Fire Tablet Repair Services in Winnipeg</h2>
        <p class="kindle-section-subtitle">Expert repairs for all Amazon Kindle and Fire models. Quality parts, honest advice, warranty included.</p>
      </div>
      <div class="kindle-services-grid">
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="kindle-service-title">Screen Replacement</h3>
          <p class="kindle-service-body">Cracked or unresponsive display? We replace E-Ink electrophoretic screens on all Kindle e-reader models and LCD screens on Fire HD tablets. E-Ink displays use a completely different technology from standard phone or tablet screens — they require model-specific replacement modules and careful handling. We provide an honest assessment of repair cost versus device value before starting any Kindle screen repair.</p>
        </div>
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="kindle-service-title">Battery Replacement</h3>
          <p class="kindle-service-body">Kindle dying mid-chapter or Fire tablet not lasting the day? We replace batteries on all Kindle and Fire models with quality cells. Kindle e-reader batteries are designed to last weeks between charges — if yours is lasting only hours, a replacement can restore that extended reading life. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="kindle-service-title">Charging Port Repair</h3>
          <p class="kindle-service-body">Kindle or Fire tablet not charging or connecting intermittently? We repair USB-C and Micro-USB charging ports on all Amazon devices. Charging port failures are especially common on Fire tablets used by children — we clean the port before recommending replacement since debris is a frequent cause of charging issues. Most charging port repairs are completed same-day.</p>
        </div>
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
          <h3 class="kindle-service-title">Speaker Repair</h3>
          <p class="kindle-service-body">Muffled audio or no sound from your Fire tablet? We repair speaker assemblies and earpieces on all Fire HD models. Speaker issues are common on Fire Kids tablets after drops or liquid exposure — we diagnose the specific cause before recommending replacement. Most speaker repairs are completed same-day.</p>
        </div>
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          </div>
          <h3 class="kindle-service-title">Water Damage Recovery</h3>
          <p class="kindle-service-body">Kindle or Fire tablet dropped in water? We perform component-level diagnostics and cleaning to assess what can be recovered from liquid-damaged devices. Kindle e-readers are not water resistant on older models — we evaluate the extent of damage and give you an honest prognosis before recommending any repair.</p>
        </div>
        <div class="kindle-service-card">
          <div class="kindle-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12.55a11 11 0 0114 0M8.53 16.11a6 6 0 016.95 0M12 20h.01"/></svg>
          </div>
          <h3 class="kindle-service-title">Wi-Fi & Connectivity Issues</h3>
          <p class="kindle-service-body">Kindle or Fire tablet dropping Wi-Fi, failing to connect, or showing weak signal? We diagnose and repair wireless antenna and Wi-Fi module issues across all Kindle and Fire models. Connectivity problems are often caused by physical antenna damage from drops — we identify the root cause before recommending any repair.</p>
        </div>
      </div>
      <div class="kindle-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="kindle-cta-primary">
          Request Repair
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="kindle-models-section" id="models">
    <div class="kindle-container">
      <div class="kindle-section-header">
        <h2 class="kindle-section-title">All Kindle & Fire Models We Repair in Winnipeg</h2>
        <p class="kindle-section-subtitle">E-readers, tablets, and Kids Edition devices — all Amazon models serviced</p>
      </div>
      <div class="kindle-models-grid">
        <div class="kindle-model-card">
          <div class="kindle-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="kindle-model-title">Kindle E-Readers</h3>
          <p class="kindle-model-description">E-Ink screen repairs and battery replacements for all Kindle generations. E-Ink panels are model-specific — contact us to confirm availability for your Kindle before visiting.</p>
          <div class="kindle-model-pills">
            <span class="kindle-pill">Kindle Scribe</span>
            <span class="kindle-pill">Kindle Paperwhite Signature Edition</span>
            <span class="kindle-pill">Kindle Paperwhite (11th Gen)</span>
            <span class="kindle-pill">Kindle Paperwhite (10th Gen)</span>
            <span class="kindle-pill">Kindle Oasis (10th Gen)</span>
            <span class="kindle-pill">Kindle Oasis (9th Gen)</span>
            <span class="kindle-pill">Kindle (11th Gen)</span>
            <span class="kindle-pill">Kindle (10th Gen)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="kindle-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="kindle-model-card">
          <div class="kindle-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="kindle-model-title">Fire Tablets</h3>
          <p class="kindle-model-description">LCD screen, battery, and charging port repairs for all Fire HD tablet generations. Fire tablet repairs are generally more accessible than Kindle E-Ink repairs with better parts availability.</p>
          <div class="kindle-model-pills">
            <span class="kindle-pill">Fire Max 11</span>
            <span class="kindle-pill">Fire HD 10 (2023)</span>
            <span class="kindle-pill">Fire HD 10 (2021)</span>
            <span class="kindle-pill">Fire HD 10 Plus</span>
            <span class="kindle-pill">Fire HD 8 (2022)</span>
            <span class="kindle-pill">Fire HD 8 (2020)</span>
            <span class="kindle-pill">Fire HD 8 Plus</span>
            <span class="kindle-pill">Fire 7 (2022)</span>
            <span class="kindle-pill">Fire 7 (2019)</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="kindle-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="kindle-model-card">
          <div class="kindle-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="kindle-model-title">Kids Edition Devices</h3>
          <p class="kindle-model-description">Kindle Kids and Fire Kids tablet repairs. Kids Edition devices come with rubber bumper cases that offer some drop protection — but internal screens still crack. We repair all Kids Edition models.</p>
          <div class="kindle-model-pills">
            <span class="kindle-pill">Kindle Kids (2022)</span>
            <span class="kindle-pill">Fire HD 10 Kids</span>
            <span class="kindle-pill">Fire HD 10 Kids Pro</span>
            <span class="kindle-pill">Fire HD 8 Kids</span>
            <span class="kindle-pill">Fire HD 8 Kids Pro</span>
            <span class="kindle-pill">Fire 7 Kids</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="kindle-model-cta">
            Get Quote
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="kindle-why-section" id="why-choose-us">
    <div class="kindle-container">
      <div class="kindle-section-header">
        <h2 class="kindle-section-title">The Mobile Tech Lab Advantage: Winnipeg's Kindle & Fire Repair Experts</h2>
        <p class="kindle-section-subtitle">Why Winnipeg readers and families trust us with their Amazon devices</p>
      </div>
      <div class="kindle-pillars-grid">
        <div class="kindle-pillar-card">
          <div class="kindle-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/><path d="M8 6h8M8 10h8M8 14h4"/></svg>
