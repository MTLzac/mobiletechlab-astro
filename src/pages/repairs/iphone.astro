---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "iPhone Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Expert iPhone repair in Winnipeg & Thompson. Same-day screen, battery, charging port & back glass repair for all models. Price match guarantee at Mobile Tech Lab.";
const canonical = "https://mobiletechlab.ca/repairs/iphone";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "iPhone Repair", "item": "https://mobiletechlab.ca/repairs/iphone" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "iPhone Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Phone Repair",
  "url": "https://mobiletechlab.ca/repairs/iphone",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "iPhone Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Back Glass Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Camera Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Damage Recovery" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does iPhone screen replacement take in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most iPhone screen replacements at our Winnipeg shop are completed in 1–2 hours while you wait. We stock screens for all popular iPhone models so walk-in same-day service is available at our St. Vital location." } },
    { "@type": "Question", "name": "Do you offer same-day iPhone battery replacement in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — same-day iPhone battery replacement is available for all models at our Winnipeg St. Vital location. Most battery swaps take under an hour and your phone is returned fully tested before you leave." } },
    { "@type": "Question", "name": "Are your iPhone repair parts genuine Apple or aftermarket?", "acceptedAnswer": { "@type": "Answer", "text": "We use high-quality parts that meet or exceed OEM standards for most repairs, and genuine Apple parts are available for customers who prefer them. As an Apple Independent Repair Provider, we have access to official Apple parts and diagnostics." } },
    { "@type": "Question", "name": "Do I need an appointment for iPhone repair in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "No appointment is needed — walk-ins are welcome at both our St. Vital and Thompson locations any time during business hours. Booking ahead helps us confirm we have your specific model's parts ready, which can speed up your repair." } },
    { "@type": "Question", "name": "What warranty do you offer on iPhone repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Screen repairs carry a 30-day to lifetime warranty depending on the part tier selected. Battery replacements include a 90-day warranty, and most other component repairs carry a lifetime warranty on parts and labour." } },
    { "@type": "Question", "name": "What if I find a cheaper iPhone repair quote in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "We offer a price match guarantee — show us a lower quote from any Winnipeg repair shop for the same repair and we'll match it. We believe you shouldn't have to pay more than necessary for a quality iPhone fix." } },
    { "@type": "Question", "name": "Can you repair an iPhone that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a completely unresponsive iPhone is often caused by a fully drained battery, a failed display connection, or a software issue. We run free diagnostics before recommending any repair so you know exactly what the issue is." } },
    { "@type": "Question", "name": "Do you repair iPhone back glass in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we replace cracked back glass on iPhone 8 and all newer models including the full iPhone 16 lineup. Back glass repair requires full disassembly of the device, so it takes a bit longer than a screen replacement." } },
    { "@type": "Question", "name": "Can you fix iPhone water damage in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — despite water resistance ratings, iPhones can still suffer liquid damage from salt water, pool chemicals, or older models with degraded seals. We perform ultrasonic cleaning and component-level diagnostics to assess what can be recovered." } },
    { "@type": "Question", "name": "Do you repair iPhones in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 offers the same iPhone repair services as Winnipeg. Walk-ins are welcome Monday through Saturday 10AM–6PM." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumbs -->
  <nav class="ip-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="ip-container">
      <ol class="ip-breadcrumb-list">
        <li><a href="/" class="ip-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ip-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="ip-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ip-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="ip-breadcrumb-current" aria-current="page">iPhone Repair</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="ip-hero-section" id="hero">
    <div class="ip-hero-inner">
      <div class="ip-hero-content">
        <div class="ip-hero-badge-row">
          <span class="ip-service-badge">Professional iPhone Repair</span>
          <span class="ip-location-badge">
            <span class="ip-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="ip-location-badge">
            <span class="ip-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="ip-hero-headline">
          iPhone Repair <span class="ip-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="ip-hero-subheadline">Fast, Affordable iPhone Repair Specialists in Winnipeg</p>

        <div class="ip-hero-body">
          <p>Cracked screen, dead battery, or charging port not working? We repair all iPhone models at our Winnipeg shop — from iPhone 6s through iPhone 16 Pro Max. Common repairs include screen replacements, battery swaps, charging port fixes, back glass restoration, camera repairs, and water damage recovery. We also repair <a href="/repairs/ipad">iPads</a>, <a href="/repairs/macbook">MacBooks</a>, and <a href="/repairs/apple-watch">Apple Watches</a>.</p>
          <p>Most iPhone repairs are completed in 1–2 hours while you wait. Our technicians use high-quality parts that meet or exceed OEM standards, and every repair is backed by our warranty. We're so confident in our pricing that we offer a price match guarantee — find a cheaper quote from any Winnipeg repair shop and we'll match it.</p>
        </div>

        <div class="ip-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="ip-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="ip-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="ip-hero-image-wrapper">
        <img
          src="/assets/hero-iphone.png"
          alt="iPhone repair in Winnipeg — screen, battery and charging port specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="ip-annotations-list" aria-label="Common iPhone issues we fix">
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
            Charging port issues
          </li>
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Back glass cracked
          </li>
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Camera not working
          </li>
          <li class="ip-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            Water damage
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Repair Services -->
  <section class="ip-services-section" id="services">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">iPhone Repair Services in Winnipeg</h2>
        <p class="ip-section-subtitle">Expert repairs for all iPhone models. Fast turnaround, quality parts, and warranty included.</p>
      </div>
      <div class="ip-services-grid">
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ip-service-title">Screen Replacement</h3>
          <p class="ip-service-body">Cracked, shattered, or unresponsive iPhone screen? We replace displays on all models from iPhone 6s through iPhone 16 Pro Max using quality parts that meet or exceed OEM standards. Most screen replacements are completed in 1–2 hours. Premium OLED replacements available for Face ID models with colour accuracy to match the original display.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="ip-service-title">Battery Replacement</h3>
          <p class="ip-service-body">iPhone not lasting the day? We replace degraded batteries with quality cells and same-day turnaround on all models. Genuine Apple battery upgrades are available for customers who prefer OEM parts. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="ip-service-title">Back Glass Repair</h3>
          <p class="ip-service-body">iPhone 8 and newer models use glass backs that crack from drops. We replace rear glass panels with quality parts. Back glass repair is more involved than screen repair — we fully disassemble the device to replace the panel correctly.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="ip-service-title">Charging Port Repair</h3>
          <p class="ip-service-body">iPhone not charging or connecting intermittently? We repair and replace both Lightning and USB-C ports across all iPhone models. Most charging port repairs are completed same-day.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="ip-service-title">Camera Repair</h3>
          <p class="ip-service-body">Blurry photos, black camera screen, or cracked camera lens? We fix front and rear camera issues on all iPhone models including the Pro camera systems on iPhone 12 Pro and newer.</p>
        </div>
        <div class="ip-service-card">
          <div class="ip-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          </div>
          <h3 class="ip-service-title">Water Damage Recovery</h3>
          <p class="ip-service-body">Dropped your iPhone in water? Despite water resistance ratings, iPhones can still suffer liquid damage. We perform ultrasonic cleaning and component-level diagnostics to assess and repair water-damaged devices before recommending any further action.</p>
        </div>
      </div>
      <div class="ip-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ip-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Models -->
  <section class="ip-models-section" id="models">
    <div class="ip-container">
      <div class="ip-section-header">
        <h2 class="ip-section-title">All iPhone Models We Repair in Winnipeg</h2>
        <p class="ip-section-subtitle">From iPhone 6s to the latest iPhone 16 Pro Max — we repair them all</p>
      </div>
      <div class="ip-models-grid">
        <div class="ip-model-card">
          <div class="ip-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ip-model-title">iPhone 16 &amp; 15 Series</h3>
          <p class="ip-model-description">Latest generation with USB-C, Dynamic Island, and A17/A18 chips. Screen, battery, and camera repairs available same-day.</p>
          <div class="ip-model-pills">
            <span class="ip-pill">iPhone 16 Pro Max</span>
            <span class="ip-pill">iPhone 16 Pro</span>
            <span class="ip-pill">iPhone 16 Plus</span>
            <span class="ip-pill">iPhone 16</span>
            <span class="ip-pill">iPhone 15 Pro Max</span>
            <span class="ip-pill">iPhone 15 Pro</span>
            <span class="ip-pill">iPhone 15 Plus</span>
