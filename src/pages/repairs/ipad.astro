  <section class="ipad-cost-section" id="pricing">
    <div class="ipad-container">
      <div class="ipad-section-header">
        <h2 class="ipad-section-title">Worried About Repair Cost? You Have Options.</h2>
        <p class="ipad-section-subtitle">Most customers use one of these options to lower their repair cost.</p>
      </div>
      <div class="ipad-cost-grid">
        <div class="ipad-cost-card">
          <div class="ipad-cost-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
