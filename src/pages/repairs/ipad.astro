---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "iPad Repair Winnipeg | Screen & Battery | Mobile Tech Lab";
const description = "Professional iPad repair in Winnipeg & Thompson. Screen replacement, battery, charging port repair for iPad Pro, Air, mini & all models. Same-day service available.";
const canonical = "https://mobiletechlab.ca/repairs/ipad";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mobiletechlab.ca/" },
    { "@type": "ListItem", "position": 2, "name": "Repairs", "item": "https://mobiletechlab.ca/repairs" },
    { "@type": "ListItem", "position": 3, "name": "iPad Repair", "item": "https://mobiletechlab.ca/repairs/ipad" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "iPad Repair Service",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mobile Tech Lab",
    "url": "https://mobiletechlab.ca"
  },
  "areaServed": { "@type": "City", "name": "Winnipeg" },
  "serviceType": "Tablet Repair",
  "url": "https://mobiletechlab.ca/repairs/ipad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "iPad Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Screen Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Replacement" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charging Port Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Liquid Damage Recovery" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Software and Boot Issues" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Button and Sensor Repair" } }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does iPad screen repair cost in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "iPad repair costs vary significantly by model — standard iPad models are the most affordable to repair while iPad Pro screens are the most expensive due to their ProMotion OLED assemblies. Contact us or use our online quote tool for a free upfront price on your specific iPad model." } },
    { "@type": "Question", "name": "How long does it take to repair a cracked iPad screen in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Most iPad screen replacements are completed same-day at our Winnipeg St. Vital location, typically within a few hours. iPad Pro screen repairs may take longer due to the complexity of the fused display assembly — we'll give you a time estimate when you drop it off." } },
    { "@type": "Question", "name": "Do you use genuine Apple parts for iPad repairs?", "acceptedAnswer": { "@type": "Answer", "text": "As an Apple Independent Repair Provider, we have access to genuine Apple parts and official diagnostics for iPad repairs. We also offer quality aftermarket parts at a lower price point — we'll explain both options and let you choose before starting any repair." } },
    { "@type": "Question", "name": "What warranty do you offer on iPad repairs?", "acceptedAnswer": { "@type": "Answer", "text": "Screen repairs carry a 30-day to lifetime warranty depending on the part tier selected. Battery replacements include a 90-day warranty, and most other component repairs carry a lifetime warranty on parts and labour." } },
    { "@type": "Question", "name": "Can you fix a water-damaged iPad in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we offer liquid damage recovery using ultrasonic cleaning and component-level diagnostics to assess what can be saved. Recovery success depends on the extent of the damage and how quickly the device was powered off after exposure — bring it in as soon as possible for the best outcome." } },
    { "@type": "Question", "name": "Can you repair an iPad that won't turn on?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a non-responsive iPad is often caused by a fully depleted battery, a failed display connection, or a software issue. We run free diagnostics to identify the root cause before recommending any repair so you know exactly what's wrong before spending anything." } },
    { "@type": "Question", "name": "Do you repair iPad Pro screens in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair all iPad Pro models including the latest M4 Pro. iPad Pro screens use ProMotion OLED fused displays that require specialized tools and model-specific parts — we stock them for all current iPad Pro generations at our St. Vital location." } },
    { "@type": "Question", "name": "Can you fix an iPad home button or Touch ID?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we repair and replace home buttons, Touch ID sensors, power buttons, and Face ID components across all iPad models. Most button repairs are completed same-day and carry a warranty on parts and labour." } },
    { "@type": "Question", "name": "Do I need an appointment for iPad repair in Winnipeg?", "acceptedAnswer": { "@type": "Answer", "text": "No appointment is needed — walk-ins are welcome at both our St. Vital and Thompson locations during business hours. Calling ahead is helpful for iPad Pro repairs so we can confirm we have your model's specific parts in stock before your visit." } },
    { "@type": "Question", "name": "Do you repair iPads in Thompson, MB?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — our Thompson location at 300 Mystery Lake Rd #1530 accepts iPad repairs and walk-ins Monday through Saturday 10AM–6PM. For iPad Pro or less common models, calling ahead helps us confirm parts availability before your visit." } }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <nav class="ipad-breadcrumb-nav" aria-label="Breadcrumb">
    <div class="ipad-container">
      <ol class="ipad-breadcrumb-list">
        <li><a href="/" class="ipad-breadcrumb-link">Home</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ipad-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li><a href="/repairs" class="ipad-breadcrumb-link">Repairs</a></li>
        <li><svg xmlns="http://www.w3.org/2000/svg" class="ipad-breadcrumb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 18 6-6-6-6"/></svg></li>
        <li class="ipad-breadcrumb-current" aria-current="page">iPad Repair</li>
      </ol>
    </div>
  </nav>

  <section class="ipad-hero-section" id="hero">
    <div class="ipad-hero-inner">
      <div class="ipad-hero-content">
        <div class="ipad-hero-badge-row">
          <span class="ipad-service-badge">Professional iPad Repair</span>
          <span class="ipad-location-badge">
            <span class="ipad-badge-dot"></span>
            St. Vital — Open
          </span>
          <span class="ipad-location-badge">
            <span class="ipad-badge-dot"></span>
            Thompson — Opens tomorrow 10AM
          </span>
        </div>

        <h1 class="ipad-hero-headline">
          iPad Repair <span class="ipad-highlight">Winnipeg</span> &amp; Manitoba
        </h1>
        <p class="ipad-hero-subheadline">iPad Pro, Air, Mini & Standard Repair Specialists in Winnipeg</p>

        <div class="ipad-hero-body">
          <p>Shattered iPad screen or battery that won't hold a charge? We repair all iPad models at our Winnipeg shop — from the original iPad through iPad Pro M4, iPad Air M2, iPad mini 6th Gen, and all standard iPad generations. Common repairs include screen replacements, battery swaps, charging port fixes, liquid damage recovery, button and sensor repairs, and software issues.</p>
          <p>iPad Pro screens use ProMotion OLED displays with fused glass assemblies — a repair that requires precision tools and model-specific parts most general repair shops don't carry. As an Apple Independent Repair Provider, our Winnipeg technicians have access to genuine Apple parts and official diagnostics for accurate, warranty-backed repairs.</p>
        </div>

        <div class="ipad-hero-cta-group">
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-cta-primary">
            Get a Free Quote &rarr;
          </a>
          <a href="tel:2045009757" class="ipad-cta-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <p class="ipad-pricing-note">Not sure what affects the cost? <a href="/pricing">How repair pricing works</a></p>
      </div>

      <div class="ipad-hero-image-wrapper">
        <img
          src="/assets/hero-ipad-CGp2855O.png"
          alt="iPad repair in Winnipeg — screen and battery replacement specialists at Mobile Tech Lab"
          width="500"
          height="500"
          loading="eager"
        />
        <ul class="ipad-annotations-list" aria-label="Common iPad issues we fix">
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Cracked screen
          </li>
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            Battery draining fast
          </li>
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
            Charging port issues
          </li>
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Won't turn on
          </li>
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            Water damage
          </li>
          <li class="ipad-annotation">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
            Home button broken
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="ipad-services-section" id="services">
    <div class="ipad-container">
      <div class="ipad-section-header">
        <h2 class="ipad-section-title">iPad Repair Services in Winnipeg</h2>
        <p class="ipad-section-subtitle">Expert repairs for all iPad models. Fast turnaround, quality parts, and warranty included.</p>
      </div>
      <div class="ipad-services-grid">
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ipad-service-title">Screen Replacement</h3>
          <p class="ipad-service-body">Cracked or unresponsive iPad screen? We handle fused LCD and digitizer assemblies for a factory-quality finish on all iPad models. Glass-only repairs are available for iPad Air and Mini to save money where the display beneath is undamaged. iPad Pro screens use ProMotion OLED panels that require precision tools and model-specific parts — we stock them for all current Pro generations.</p>
        </div>
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="ipad-service-title">Battery Replacement</h3>
          <p class="ipad-service-body">iPad dying at 20% or feeling sluggish during use? A fresh battery can add years to your device's lifespan. We replace batteries on all iPad models with quality cells and same-day turnaround. All battery replacements include a 90-day warranty.</p>
        </div>
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12H19M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="ipad-service-title">Charging Port Repair</h3>
          <p class="ipad-service-body">iPad not charging or connecting to your computer? We clean the port before recommending replacement — debris is a common culprit. If the port is damaged we perform microsoldering to restore the Lightning or USB-C connection on all iPad models.</p>
        </div>
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          </div>
          <h3 class="ipad-service-title">Liquid Damage Recovery</h3>
          <p class="ipad-service-body">Spilled liquid on your iPad? Our ultrasonic cleaning process gives your device the best chance of recovery. We perform component-level diagnostics to assess what can be salvaged and give you a full report before recommending any repair.</p>
        </div>
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="ipad-service-title">Software & Boot Issues</h3>
          <p class="ipad-service-body">iPad stuck on the Apple logo, boot looping, or showing a black screen? Our technicians perform advanced restores, DFU recovery, and data recovery for software-related failures. We diagnose the root cause before attempting any restore so your data has the best chance of being preserved.</p>
        </div>
        <div class="ipad-service-card">
          <div class="ipad-service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="ipad-service-title">Button & Sensor Repair</h3>
          <p class="ipad-service-body">Home button unresponsive, power button stuck, Touch ID not working, or Face ID failing? We repair and replace home buttons, power buttons, Touch ID sensors, and Face ID components across all iPad models. Button repairs are typically completed same-day.</p>
        </div>
      </div>
      <div class="ipad-section-cta">
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-cta-primary">
          Request Repair &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="ipad-models-section" id="models">
    <div class="ipad-container">
      <div class="ipad-section-header">
        <h2 class="ipad-section-title">All iPad Models We Repair in Winnipeg</h2>
        <p class="ipad-section-subtitle">From the original iPad through iPad Pro M4 — we repair every generation</p>
      </div>
      <div class="ipad-models-grid">
        <div class="ipad-model-card">
          <div class="ipad-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ipad-model-title">iPad Pro</h3>
          <p class="ipad-model-description">ProMotion OLED displays require precision tools and model-specific parts. We stock screens for all current and recent iPad Pro generations including M4 and M2 models.</p>
          <div class="ipad-model-pills">
            <span class="ipad-pill">iPad Pro 11-inch (M4)</span>
            <span class="ipad-pill">iPad Pro 13-inch (M4)</span>
            <span class="ipad-pill">iPad Pro 12.9-inch (6th Gen)</span>
            <span class="ipad-pill">iPad Pro 11-inch (4th Gen)</span>
            <span class="ipad-pill">iPad Pro 12.9-inch (5th Gen)</span>
            <span class="ipad-pill">All iPad Pro models</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ipad-model-card">
          <div class="ipad-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ipad-model-title">iPad Air & iPad mini</h3>
          <p class="ipad-model-description">Glass-only repairs available for iPad Air and Mini where the display beneath is undamaged — saving you money on the most common damage type. Battery and charging port repairs available same-day.</p>
          <div class="ipad-model-pills">
            <span class="ipad-pill">iPad Air 13-inch (M2)</span>
            <span class="ipad-pill">iPad Air 11-inch (M2)</span>
            <span class="ipad-pill">iPad Air (5th Gen)</span>
            <span class="ipad-pill">iPad Air (4th Gen)</span>
            <span class="ipad-pill">iPad mini (6th Gen)</span>
            <span class="ipad-pill">iPad mini (5th Gen)</span>
            <span class="ipad-pill">All Air & Mini models</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ipad-model-card">
          <div class="ipad-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ipad-model-title">Standard iPad</h3>
          <p class="ipad-model-description">The most affordable iPad to repair — standard iPad models use LCD displays with non-fused glass assemblies that are quicker and less expensive to replace than Pro or Air screens.</p>
          <div class="ipad-model-pills">
            <span class="ipad-pill">iPad (10th Gen)</span>
            <span class="ipad-pill">iPad (9th Gen)</span>
            <span class="ipad-pill">iPad (8th Gen)</span>
            <span class="ipad-pill">iPad (7th Gen)</span>
            <span class="ipad-pill">iPad (6th Gen)</span>
            <span class="ipad-pill">All standard iPad models</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-model-cta">
            Get Quote &rarr;
          </a>
        </div>
        <div class="ipad-model-card">
          <div class="ipad-model-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <h3 class="ipad-model-title">Legacy & Discontinued iPads</h3>
          <p class="ipad-model-description">Don't see your model? We service all iPad generations including older iPad Pro, Air, and mini models. Contact us to confirm parts availability for your specific generation.</p>
          <div class="ipad-model-pills">
            <span class="ipad-pill">iPad Pro (1st Gen)</span>
            <span class="ipad-pill">iPad Air (3rd Gen)</span>
            <span class="ipad-pill">iPad Air (2nd Gen)</span>
            <span class="ipad-pill">iPad mini (4th Gen)</span>
            <span class="ipad-pill">iPad mini (3rd Gen)</span>
            <span class="ipad-pill">All legacy models</span>
          </div>
          <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="ipad-model-cta">
            Get Quote &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="ipad-why-section" id="why-choose-us">
    <div class="ipad-container">
      <div class="ipad-section-header">
        <h2 class="ipad-section-title">The Mobile Tech Lab Advantage: Winnipeg's iPad Repair Experts</h2>
        <p class="ipad-section-subtitle">Why Winnipeg customers trust us with their iPads</p>
      </div>
      <div class="ipad-pillars-grid">
        <div class="ipad-pillar-card">
          <div class="ipad-pillar-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="ipad-pillar-title">Apple IRP Certified</h3>
          <p class="ipad-pillar-body">Mobile Tech Lab is an Apple Independent Repair Provider — giving us access to genuine Apple parts, official diagnostics, and specialized tools for iPad repair. This means your iPad is repaired to Apple's own quality standards without the Apple Store wait times.</p>
        </div>
        <div class="ipad-pillar-card">
          <div class="ipad-pillar-icon-wrapper">
