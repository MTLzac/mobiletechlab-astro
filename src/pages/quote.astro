---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Get a Free Repair Quote | Mobile Tech Lab";
const description = "Get a free, no-obligation repair quote for your phone, tablet, laptop, or game console. Fast turnaround, quality parts, and a 90-day warranty on all repairs.";
const canonical = "https://mobiletechlab.ca/quote";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 md:py-28">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-5 text-4xl font-bold tracking-tight md:text-5xl">
        Get a Free Repair Quote
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Tell us what device you have and what's wrong. We'll give you a quick, no-obligation quote with transparent pricing before we start any work.
      </p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Start Your Quote Online
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-3 text-center text-2xl font-bold md:text-3xl">How It Works</h2>
        <p class="mb-10 text-center text-muted-foreground">Getting your device repaired is simple and straightforward</p>
        <div class="grid gap-6 md:grid-cols-3">
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-card p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">1</div>
            <h3 class="mb-2 font-semibold">Submit Your Device Info</h3>
            <p class="text-sm text-muted-foreground">Fill out our quick online form with your device type, model, and the issue you're experiencing.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-card p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">2</div>
            <h3 class="mb-2 font-semibold">Receive Your Quote</h3>
            <p class="text-sm text-muted-foreground">Our team reviews your request and provides a transparent, no-obligation price estimate.</p>
          </div>
          <div class="flex flex-col items-center text-center rounded-lg border border-border bg-card p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary text-xl font-bold">3</div>
            <h3 class="mb-2 font-semibold">Drop Off or Mail In</h3>
            <p class="text-sm text-muted-foreground">Bring your device to our Winnipeg or Thompson location, or ship it to us using our mail-in repair service.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary/40 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-10 text-center text-2xl font-bold md:text-3xl">Contact Us Directly</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-lg border border-border bg-background p-6">
            <h3 class="mb-1 font-semibold text-lg">Winnipeg — St. Vital</h3>
            <p class="mb-3 text-sm text-muted-foreground">845 Dakota St #25, Winnipeg, MB R2M 5M3</p>
            <div class="space-y-1 text-sm text-muted-foreground mb-4">
              <p>Mon–Sat: 9AM – 7PM</p>
              <p>Sun: 12PM – 7PM</p>
            </div>
            <a href="tel:2045009757" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              (204) 500-9757
            </a>
          </div>
          <div class="rounded-lg border border-border bg-background p-6">
            <h3 class="mb-1 font-semibold text-lg">Thompson</h3>
            <p class="mb-3 text-sm text-muted-foreground">300 Mystery Lake Rd #1530, Thompson, MB R8N 0M2</p>
            <div class="space-y-1 text-sm text-muted-foreground mb-4">
              <p>Mon–Sat: 10AM – 6PM</p>
              <p>Sun: Closed</p>
            </div>
            <a href="tel:2044100262" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              (204) 410-0262
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-primary/5 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="mb-3 text-2xl font-bold md:text-3xl">Ready to Get Started?</h2>
      <p class="mb-8 text-muted-foreground">Submit your repair request online and we'll get back to you quickly with a price.</p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
