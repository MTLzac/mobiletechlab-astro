---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Contact Us | Mobile Tech Lab Winnipeg & Thompson";
const description = "Contact Mobile Tech Lab for device repair in Winnipeg and Thompson, Manitoba. Call us, visit our stores, or get a free online quote. Walk-ins welcome!";
const canonical = "https://mobiletechlab.ca/contact";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <section class="bg-gradient-to-b from-secondary/50 to-background py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl">Contact Mobile Tech Lab</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Get in touch with Manitoba's trusted device repair specialists. Visit us in-store or get a free quote online.
      </p>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
      </a>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-3xl font-bold">Our Locations</h2>
        <p class="text-muted-foreground">Two convenient locations serving Winnipeg and Northern Manitoba</p>
      </div>

      <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">

        <div class="relative overflow-hidden rounded-lg border border-border bg-card">
          <div class="absolute right-4 top-4">
            <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">PRIMARY</span>
          </div>
          <div class="p-6">
            <div class="mb-4 flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <h3 class="mb-1 text-xl font-semibold">St. Vital Location</h3>
                <p class="text-muted-foreground">845 Dakota St #25, Winnipeg, MB R2M 5M3</p>
              </div>
            </div>

            <div class="mb-4 flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:2045009757" class="text-lg font-medium hover:text-primary transition-colors">(204) 500-9757</a>
            </div>

            <div class="mb-6 flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div class="text-muted-foreground">
                <p>Mon–Sat: 9AM – 7PM</p>
                <p>Sun: 12PM – 7PM</p>
              </div>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row">
              <a href="tel:2045009757" class="flex flex-1 items-center justify-center gap-2 rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Call Now
              </a>
              <a href="https://maps.google.com/?q=845+Dakota+St+25+Winnipeg+MB+R2M+5M3" target="_blank" rel="noopener noreferrer" class="flex flex-1 items-center justify-center gap-2 rounded-md border border-input bg-background px-4 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                Get Directions
              </a>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-border bg-card">
          <div class="p-6">
            <div class="mb-4 flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <h3 class="mb-1 text-xl font-semibold">Thompson Location</h3>
                <p class="text-muted-foreground">300 Mystery Lake Rd #1530, Thompson, MB R8N 0M2</p>
              </div>
            </div>

            <div class="mb-4 flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:2044100262" class="text-lg font-medium hover:text-primary transition-colors">(204) 410-0262</a>
            </div>

            <div class="mb-6 flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div class="text-muted-foreground">
                <p>Mon–Sat: 10AM – 6PM</p>
                <p>Sun: Closed</p>
              </div>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row">
              <a href="tel:2044100262" class="flex flex-1 items-center justify-center gap-2 rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Call Now
              </a>
              <a href="https://maps.google.com/?q=300+Mystery+Lake+Rd+1530+Thompson+MB+R8N+0M2" target="_blank" rel="noopener noreferrer" class="flex flex-1 items-center justify-center gap-2 rounded-md border border-input bg-background px-4 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                Get Directions
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-2xl rounded-lg border border-primary/20 bg-gradient-to-br from-primary/5 to-transparent p-8 text-center">
        <h2 class="mb-3 text-2xl font-bold">Prefer to Get a Quote Online?</h2>
        <p class="mb-6 text-muted-foreground">
          Use our repair widget for instant pricing on your device repair. No appointment needed — walk-ins are always welcome!
        </p>
        <a
          href="https://shop.mobiletechlab.ca/pages/repair2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Start Your Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-secondary/30 py-16">
    <div class="container mx-auto px-4">
      <div class="mb-8 text-center">
        <h2 class="mb-3 text-2xl font-bold">Find Us on the Map</h2>
        <p class="text-muted-foreground">Visit us at either of our convenient Manitoba locations</p>
      </div>
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2">

        <div class="overflow-hidden rounded-lg border border-border bg-card shadow-sm">
          <div class="border-b bg-muted/50 px-4 py-3">
            <h3 class="font-semibold">St. Vital Location</h3>
          </div>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2573.0896367686387!2d-97.10548882318454!3d49.85899357148345!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x52ea75c3a16e3141%3A0x5aee2e35bcc25930!2sMobile%20Tech%20Lab%20St.%20Vital!5e0!3m2!1sen!2sca!4v1704400000000!5m2!1sen!2sca"
            width="100%"
            height="300"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mobile Tech Lab St. Vital Location"
            class="w-full border-0"
          ></iframe>
        </div>

        <div class="overflow-hidden rounded-lg border border-border bg-card shadow-sm">
          <div class="border-b bg-muted/50 px-4 py-3">
            <h3 class="font-semibold">Thompson Location</h3>
          </div>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2341.8442533087883!2d-97.83205152298!3d55.74447997312!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x52608b6e5c2b6e5d%3A0x1234567890abcdef!2s300%20Mystery%20Lake%20Rd%20%231530%2C%20Thompson%2C%20MB%20R8N%200M2!5e0!3m2!1sen!2sca!4v1704400000000!5m2!1sen!2sca"
            width="100%"
            height="300"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mobile Tech Lab Thompson Location"
            class="w-full border-0"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
