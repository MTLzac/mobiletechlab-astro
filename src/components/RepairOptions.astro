---
---

<section class="bg-gray-50 py-20 px-6" id="repair-options-section">
  <div class="max-w-5xl mx-auto text-center">

    <h2 class="font-bold text-4xl text-gray-900">
      Worried About Repair Cost?<span class="text-red-500"> You Have Options.</span>
    </h2>
    <p class="text-gray-500 text-sm mt-3">Most customers use one of these options to lower their repair cost.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10 text-left">

      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50 mb-5" aria-label="Shield icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl text-gray-900 mb-3">We'll Match Any Local Repair Price</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Found a lower price at another Winnipeg repair shop? We'll match it — so you don't overpay. No pressure. No hassle.</p>
        </div>
        <a
          href="sms:2045009757?body=Hey%20Mobile%20Tech%20Lab!%20I%20want%20a%20better%20price%20on%20a%20repair!"
          class="border border-gray-300 rounded-lg px-4 py-3 text-sm font-medium text-gray-800 flex items-center gap-2 hover:bg-gray-100 transition w-full justify-center mt-6"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Check If We Can Match Your Price
        </a>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50 mb-5" aria-label="Trade-in icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
              <path d="M21 3v5h-5"/>
              <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
              <path d="M3 21v-5h5"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl text-gray-900 mb-3">Lower Your Repair Cost With a Trade-In</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Trade in phones, tablets, consoles, or laptops — even broken ones — to reduce today's repair cost.</p>
          <p class="text-xs text-gray-400 mt-2">Get paid via Cash, E-Transfer, or Store Credit</p>
        </div>
        <a
          href="/trade-in"
          class="border border-red-200 bg-red-50 rounded-lg px-4 py-3 text-sm font-medium text-red-500 flex items-center justify-center gap-2 hover:bg-red-100 transition w-full mt-6"
        >
          Lower My Repair Cost &rarr;
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Section background */
  #repair-options-section {
    background: linear-gradient(135deg, #fff5f5 0%, #ffffff 50%, #fff5f5 100%);
  }

  /* Card resting state */
  #repair-options-section .grid > div {
    border: 1px solid #fde8e8;
    border-left: 4px solid #ef4444;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(239, 68, 68, 0.07);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  /* Card hover */
  #repair-options-section .grid > div:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(239, 68, 68, 0.13);
  }

  /* Icon wrapper */
  #repair-options-section .grid > div > div:first-child > div:first-child {
    background-color: #fff1f1;
    border-radius: 10px;
    padding: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: background-color 0.2s ease;
  }

  /* Icon colour */
  #repair-options-section .grid > div > div:first-child > div:first-child svg {
    color: #ef4444;
    stroke: #ef4444;
    width: 22px;
    height: 22px;
  }

  /* Icon wrapper hover */
  #repair-options-section .grid > div:hover > div:first-child > div:first-child {
    background-color: #fecaca;
  }

  /* Ghost / price-match button (SMS) */
  #repair-options-section .grid > div:first-child > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 20px;
    border: 1.5px solid #d1d5db;
    border-radius: 10px;
    background: #ffffff;
    color: #374151;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  #repair-options-section .grid > div:first-child > a:hover {
    border-color: #ef4444;
    color: #ef4444;
    box-shadow: 0 2px 12px rgba(239, 68, 68, 0.1);
  }

  /* Trade-in button */
  #repair-options-section .grid > div:last-child > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 20px;
    border: 1.5px solid #fca5a5;
    border-radius: 10px;
    background: #fff1f1;
    color: #ef4444;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    cursor: pointer;
  }

  #repair-options-section .grid > div:last-child > a:hover {
    background-color: #fee2e2;
    border-color: #ef4444;
    box-shadow: 0 4px 16px rgba(239, 68, 68, 0.18);
    transform: translateY(-1px);
  }
</style>
