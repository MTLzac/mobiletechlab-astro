---
---

<section class="bg-gray-50 py-20 px-6">
  <div class="max-w-5xl mx-auto text-center">

    <h2 class="font-bold text-4xl text-gray-900">
      Worried About Repair Cost?<span class="text-red-500"> You Have Options.</span>
    </h2>
    <p class="text-gray-500 text-sm mt-3">Most customers use one of these options to lower their repair cost.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10 text-left">

      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50 mb-5" aria-label="Shield icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl text-gray-900 mb-3">We'll Match Any Local Repair Price</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Found a lower price at another Winnipeg repair shop? We'll match it — so you don't overpay. No pressure. No hassle.</p>
        </div>
        <a
          href="sms:2045009757?body=Hey%20Mobile%20Tech%20Lab!%20I%20want%20a%20better%20price%20on%20a%20repair!"
          class="border border-gray-300 rounded-lg px-4 py-3 text-sm font-medium text-gray-800 flex items-center gap-2 hover:bg-gray-100 transition w-full justify-center mt-6"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Check If We Can Match Your Price
        </a>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50 mb-5" aria-label="Trade-in icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
              <path d="M21 3v5h-5"/>
              <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
              <path d="M3 21v-5h5"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl text-gray-900 mb-3">Lower Your Repair Cost With a Trade-In</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Trade in phones, tablets, consoles, or laptops — even broken ones — to reduce today's repair cost.</p>
          <p class="text-xs text-gray-400 mt-2">Get paid via Cash, E-Transfer, or Store Credit</p>
        </div>
        <a
          href="/trade-in"
          class="border border-red-200 bg-red-50 rounded-lg px-4 py-3 text-sm font-medium text-red-500 flex items-center justify-center gap-2 hover:bg-red-100 transition w-full mt-6"
        >
          Lower My Repair Cost &rarr;
        </a>
      </div>

    </div>
  </div>
</section>
