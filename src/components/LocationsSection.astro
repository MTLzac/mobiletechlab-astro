</section>

<style>
  .locations-section {
    width: 100%;
    background: linear-gradient(135deg, #fff5f5 0%, #ffffff 50%, #fff5f5 100%);
    padding: 80px 24px;
  }

  .locations-wrapper {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .locations-heading {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #111827;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .locations-subheading {
    font-size: 15px;
    color: #6b7280;
    margin: 0 0 48px 0;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    text-align: left;
  }

  .location-card {
    background: #ffffff;
    border: 1px solid #fde8e8;
    border-left: 4px solid #ef4444;
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
    box-shadow: 0 2px 16px rgba(239, 68, 68, 0.07);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .location-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(239, 68, 68, 0.13);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .location-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #fff5f5;
    border: 1px solid #fde8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #ef4444;
  }

  .location-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
    line-height: 1.3;
  }

  .location-address {
    display: block;
    font-size: 13.5px;
    color: #6b7280;
    text-decoration: none;
    margin-bottom: 20px;
    line-height: 1.5;
    transition: color 0.15s ease;
  }

  .location-address:hover {
    color: #ef4444;
  }

  .location-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }

  .btn-call,
  .btn-map {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .btn-call {
    background-color: #ef4444;
    color: #ffffff;
    border: 1.5px solid #ef4444;
  }

  .btn-call:hover {
    background-color: #dc2626;
    border-color: #dc2626;
  }

  .btn-map {
    background-color: #ffffff;
    color: #374151;
    border: 1.5px solid #e5e7eb;
  }

  .btn-map:hover {
    border-color: #ef4444;
    color: #ef4444;
  }

  .location-note {
    font-size: 12px;
    color: #9ca3af;
    margin: 0;
    text-align: center;
  }

  @media (max-width: 768px) {
    .locations-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
