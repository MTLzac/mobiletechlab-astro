---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur-sm"
  x-data="{ mobileOpen: false }"
>
  <div class="container mx-auto flex h-16 items-center justify-between px-4">

    <a href="/" class="flex shrink-0 items-center">
      <img src="/assets/logo-CFQZ0lrl.png" alt="Mobile Tech Lab" class="h-10 w-auto" />
    </a>

    <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1 text-sm font-medium">

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 transition-colors"
          style="background-color: #e8472a; color: #ffffff;"
        >
          <a href="/repairs" class="outline-none" style="color: inherit;">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 rounded-lg border border-border bg-background shadow-xl"
          style="width: 500px;"
          role="menu"
        >
          <div class="border-b border-border px-5 py-3">
            <a href="/repairs" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline" role="menuitem">
              <svg xmlns="http://www.w3.org/2000/svg" style="height:14px;width:14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              View All Repair Services
            </a>
          </div>

          <div class="grid grid-cols-3 gap-0 p-5">
            <div class="pr-5">
              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>
                Phone Repairs
              </p>
              <ul class="space-y-2">
                {repairs.phones.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>

            <div class="border-x border-border px-5">
              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="22" y2="22"/><line x1="12" x2="12" y1="18" y2="22"/></svg>
                Tablets
              </p>
              <ul class="space-y-2 mb-6">
                {repairs.tablets.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>

              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
                Computers
              </p>
              <ul class="space-y-2">
                {repairs.computers.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>

            <div class="pl-5">
              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 11a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v5H6v-5Z"/><path d="M10 7V5a2 2 0 0 1 4 0v2"/><rect x="2" y="16" width="20" height="4" rx="1"/><path d="M8 16v-1"/><path d="M16 16v-1"/></svg>
                Gaming Consoles
              </p>
              <ul class="space-y-2 mb-6">
                {repairs.gaming.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>

              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
                Other Devices
              </p>
              <ul class="space-y-2 mb-6">
                {repairs.otherDevices.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>

              <p class="mb-2.5 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                Specialty Repairs
              </p>
              <ul class="space-y-2">
                {repairs.specialty.map(l => (
                  <li><a href={l.href} class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
