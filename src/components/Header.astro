    { label: 'Google Pixel', href: '/repair/google-pixel' },
    { label: 'Motorola', href: '/repair/motorola' },
    { label: 'OnePlus', href: '/repair/google-pixel' },
    { label: 'LG', href: '/repair/google-pixel' },
    { label: 'Huawei', href: '/repair/google-pixel' },
    { label: 'Xiaomi', href: '/repair/google-pixel' },
    { label: 'Oppo', href: '/repair/google-pixel' },
    { label: 'Nothing', href: '/repair/google-pixel' },
