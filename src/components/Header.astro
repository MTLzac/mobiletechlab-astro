        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 w-52 rounded-lg border border-border bg-background p-3 shadow-xl"
          role="menu"
        >
          <ul class="space-y-1">
            {devices.map(l => (
              <li><a href={l.href} class="block rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors" role="menuitem">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 rounded-lg border border-border bg-background shadow-xl"
          style="width: 360px;"
          role="menu"
        >
          <div class="grid grid-cols-2 gap-0 p-5">
            <div class="pr-5">
              <p class="mb-3 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Physical Stores
              </p>
              <ul class="space-y-2.5">
                <li><a href="/location/winnipeg" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Winnipeg (St. Vital), MB</a></li>
                <li><a href="/location/thompson" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Thompson, MB</a></li>
              </ul>
            </div>

            <div class="border-l border-border pl-5">
              <p class="mb-3 flex items-center gap-1.5 text-xs font-semibold text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:13px;width:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                Mail-In Service Areas
              </p>
              <ul class="space-y-2.5">
                <li><a href="/service-area/steinbach" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Steinbach, MB</a></li>
                <li><a href="/service-area/brandon" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Brandon, MB</a></li>
                <li><a href="/service-area/portage-la-prairie" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Portage la Prairie, MB</a></li>
                <li><a href="/service-area/selkirk" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">Selkirk, MB</a></li>
                <li><a href="/service-area/the-pas" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">The Pas, MB</a></li>
                <li><a href="/service-areas" class="text-sm text-foreground hover:text-primary transition-colors" role="menuitem">More Areas</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <a href="/trade-in" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Trade In</a>
      <a href="/contact" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Contact</a>

    </nav>

    <div class="hidden md:flex items-center gap-2">
      <a
        href="tel:2045009757"
        class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (204) 500-9757
      </a>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get Quote
      </a>
    </div>

    <button
      class="lg:hidden flex h-10 w-10 items-center justify-center rounded-md hover:bg-accent transition-colors"
      @click="mobileOpen = !mobileOpen"
      :aria-expanded="mobileOpen"
      aria-label="Toggle navigation menu"
    >
      <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg x-show="mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

  </div>

  <div
    x-show="mobileOpen"
    class="lg:hidden border-t border-border bg-background pb-4"
    @click.away="mobileOpen = false"
  >
    <div class="container mx-auto space-y-1 px-4 pt-3">

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          <a href="/repairs" class="outline-none">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          <a href="/repairs" class="block rounded-md px-2 py-1.5 text-sm font-medium text-primary hover:bg-accent transition-colors">View All Repair Services</a>
          <p class="pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phone Repairs</p>
          {repairs.phones.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets</p>
          {repairs.tablets.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Computers</p>
          {repairs.computers.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming Consoles</p>
          {repairs.gaming.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Other Devices</p>
          {repairs.otherDevices.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Specialty Repairs</p>
          {repairs.specialty.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
        </div>
      </div>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
