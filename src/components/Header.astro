---
const repairs = {
  phones: [
    { label: 'iPhone Repair', href: '/repair/iphone' },
    { label: 'Samsung Repair', href: '/repair/samsung' },
    { label: 'Google Pixel', href: '/repair/google-pixel' },
    { label: 'Motorola', href: '/repair/motorola' },
    { label: 'TCL', href: '/repair/tcl' },
  ],
  tablets: [
    { label: 'iPad Repair', href: '/repair/ipad' },
    { label: 'Samsung Galaxy Tab', href: '/repair/samsung-galaxy-tab' },
    { label: 'MacBook Repair', href: '/repair/macbook' },
    { label: 'Laptop Repair', href: '/repair/laptop' },
    { label: 'Surface Repair', href: '/repair/surface' },
  ],
  gaming: [
    { label: 'PS5 Repair', href: '/repair/ps5' },
    { label: 'PS4 Repair', href: '/repair/ps4' },
    { label: 'Xbox Repair', href: '/repair/xbox' },
    { label: 'Nintendo Switch', href: '/repair/nintendo-switch' },
    { label: 'Steam Deck', href: '/repair/steam-deck' },
  ],
  other: [
    { label: 'Apple Watch', href: '/repair/apple-watch' },
    { label: 'Water Damage', href: '/repair/water-damage' },
    { label: 'Controller Repair', href: '/repair/controller-repair-winnipeg' },
    { label: 'All Repairs', href: '/repairs' },
  ],
};

const devices = [
  { label: 'iPhone 11 Pro', href: '/devices/iphone-11-pro' },
  { label: 'iPhone 11', href: '/devices/iphone-11' },
  { label: 'iPhone XS Max', href: '/devices/iphone-xs-max' },
  { label: 'iPhone XS', href: '/devices/iphone-xs' },
  { label: 'iPhone XR', href: '/devices/iphone-xr' },
];

const locations = [
  { label: 'Winnipeg', href: '/location/winnipeg' },
  { label: 'Thompson', href: '/location/thompson' },
  { label: 'Brandon', href: '/service-area/brandon' },
  { label: 'Selkirk', href: '/service-area/selkirk' },
  { label: 'Steinbach', href: '/service-area/steinbach' },
  { label: 'Portage la Prairie', href: '/service-area/portage-la-prairie' },
  { label: 'The Pas', href: '/service-area/the-pas' },
  { label: 'All Service Areas', href: '/service-areas' },
];
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur-sm"
  x-data="{ mobileOpen: false }"
>
  <div class="container mx-auto flex h-16 items-center justify-between px-4">

    <a href="/" class="flex shrink-0 items-center">
      <img src="/assets/logo-CFQZ0lrl.png" alt="Mobile Tech Lab" class="h-10 w-auto" />
    </a>

    <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1 text-sm font-medium">

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          <a href="/repairs" class="outline-none">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 w-[720px] rounded-lg border border-border bg-background p-6 shadow-xl"
          role="menu"
        >
          <div class="grid grid-cols-4 gap-6">
            <div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phones</p>
              <ul class="space-y-2">
                {repairs.phones.map(l => (
                  <li><a href={l.href} class="text-sm hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets &amp; Computers</p>
              <ul class="space-y-2">
                {repairs.tablets.map(l => (
                  <li><a href={l.href} class="text-sm hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming</p>
              <ul class="space-y-2">
                {repairs.gaming.map(l => (
                  <li><a href={l.href} class="text-sm hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Other</p>
              <ul class="space-y-2">
                {repairs.other.map(l => (
                  <li><a href={l.href} class="text-sm hover:text-primary transition-colors" role="menuitem">{l.label}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          Devices
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 w-52 rounded-lg border border-border bg-background p-3 shadow-xl"
          role="menu"
        >
          <ul class="space-y-1">
            {devices.map(l => (
              <li><a href={l.href} class="block rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors" role="menuitem">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 w-56 rounded-lg border border-border bg-background p-3 shadow-xl"
          role="menu"
        >
          <ul class="space-y-1">
            {locations.map(l => (
              <li><a href={l.href} class="block rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors" role="menuitem">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/trade-in" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Trade In</a>
      <a href="/contact" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Contact</a>

    </nav>

    <div class="hidden md:flex items-center gap-2">
      <a
        href="tel:2045009757"
        class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (204) 500-9757
      </a>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get Quote
      </a>
    </div>

    <button
      class="lg:hidden flex h-10 w-10 items-center justify-center rounded-md hover:bg-accent transition-colors"
      @click="mobileOpen = !mobileOpen"
      :aria-expanded="mobileOpen"
      aria-label="Toggle navigation menu"
    >
      <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg x-show="mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

  </div>

  <div
    x-show="mobileOpen"
    class="lg:hidden border-t border-border bg-background pb-4"
    @click.away="mobileOpen = false"
  >
    <div class="container mx-auto space-y-1 px-4 pt-3">

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          <a href="/repairs" class="outline-none">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          <p class="pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phones</p>
          {repairs.phones.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets &amp; Computers</p>
          {repairs.tablets.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming</p>
          {repairs.gaming.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Other</p>
          {repairs.other.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
        </div>
      </div>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          Devices
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          {devices.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
        </div>
      </div>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          {locations.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
        </div>
      </div>

      <a href="/trade-in" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Trade In</a>
      <a href="/contact" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Contact</a>

      <div class="flex flex-col gap-2 pt-3">
        <a href="tel:2045009757" class="flex items-center justify-center gap-2 rounded-md border border-input px-4 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
          Get a Quote
        </a>
      </div>

    </div>
  </div>

</header>

<script>
  import Alpine from 'alpinejs';
  if (!window.Alpine) {
    window.Alpine = Alpine;
    Alpine.start();
  }
</script>
