---
import RepairsMegaMenu from './RepairsMegaMenu.astro';

const devices = [
  { label: 'iPhone 11 Pro', href: '/devices/iphone-11-pro' },
  { label: 'iPhone 11', href: '/devices/iphone-11' },
  { label: 'iPhone XS Max', href: '/devices/iphone-xs-max' },
  { label: 'iPhone XS', href: '/devices/iphone-xs' },
  { label: 'iPhone XR', href: '/devices/iphone-xr' },
];

const physicalLocations = [
  { label: 'Winnipeg (St. Vital), MB', href: '/location/winnipeg', mapsHref: 'https://maps.google.com/?q=Mobile+Tech+Lab+Winnipeg+St+Vital' },
  { label: 'Thompson, MB', href: '/location/thompson', mapsHref: 'https://maps.google.com/?q=Mobile+Tech+Lab+Thompson+MB' },
];

const serviceAreas = [
  { label: 'Steinbach, MB', href: '/service-area/steinbach' },
  { label: 'Brandon, MB', href: '/service-area/brandon' },
  { label: 'Portage la Prairie, MB', href: '/service-area/portage-la-prairie' },
  { label: 'Selkirk, MB', href: '/service-area/selkirk' },
  { label: 'The Pas, MB', href: '/service-area/the-pas' },
];

const mobileLocations = [
  { label: 'Winnipeg', href: '/location/winnipeg' },
  { label: 'Thompson', href: '/location/thompson' },
  { label: 'Brandon', href: '/service-area/brandon' },
  { label: 'Selkirk', href: '/service-area/selkirk' },
  { label: 'Steinbach', href: '/service-area/steinbach' },
  { label: 'Portage la Prairie', href: '/service-area/portage-la-prairie' },
  { label: 'The Pas', href: '/service-area/the-pas' },
  { label: 'All Service Areas', href: '/service-areas' },
];
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background"
  x-data="{ mobileOpen: false }"
>
  <div class="container mx-auto flex h-16 items-center justify-between px-4">

    <a href="/" class="flex shrink-0 items-center">
      <img src="/assets/logo-CFQZ0lrl.png" alt="Mobile Tech Lab" class="h-10 w-auto" />
    </a>

    <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1 text-sm font-medium">

      <!-- Repairs mega menu -->
      <RepairsMegaMenu />

      <!-- Locations mega menu -->
      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          :aria-expanded="open"
          class="flex items-center gap-1 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-1"
          @click.away="open = false"
          class="absolute left-0 top-full mt-1 rounded-lg border border-border bg-white shadow-xl"
          style="width: 440px; z-index: 9999;"
          role="menu"
        >
          <div class="grid grid-cols-2 p-5 gap-x-0">

            <!-- Physical Stores -->
            <div class="pr-5 border-r border-border">
              <p class="mb-3 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Physical Stores
              </p>

              {physicalLocations.map(loc => (
                <div class="mb-3 last:mb-0">
                  <a href={loc.href} class="block text-sm font-medium text-foreground hover:text-primary transition-colors">{loc.label}</a>
                  <a href={loc.mapsHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-0.5 text-xs text-muted-foreground hover:text-primary transition-colors mt-0.5">
                    Get Directions
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                </div>
              ))}
            </div>

            <!-- Mail-In Service Areas -->
            <div class="pl-5">
              <p class="mb-3 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Mail-In Service Areas
              </p>

              <ul class="space-y-1.5">
                {serviceAreas.map(area => (
                  <li>
                    <a href={area.href} class="block text-sm text-foreground hover:text-primary transition-colors" role="menuitem">{area.label}</a>
                  </li>
                ))}
              </ul>

              <a href="/service-areas" class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline mt-3">
                View All Service Areas
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>

          </div>
        </div>
      </div>

      <a href="/trade-in" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Trade In</a>
      <a href="https://shop.mobiletechlab.ca" target="_blank" rel="noopener noreferrer" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Shop</a>
      <a href="/contact" class="rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground transition-colors">Contact</a>

    </nav>

    <div class="hidden md:flex items-center gap-2">
      <a
        href="tel:2045009757"
        class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (204) 500-9757
      </a>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get Quote
      </a>
    </div>

    <button
      class="lg:hidden flex h-10 w-10 items-center justify-center rounded-md hover:bg-accent transition-colors"
      @click="mobileOpen = !mobileOpen"
      :aria-expanded="mobileOpen"
      aria-label="Toggle navigation menu"
    >
      <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg x-show="mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

  </div>

  <!-- Mobile menu -->
  <div
    x-show="mobileOpen"
    class="lg:hidden border-t border-border bg-background pb-4"
    @click.away="mobileOpen = false"
  >
    <div class="container mx-auto space-y-1 px-4 pt-3">

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          <a href="/repairs" class="outline-none">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          <a href="/repairs" class="block rounded-md px-2 py-1.5 text-sm font-medium text-primary hover:bg-accent transition-colors">View All Repair Services</a>
          <p class="pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phone Repairs</p>
          <a href="/repairs/iphone" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">iPhone</a>
          <a href="/repairs/samsung" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Samsung</a>
          <a href="/repairs/google-pixel" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Google Pixel</a>
          <a href="/repairs/motorola" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Motorola</a>
          <a href="/repairs/oneplus" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">OnePlus</a>
          <a href="/repairs/lg" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">LG</a>
          <a href="/repairs/huawei" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Huawei</a>
          <a href="/repairs/xiaomi" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Xiaomi</a>
          <a href="/repairs/oppo" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Oppo</a>
          <a href="/repairs/nothing" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Nothing</a>
          <a href="/repairs/infinix" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Infinix</a>
          <a href="/repairs/tcl" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">TCL</a>
          <a href="/repairs/zte" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">ZTE</a>
          <a href="/repairs/blackberry" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Blackberry</a>
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets</p>
          <a href="/repairs/ipad" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">iPad</a>
          <a href="/repairs/galaxy-tab" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Galaxy Tab</a>
          <a href="/repairs/kindle-fire" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Amazon Kindle/Fire</a>
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Computers</p>
          <a href="/repairs/macbook" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">MacBook</a>
          <a href="/repairs/microsoft-surface" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Microsoft Surface</a>
          <a href="/repairs/laptop" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Laptop Repair</a>
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming Consoles</p>
          <a href="/repairs/consoles" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">All Console Repairs</a>
          <a href="/repairs/nintendo-switch" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Nintendo Switch</a>
          <a href="/repairs/playstation-5" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">PlayStation 5</a>
          <a href="/repairs/playstation-4" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">PlayStation 4</a>
          <a href="/repairs/xbox" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Xbox</a>
          <a href="/repairs/steam-deck" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Steam Deck</a>
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Other Devices</p>
          <a href="/repairs/apple-watch" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Apple Watch</a>
          <a href="/repairs/ipod" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">iPod</a>
          <a href="/repairs/water-damage" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">Water Damage</a>
          <p class="pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Specialty Repairs</p>
          <a href="/repairs/cat-s62-charging-port" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">CAT S62 Charging Port</a>
          <a href="/repairs/blackmagic-hdmi" class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">BlackMagic HDMI</a>
        </div>
      </div>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="ml-4 mt-1 space-y-1 border-l border-border pl-4">
          {mobileLocations.map(l => (
            <a href={l.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{l.label}</a>
          ))}
        </div>
      </div>

      <a href="/trade-in" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Trade In</a>
      <a href="https://shop.mobiletechlab.ca" target="_blank" rel="noopener noreferrer" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Shop</a>
      <a href="/contact" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Contact</a>

      <div class="flex flex-col gap-2 pt-3">
        <a href="tel:2045009757" class="flex items-center justify-center gap-2 rounded-md border border-input px-4 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
          Get a Quote
        </a>
      </div>

    </div>
  </div>

</header>

<script>
  import Alpine from 'alpinejs';
  if (!window.Alpine) {
    window.Alpine = Alpine;
    Alpine.start();
  }
</script>
