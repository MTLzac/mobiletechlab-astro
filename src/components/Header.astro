---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Business', href: '/business' },
  { label: 'Trade-In', href: '/trade-in' },
  { label: 'Pre-Owned', href: 'https://shop.mobiletechlab.ca', external: true },
  { label: 'Contact', href: '/contact' },
];

const repairsMenu = {
  phones: [
    { label: 'iPhone Repair', href: '/repair/iphone' },
    { label: 'Samsung Repair', href: '/repair/samsung' },
    { label: 'Google Pixel', href: '/repair/google-pixel' },
    { label: 'Motorola', href: '/repair/motorola' },
    { label: 'LG Repair', href: '/repair/lg' },
    { label: 'Huawei', href: '/repair/huawei' },
    { label: 'OnePlus', href: '/repair/oneplus' },
    { label: 'Sony Xperia', href: '/repair/sony-xperia' },
  ],
  tablets: [
    { label: 'iPad Repair', href: '/repair/ipad' },
    { label: 'Samsung Galaxy Tab', href: '/repair/samsung-galaxy-tab' },
    { label: 'Surface Repair', href: '/repair/surface' },
    { label: 'MacBook Repair', href: '/repair/macbook' },
    { label: 'Laptop Repair', href: '/repair/laptop' },
  ],
  gaming: [
    { label: 'PS5 Repair', href: '/repair/ps5' },
    { label: 'PS4 Repair', href: '/repair/ps4' },
    { label: 'Xbox Repair', href: '/repair/xbox' },
    { label: 'Nintendo Switch', href: '/repair/nintendo-switch' },
    { label: 'Steam Deck', href: '/repair/steam-deck' },
    { label: 'Apple Watch', href: '/repair/apple-watch' },
    { label: 'Water Damage', href: '/repair/water-damage' },
  ],
};

const locationsMenu = [
  { label: 'Winnipeg — St. Vital', href: '/location/winnipeg' },
  { label: 'Thompson', href: '/location/thompson' },
];
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur-sm"
  x-data="{ mobileOpen: false }"
>
  <div class="container mx-auto flex h-16 items-center justify-between px-4">

    <a href="/" class="flex items-center shrink-0">
      <img src="/assets/logo-CFQZ0lrl.png" alt="Mobile Tech Lab" class="h-10 w-auto" />
    </a>

    <nav aria-label="Main" class="hidden lg:flex items-center space-x-1 text-sm font-medium">

      <a href="/" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Home</a>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          class="flex items-center gap-1 px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors"
          :aria-expanded="open"
        >
          <a href="/repairs">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          class="absolute left-0 top-full mt-1 w-[680px] rounded-lg border border-border bg-background shadow-xl p-6 grid grid-cols-3 gap-6"
          @click.away="open = false"
        >
          <div>
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phones</h3>
            <ul class="space-y-2">
              {repairsMenu.phones.map(link => (
                <li><a href={link.href} class="text-sm hover:text-primary transition-colors">{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets &amp; Computers</h3>
            <ul class="space-y-2">
              {repairsMenu.tablets.map(link => (
                <li><a href={link.href} class="text-sm hover:text-primary transition-colors">{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming &amp; More</h3>
            <ul class="space-y-2">
              {repairsMenu.gaming.map(link => (
                <li><a href={link.href} class="text-sm hover:text-primary transition-colors">{link.label}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
        <button
          @click="open = !open"
          class="flex items-center gap-1 px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors"
          :aria-expanded="open"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          x-show="open"
          class="absolute left-0 top-full mt-1 w-56 rounded-lg border border-border bg-background shadow-xl p-3"
          @click.away="open = false"
        >
          <ul class="space-y-1">
            {locationsMenu.map(link => (
              <li><a href={link.href} class="block rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      {navLinks.filter(l => !['Home'].includes(l.label)).map(link => (
        link.external
          ? <a href={link.href} target="_blank" rel="noopener noreferrer" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">{link.label}</a>
          : <a href={link.href} class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">{link.label}</a>
      ))}

    </nav>

    <div class="hidden md:flex items-center gap-2">
      <a
        href="tel:2045009757"
        class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (204) 500-9757
      </a>
      <a
        href="https://shop.mobiletechlab.ca/pages/repair2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        Get Quote
      </a>
    </div>

    <button
      class="lg:hidden flex items-center justify-center h-10 w-10 rounded-md hover:bg-accent transition-colors"
      @click="mobileOpen = !mobileOpen"
      :aria-expanded="mobileOpen"
      aria-label="Toggle menu"
    >
      <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg x-show="mobileOpen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

  </div>

  <div
    x-show="mobileOpen"
    class="lg:hidden border-t border-border bg-background pb-4"
    @click.away="mobileOpen = false"
  >
    <div class="container mx-auto px-4 pt-4 space-y-1">

      <a href="/" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Home</a>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          <a href="/repairs">Repairs</a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="mt-1 ml-4 space-y-1 border-l border-border pl-4">
          <p class="py-1 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Phones</p>
          {repairsMenu.phones.map(link => (
            <a href={link.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{link.label}</a>
          ))}
          <p class="pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Tablets &amp; Computers</p>
          {repairsMenu.tablets.map(link => (
            <a href={link.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{link.label}</a>
          ))}
          <p class="pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Gaming &amp; More</p>
          {repairsMenu.gaming.map(link => (
            <a href={link.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{link.label}</a>
          ))}
        </div>
      </div>

      <div x-data="{ open: false }">
        <button
          @click="open = !open"
          class="flex w-full items-center justify-between rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          Locations
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div x-show="open" class="mt-1 ml-4 space-y-1 border-l border-border pl-4">
          {locationsMenu.map(link => (
            <a href={link.href} class="block rounded-md px-2 py-1.5 text-sm hover:bg-accent transition-colors">{link.label}</a>
          ))}
        </div>
      </div>

      <a href="/business" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Business</a>
      <a href="/trade-in" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Trade-In</a>
      <a href="https://shop.mobiletechlab.ca" target="_blank" rel="noopener noreferrer" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Pre-Owned</a>
      <a href="/contact" class="block rounded-md px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">Contact</a>

      <div class="pt-3 flex flex-col gap-2">
        <a href="tel:2045009757" class="flex items-center justify-center gap-2 rounded-md border border-input bg-background px-4 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (204) 500-9757
        </a>
        <a href="https://shop.mobiletechlab.ca/pages/repair2" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
          Get a Quote
        </a>
      </div>

    </div>
  </div>

</header>

<script>
  import Alpine from 'alpinejs';
  if (!window.Alpine) {
    window.Alpine = Alpine;
    Alpine.start();
  }
</script>
