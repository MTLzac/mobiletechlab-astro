  { label: 'iPhone 11 Pro', href: '/devices/iphone-11-pro' },
  { label: 'iPhone 11', href: '/devices/iphone-11' },
  { label: 'iPhone XS Max', href: '/devices/iphone-xs-max' },
  { label: 'iPhone XS', href: '/devices/iphone-xs' },
  { label: 'iPhone XR', href: '/devices/iphone-xr' },
];

const locations = [
  { label: 'Winnipeg', href: '/location/winnipeg' },
  { label: 'Thompson', href: '/location/thompson' },
  { label: 'Brandon', href: '/service-area/brandon' },
  { label: 'Selkirk', href: '/service-area/selkirk' },
  { label: 'Steinbach', href: '/service-area/steinbach' },
  { label: 'Portage la Prairie', href: '/service-area/portage-la-prairie' },
  { label: 'The Pas', href: '/service-area/the-pas' },
  { label: 'All Service Areas', href: '/service-areas' },
