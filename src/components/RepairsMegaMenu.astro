---
const phones = [
  { name: "iPhone", href: "/repairs/iphone" },
  { name: "Samsung", href: "/repairs/samsung" },
  { name: "Google Pixel", href: "/repairs/google-pixel" },
  { name: "Motorola", href: "/repairs/motorola" },
  { name: "OnePlus", href: "/repairs/oneplus" },
  { name: "LG", href: "/repairs/lg" },
  { name: "Huawei", href: "/repairs/huawei" },
  { name: "Xiaomi", href: "/repairs/xiaomi" },
  { name: "Oppo", href: "/repairs/oppo" },
  { name: "Nothing", href: "/repairs/nothing" },
  { name: "Infinix", href: "/repairs/infinix" },
  { name: "TCL", href: "/repairs/tcl" },
  { name: "ZTE", href: "/repairs/zte" },
  { name: "Blackberry", href: "/repairs/blackberry" },
];

const tablets = [
  { name: "iPad", href: "/repairs/ipad" },
  { name: "Galaxy Tab", href: "/repairs/galaxy-tab" },
  { name: "Amazon Kindle/Fire", href: "/repairs/kindle-fire" },
];

const gaming = [
  { name: "All Console Repairs", href: "/repairs/consoles" },
  { name: "Nintendo Switch", href: "/repairs/nintendo-switch" },
  { name: "PlayStation 5", href: "/repairs/playstation-5" },
  { name: "PlayStation 4", href: "/repairs/playstation-4" },
  { name: "Xbox", href: "/repairs/xbox" },
  { name: "Steam Deck", href: "/repairs/steam-deck" },
];

const computers = [
  { name: "MacBook", href: "/repairs/macbook" },
  { name: "Microsoft Surface", href: "/repairs/microsoft-surface" },
  { name: "Laptop Repair", href: "/repairs/laptop" },
];

const otherDevices = [
  { name: "Apple Watch", href: "/repairs/apple-watch" },
  { name: "iPod", href: "/repairs/ipod" },
  { name: "Water Damage", href: "/repairs/water-damage" },
];

const specialty = [
  { name: "CAT S62 Charging Port", href: "/repairs/cat-s62-charging-port" },
  { name: "BlackMagic HDMI", href: "/repairs/blackmagic-hdmi" },
];
---

<div x-data="{ open: false }" class="relative" @mouseenter="open = true" @mouseleave="open = false">
  <button
    type="button"
    aria-haspopup="true"
    :aria-expanded="open"
    class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-semibold transition-colors hover:bg-accent hover:text-accent-foreground"
  >
    Repairs
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-150"
    x-transition:enter-start="opacity-0 translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-100"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-1"
    @click.away="open = false"
    role="navigation"
    aria-label="Repair services menu"
    class="absolute left-1/2 -translate-x-1/2 top-full rounded-xl border border-border bg-white shadow-2xl"
    style="width: 680px; z-index: 9999; margin-top: 0;"
  >
    <!-- View All CTA -->
    <div class="flex items-center border-b border-border px-6 py-3">
      <a href="/repairs" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        View All Repair Services
      </a>
    </div>

    <!-- Row One: Phone Repairs | Tablets | Gaming Consoles -->
    <div class="grid grid-cols-3 gap-0 px-6 pt-5 pb-4" style="border-bottom: 1px solid var(--border, #e5e7eb);">

      <!-- Phone Repairs -->
      <div class="pr-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          Phone Repairs
        </p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; column-gap: 0.75rem;">
          {phones.map(item => (
            <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
          ))}
        </div>
      </div>

      <!-- Tablets -->
      <div class="border-x border-border px-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          Tablets
        </p>
        {tablets.map(item => (
          <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
        ))}
      </div>

      <!-- Gaming Consoles -->
      <div class="pl-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="11" r="1"/><circle cx="17" cy="13" r="1"/><path d="M3 9l1.5 9h15L21 9a2 2 0 00-2-2H5a2 2 0 00-2 2z"/></svg>
          Gaming Consoles
        </p>
        {gaming.map(item => (
          <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
        ))}
      </div>

    </div>

    <!-- Row Two: Computers | Other Devices | Specialty Repairs -->
    <div class="grid grid-cols-3 gap-0 px-6 pt-4 pb-5">

      <!-- Computers -->
      <div class="pr-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          Computers
        </p>
        {computers.map(item => (
          <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
        ))}
      </div>

      <!-- Other Devices -->
      <div class="border-x border-border px-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Other Devices
        </p>
        {otherDevices.map(item => (
          <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
        ))}
      </div>

      <!-- Specialty Repairs -->
      <div class="pl-5">
        <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
          Specialty Repairs
        </p>
        {specialty.map(item => (
          <a href={item.href} class="block py-1 text-sm text-foreground hover:text-primary transition-colors">{item.name}</a>
        ))}
      </div>

    </div>
  </div>
</div>
