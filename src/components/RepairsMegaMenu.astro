---
const phones = [
  { name: "iPhone", href: "/repair/iphone" },
  { name: "Samsung", href: "/repair/samsung" },
  { name: "Google Pixel", href: "/repair/google-pixel" },
  { name: "Motorola", href: "/repair/motorola" },
  { name: "LG", href: "/repair/lg" },
  { name: "Huawei", href: "/repair/huawei" },
  { name: "Oppo", href: "/repair/oppo" },
  { name: "TCL", href: "/repair/tcl" },
  { name: "ZTE", href: "/repair/zte" },
];

const tablets = [
  { name: "iPad", href: "/repair/ipad" },
  { name: "Galaxy Tab", href: "/repair/samsung-galaxy-tab" },
  { name: "Amazon Kindle/Fire", href: "/repair/amazon-kindle" },
];

const gaming = [
  { name: "All Console Repairs", href: "/consoles" },
  { name: "Nintendo Switch", href: "/repair/nintendo-switch" },
  { name: "PlayStation 5", href: "/repair/ps5" },
  { name: "PlayStation 4", href: "/repair/ps4" },
  { name: "Xbox", href: "/repair/xbox" },
  { name: "Steam Deck", href: "/repair/steam-deck" },
];

const computers = [
  { name: "MacBook", href: "/repair/macbook" },
  { name: "Surface", href: "/repair/surface" },
  { name: "Laptop Repair", href: "/repair/laptop" },
];

const otherDevices = [
  { name: "Apple Watch", href: "/repair/apple-watch" },
  { name: "iPod", href: "/repair/ipod" },
  { name: "Water Damage", href: "/repair/water-damage" },
];
---

<div class="relative inline-block" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
  <button
    type="button"
    aria-haspopup="true"
    :aria-expanded="open.toString()"
    class="repairs-trigger"
  >
    Repairs
    <svg xmlns="http://www.w3.org/2000/svg" class="repairs-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true" width="12" height="12"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-150"
    x-transition:enter-start="opacity-0 translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-100"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-1"
    @click.away="open = false"
    role="navigation"
    aria-label="Repair services menu"
    class="mega-menu-panel"
  >
    <div class="mega-menu-header">
      <a href="/repairs">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        View All Repair Services
      </a>
    </div>

    <div class="mega-menu-row">
      <div class="mega-menu-col">
        <div class="mega-menu-category-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          <span class="mega-menu-category-label">Phone Repairs</span>
        </div>
        <div class="phone-brands-grid">
          {phones.map(item => (
            <a class="mega-menu-item" href={item.href}>{item.name}</a>
          ))}
        </div>
      </div>

      <div class="mega-menu-col">
        <div class="mega-menu-category-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          <span class="mega-menu-category-label">Tablets</span>
        </div>
        {tablets.map(item => (
          <a class="mega-menu-item" href={item.href}>{item.name}</a>
        ))}
      </div>

      <div class="mega-menu-col">
        <div class="mega-menu-category-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="11" r="1"/><circle cx="17" cy="13" r="1"/><path d="M3 9l1.5 9h15L21 9a2 2 0 00-2-2H5a2 2 0 00-2 2z"/></svg>
          <span class="mega-menu-category-label">Gaming Consoles</span>
        </div>
        {gaming.map(item => (
          <a class="mega-menu-item" href={item.href}>{item.name}</a>
        ))}
      </div>
    </div>

    <hr class="mega-menu-divider" />

    <div class="mega-menu-row">
      <div class="mega-menu-col">
        <div class="mega-menu-category-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span class="mega-menu-category-label">Computers</span>
        </div>
        {computers.map(item => (
          <a class="mega-menu-item" href={item.href}>{item.name}</a>
        ))}
      </div>

      <div class="mega-menu-col">
        <div class="mega-menu-category-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span class="mega-menu-category-label">Other Devices</span>
        </div>
        {otherDevices.map(item => (
          <a class="mega-menu-item" href={item.href}>{item.name}</a>
        ))}
      </div>

    </div>
  </div>
</div>

<style>
  .repairs-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 6px;
    transition: color 0.15s ease;
  }

  .repairs-trigger:hover {
    color: #ef4444;
  }

  .repairs-chevron {
    transition: transform 0.2s ease;
  }

  .repairs-trigger[aria-expanded='true'] .repairs-chevron {
    transform: rotate(180deg);
  }

  .mega-menu-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 680px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
    border: 1px solid #f0f0f0;
    padding: 24px 24px 32px 24px;
    z-index: 50;
    margin-top: 0;
  }

  .mega-menu-header {
    display: flex;
    align-items: center;
    padding-bottom: 16px;
    margin-bottom: 20px;
    border-bottom: 1px solid #f0f0f0;
  }

  .mega-menu-header a {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #ef4444;
    text-decoration: none;
  }

  .mega-menu-header a:hover {
    text-decoration: underline;
  }

  .mega-menu-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .mega-menu-col {
    padding: 0 20px;
    border-right: 1px solid #f0f0f0;
  }

  .mega-menu-col:first-child {
    padding-left: 0;
  }

  .mega-menu-col:last-child {
    padding-right: 0;
    border-right: none;
  }

  .mega-menu-divider {
    border: none;
    border-top: 1px solid #f0f0f0;
    margin: 20px 0;
  }

  .mega-menu-category-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
  }

  .mega-menu-category-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ef4444;
  }

  .phone-brands-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 12px;
  }

  .mega-menu-item {
    display: block;
    font-size: 13px;
    color: #374151;
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.15s ease;
  }

  .mega-menu-item:hover {
    color: #ef4444;
  }

  .mega-menu-col a {
    color: #374151;
    text-decoration: none;
  }

  .mega-menu-col a:hover {
    color: #ef4444;
  }
</style>
